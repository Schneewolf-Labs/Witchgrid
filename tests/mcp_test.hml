// mcp_test.hml — coverage for cp/mcp.hml
//
// The MCP layer is a pure JSON-RPC adapter: given a decoded message, a tools
// list (each a { name, description, schema } descriptor), and an `invoke`
// dispatch function, it produces the response envelope. We exercise it with
// synthetic stubs so the protocol framing — not any CP handler — is the unit
// under test.

import { describe, test, assert_eq } from "@stdlib/testing";
import { parse, stringify } from "@stdlib/json";
import { mcp_dispatch, mcp_handle } from "../cp/mcp";

// Three stub tools: one that succeeds, one that returns a non-2xx (so we can
// check the isError mapping), one that throws.
fn stub_tools(): array {
	return [
		{
			name: "echo_ok",
			description: "returns 200 with the args echoed",
			schema: { "type": "object", properties: { x: { "type": "string" } } },
		},
		{
			name: "always_404",
			description: "returns a 404 error body",
			schema: { "type": "object", properties: {} },
		},
		{
			name: "boom",
			description: "throws",
			schema: { "type": "object", properties: {} },
		},
	];
}

// The dispatch counterpart to stub_tools.
fn stub_invoke(name: string, args): object {
	if (name == "echo_ok") {
		return { status: 200, body: stringify({ got: args?.x ?? null }) };
	}
	if (name == "always_404") {
		return { status: 404, body: "{\"error\":\"nope\"}" };
	}
	if (name == "boom") {
		throw "kaboom";
	}
	return { status: 404, body: "{\"error\":\"unknown\"}" };
}

fn server_info(): object {
	return { name: "witchgrid-cp", version: "test" };
}

export fn register(): null {
	describe("mcp.mcp_dispatch (lifecycle)", fn() {
		test("initialize echoes the client's protocolVersion + serverInfo", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 1, method: "initialize",
				params: { protocolVersion: "2024-11-05" },
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.id, 1);
			assert_eq(resp.result.protocolVersion, "2024-11-05");
			assert_eq(resp.result.serverInfo.name, "witchgrid-cp");
			// Tools capability advertised so clients enable the surface.
			assert_eq(resp.result.capabilities.tools.listChanged, false);
		});

		test("initialize without a version falls back to a default", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 2, method: "initialize", params: {},
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.result.protocolVersion.length > 0, true);
		});

		test("ping returns an empty result", fn() {
			let resp = mcp_dispatch({ jsonrpc: "2.0", id: 3, method: "ping" },
				stub_tools(), stub_invoke, server_info());
			assert_eq(resp.id, 3);
			assert_eq(resp.result.keys().length, 0);
		});

		test("a notification (no id) gets no reply", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", method: "notifications/initialized",
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp, null);
		});
	});

	describe("mcp.mcp_dispatch (tools)", fn() {
		test("tools/list returns each tool's name + inputSchema", fn() {
			let resp = mcp_dispatch({ jsonrpc: "2.0", id: 4, method: "tools/list" },
				stub_tools(), stub_invoke, server_info());
			let tools = resp.result.tools;
			assert_eq(tools.length, 3);
			assert_eq(tools[0].name, "echo_ok");
			// Renamed schema → inputSchema on the wire.
			assert_eq(tools[0].inputSchema["type"], "object");
		});

		test("tools/call runs the tool and returns its body as text content", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 5, method: "tools/call",
				params: { name: "echo_ok", arguments: { x: "hi" } },
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.result.isError, false);
			let text = resp.result.content[0].text;
			let decoded = parse(text);
			assert_eq(decoded.got, "hi");
		});

		test("tools/call missing arguments defaults to empty object", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 6, method: "tools/call",
				params: { name: "echo_ok" },
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.result.isError, false);
			assert_eq(parse(resp.result.content[0].text).got, null);
		});

		test("a non-2xx tool result flips isError", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 7, method: "tools/call",
				params: { name: "always_404", arguments: {} },
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.result.isError, true);
		});

		test("a throwing tool becomes an isError result, not a dropped connection", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 8, method: "tools/call",
				params: { name: "boom", arguments: {} },
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.result.isError, true);
			assert_eq(resp.result.content[0].text.find("kaboom") >= 0, true);
		});

		test("unknown tool name → JSON-RPC invalid params (-32602)", fn() {
			let resp = mcp_dispatch({
				jsonrpc: "2.0", id: 9, method: "tools/call",
				params: { name: "ghost", arguments: {} },
			}, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.error.code, -32602);
		});

		test("unknown method → JSON-RPC method not found (-32601)", fn() {
			let resp = mcp_dispatch({ jsonrpc: "2.0", id: 10, method: "frobnicate" },
				stub_tools(), stub_invoke, server_info());
			assert_eq(resp.error.code, -32601);
		});
	});

	describe("mcp.mcp_handle (HTTP envelope)", fn() {
		test("a request body yields a 200 with a JSON-RPC body", fn() {
			let req = { method: "POST", path: "/mcp", headers: {},
				body: stringify({ jsonrpc: "2.0", id: 11, method: "ping" }) };
			let resp = mcp_handle(req, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.status, 200);
			assert_eq(parse(resp.body).id, 11);
		});

		test("a notification yields a bodyless 202", fn() {
			let req = { method: "POST", path: "/mcp", headers: {},
				body: stringify({ jsonrpc: "2.0", method: "notifications/initialized" }) };
			let resp = mcp_handle(req, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.status, 202);
			assert_eq(resp.body, "");
		});

		test("invalid JSON → 400 with a parse-error envelope", fn() {
			let req = { method: "POST", path: "/mcp", headers: {}, body: "{not json" };
			let resp = mcp_handle(req, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.status, 400);
			assert_eq(parse(resp.body).error.code, -32700);
		});

		test("empty body → 400", fn() {
			let req = { method: "POST", path: "/mcp", headers: {}, body: "" };
			let resp = mcp_handle(req, stub_tools(), stub_invoke, server_info());
			assert_eq(resp.status, 400);
		});
	});
	return null;
}
