// gguf_test.hml — coverage for cp/gguf.hml (the GGUF v3 metadata parser
// + VRAM estimator that capacity-aware placement rides on).
//
// Fixtures are synthetic header-only GGUFs generated by
// tests/fixtures/make_gguf_fixtures.py (valid magic + version + a few KV
// pairs, no tensor data — all the parser reads). Re-run that script to
// regenerate. These pin test-cases-todo.md #9 (Mistral-Nemo context lie),
// #11 (context cap), and #12 (bad magic), plus the kv/VRAM math.

import { describe, test, assert_eq, assert_throws } from "@stdlib/testing";
import {
	read_metadata, claimed_context, safe_context, kv_per_token_bytes,
	max_context_tokens, estimate_vram_mb, estimate_vram_from_ingredients
} from "../cp/gguf";

let NEMO   = "tests/fixtures/nemo_llama.gguf";    // llama, context_length=1024000 (lies)
let NORMAL = "tests/fixtures/normal_llama.gguf";  // llama, context_length=131072 (honest)
let V2     = "tests/fixtures/gguf_v2.gguf";       // valid magic, version=2
let BAD    = "tests/fixtures/bad_magic.bin";      // wrong magic

// Integer equality helper. The parser returns i64 (read_u32/read_u64),
// while bare literals are i32; assert_eq is strict on type, so normalize
// both sides to i64. (Float and string fields use assert_eq directly.)
fn eqi(actual, expected): null {
	assert_eq(i64(actual), i64(expected));
	return null;
}

export fn register(): null {
	describe("gguf.read_metadata", fn() {
		test("parses header + arch metadata from a v3 GGUF", fn() {
			let m = read_metadata(NEMO);
			eqi(m.version, 3);
			eqi(m.tensor_count, 0);
			eqi(m.metadata_kv_count, 7);
			assert_eq(m.meta["general.architecture"], "llama");
			assert_eq(m.meta["general.name"], "synthetic-nemo-12b");
			eqi(m.meta["llama.block_count"], 40);
			eqi(m.meta["llama.attention.head_count"], 32);
			eqi(m.meta["llama.attention.head_count_kv"], 8);
			eqi(m.meta["llama.embedding_length"], 5120);
		});
		test("throws a clear error on non-GGUF magic (#12)", fn() {
			assert_throws(fn() { read_metadata(BAD); });
		});
		test("throws on unsupported GGUF version", fn() {
			assert_throws(fn() { read_metadata(V2); });
		});
	});

	describe("gguf.claimed_context / safe_context (#9)", fn() {
		test("claimed_context returns the raw metadata value, lie and all", fn() {
			eqi(claimed_context(read_metadata(NEMO)), 1024000);
		});
		test("safe_context overrides Mistral-Nemo's 1024000 to the real 131072", fn() {
			eqi(safe_context(read_metadata(NEMO)), 131072);
		});
		test("safe_context leaves an honest llama context unchanged", fn() {
			let m = read_metadata(NORMAL);
			eqi(claimed_context(m), 131072);
			eqi(safe_context(m), 131072);
		});
	});

	describe("gguf.kv_per_token_bytes", fn() {
		test("2 * layers * kv_heads * head_dim * bpe (GQA, f16)", fn() {
			// head_dim = 5120/32 = 160; 2*40*8*160*2.0 = 204800
			assert_eq(kv_per_token_bytes(read_metadata(NEMO), "f16"), 204800.0);
		});
		test("q4_0 quant scales by 0.5625 bytes/elem", fn() {
			// 2*40*8*160*0.5625 = 57600
			assert_eq(kv_per_token_bytes(read_metadata(NEMO), "q4_0"), 57600.0);
		});
		test("unknown kv cache type throws", fn() {
			assert_throws(fn() { kv_per_token_bytes(read_metadata(NEMO), "q3_k_m"); });
		});
	});

	describe("gguf.max_context_tokens (#11)", fn() {
		test("caps at safe_context even when VRAM could fit far more", fn() {
			// 1 TB of headroom would mathematically allow billions of tokens;
			// must cap at the override-corrected trained context (131072).
			let m = read_metadata(NEMO);
			eqi(max_context_tokens(m, 1000000.0, "f16", 1024.0), 131072);
		});
		test("returns 0 when weights + activation overhead exceed VRAM", fn() {
			let m = read_metadata(NEMO);
			eqi(max_context_tokens(m, 1.0, "f16", 1024.0), 0);
		});
	});

	describe("gguf.estimate_vram_mb", fn() {
		test("breaks down weights + kv + activation overhead", fn() {
			let e = estimate_vram_mb(read_metadata(NEMO), 131072, "f16");
			assert_eq(e.architecture, "llama");
			eqi(e.n_layers, 40);
			eqi(e.n_kv_heads, 8);
			eqi(e.head_dim, 160);
			assert_eq(e.kv_per_token_b, 204800.0);
			assert_eq(e.activation_overhead_mb, 1024.0);
			// kv_total_mb = 204800 * 131072 / 1048576 = 25600
			assert_eq(e.kv_total_mb, 25600.0);
		});
		test("throws when general.architecture is absent (#18 guard)", fn() {
			assert_throws(fn() { estimate_vram_mb({ meta: {}, file_size: 0 }, 4096, "f16"); });
		});
	});

	describe("gguf.estimate_vram_from_ingredients (catalog path)", fn() {
		test("matches the file-parsed estimate for the same shape", fn() {
			let ing = { size_mb: 8000, architecture: "llama", n_layers: 40,
				n_heads: 32, n_kv_heads: 8, embedding_length: 5120 };
			let e = estimate_vram_from_ingredients(ing, 131072, "f16");
			eqi(e.head_dim, 160);
			assert_eq(e.kv_per_token_b, 204800.0);
			assert_eq(e.kv_total_mb, 25600.0);
			assert_eq(e.weights_mb, 8000.0);
			assert_eq(e.total_mb, 8000.0 + 25600.0 + 1024.0);
		});
		test("defaults n_kv_heads to n_heads when absent (non-GQA)", fn() {
			let ing = { size_mb: 100, architecture: "llama", n_layers: 1,
				n_heads: 4, n_kv_heads: null, embedding_length: 128 };
			let e = estimate_vram_from_ingredients(ing, 1024, "f16");
			eqi(e.n_kv_heads, 4);
		});
	});
	return null;
}
