// AUTO-GENERATED by scripts/embed_assets.sh from:
//   dashboard/index.html
//   dashboard/catalog.html
//   dashboard/transfers.html
//   dashboard/profiles.html
//   dashboard/bench.html
//   dashboard/deploy.html
//   dashboard/settings.html
//   dashboard/styles.css
//   dashboard/dashboard.js
//   assets/logo.svg
// Edit those source files, then re-run the script — do not edit
// this file by hand.

export let INDEX_HTML = "<!doctype html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\">
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">
  <title>witchgrid — overview</title>
  <link rel=\"icon\" type=\"image/svg+xml\" href=\"/assets/logo.svg\">
  <script>
    (function () {
      var t = null;
      try { t = localStorage.getItem('witchgrid-theme'); } catch (e) {}
      if (t !== 'light' && t !== 'dark') { t = 'dark'; }
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css\">
  <link rel=\"stylesheet\" href=\"/assets/styles.css\">
  <script src=\"https://unpkg.com/htmx.org@2.0.4\"></script>
  <script defer src=\"https://unpkg.com/alpinejs@3.14.3/dist/cdn.min.js\"></script>
  <script src=\"/assets/dashboard.js\"></script>
</head>
<body>
  <main x-data=\"themeToggle()\">
    <div class=\"topbar\">
      <div class=\"brand\">
        <img src=\"/assets/logo.svg\" alt=\"witchgrid\">
        <h1>witchgrid<span class=\"cursor\">_</span></h1>
        <span id=\"wg-version\" class=\"meta\" style=\"align-self:flex-end; padding-bottom:0.3rem\"></span>
      </div>
      <nav class=\"page-nav\">
        <a href=\"/\">overview</a>
        <a href=\"/catalog\">catalog</a>
        <a href=\"/profiles\">profiles</a>
        <a href=\"/utilities\">utilities</a>
        <a href=\"/deploy\">deploy</a>
        <a href=\"/settings\">settings</a>
      </nav>
      <button class=\"theme-toggle\" @click=\"toggle()\" :title=\"theme === 'dark' ? 'switch to light' : 'switch to dark'\">
        <span x-text=\"theme === 'dark' ? '☀' : '☾'\"></span>
      </button>
    </div>

    <!-- Failure-first health banner: pure function of the live SSE snapshot.
         Calm when healthy, loud (with one-click triage) when something's wrong. -->
    <div x-data=\"healthBanner()\" x-show=\"ready\" x-cloak
         class=\"health-banner\" :class=\"ok ? 'health-ok' : 'health-bad'\">
      <template x-if=\"ok\">
        <div class=\"health-line\"><span class=\"health-dot\"></span> All systems nominal · <span class=\"meta\" x-text=\"summary\"></span></div>
      </template>
      <template x-if=\"!ok\">
        <div>
          <div class=\"health-line\"><span class=\"health-dot\"></span> <strong x-text=\"headline\"></strong></div>
          <ul class=\"health-issues\">
            <template x-for=\"d in dead\" :key=\"d.id\">
              <li>
                <span class=\"badge badge-state-draining\" x-text=\"d.state === 'failed' ? 'failed' : 'down'\"></span>
                <code x-text=\"d.profile\"></code> on <code x-text=\"d.node\"></code> · port <code x-text=\"d.port\"></code>
                <button class=\"row-action\" @click=\"logs(d)\">logs</button>
                <button class=\"row-action row-action-danger\" @click=\"stop(d)\">stop</button>
              </li>
            </template>
            <template x-for=\"n in offline\" :key=\"n.node_id\">
              <li>
                <span class=\"badge\">offline</span>
                node <code x-text=\"n.node_id\"></code> — no recent heartbeat (services there are unreachable)
              </li>
            </template>
          </ul>
        </div>
      </template>
    </div>

    <div hx-get=\"/ui/stats\" hx-trigger=\"load, every 30s\" class=\"stats-wrap\">
      <div class=\"stats\">
        <div class=\"stat\"><p class=\"stat-label\">loading</p><p class=\"stat-value\">·</p></div>
      </div>
    </div>

    <section x-data=\"nodeEditor()\">
      <h2>Nodes</h2>
      <div hx-get=\"/ui/nodes\" hx-trigger=\"load, every 30s\">loading…</div>

      <!-- ── Node editor modal ─────────────────────────────────── -->
      <div class=\"modal-backdrop\" x-show=\"open\" x-cloak @click.self=\"cancel()\" style=\"display:none\">
        <div class=\"modal-card\" @click.stop style=\"max-width:560px\">
          <h3 style=\"margin:0 0 0.75rem 0\">edit <span x-text=\"node_id\"></span></h3>

          <div class=\"form-grid\">
            <div class=\"full\">
              <label>state</label>
              <div style=\"display:grid; gap:0.4rem; margin-top:0.25rem\">
                <label class=\"state-radio\">
                  <input type=\"radio\" x-model=\"state\" value=\"active\">
                  <strong>active</strong>
                  <span class=\"meta\">accept new spawns</span>
                </label>
                <label class=\"state-radio\">
                  <input type=\"radio\" x-model=\"state\" value=\"draining\">
                  <strong>draining</strong>
                  <span class=\"meta\">no new spawns; existing services keep running</span>
                </label>
                <label class=\"state-radio\">
                  <input type=\"radio\" x-model=\"state\" value=\"disabled\">
                  <strong>disabled</strong>
                  <span class=\"meta\">fully out of placement; node still visible for inspection</span>
                </label>
              </div>
            </div>
          </div>

          <p class=\"msg err\" x-show=\"error\" x-text=\"error\" style=\"margin-top:0.75rem\"></p>
          <div style=\"display:flex; gap:0.5rem; justify-content:flex-end; margin-top:1rem\">
            <button type=\"button\" class=\"row-action\" @click=\"cancel()\" :disabled=\"busy\">cancel</button>
            <button type=\"button\" @click=\"save()\" :disabled=\"busy\" x-text=\"busy ? '…' : 'save state'\"></button>
          </div>

          <hr style=\"margin:1.25rem 0; border:none; border-top:1px solid var(--border-soft)\">

          <h3 style=\"margin:0 0 0.5rem 0\">llama.cpp</h3>
          <p class=\"meta note-lg\">
            current: <code x-text=\"currentPath || '—'\"></code>
          </p>

          <div x-show=\"installs.length > 0\" style=\"margin-bottom:1rem\">
            <label style=\"display:block; font-family:ui-monospace,monospace; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--fg-dim); margin-bottom:0.25rem\">installed</label>
            <template x-for=\"inst in installs\" :key=\"inst.tag\">
              <div class=\"state-radio\" style=\"grid-template-columns: auto 1fr auto; padding:0.4rem 0.6rem\">
                <strong x-text=\"inst.tag\"></strong>
                <span>
                  <span x-show=\"inst.is_current\" class=\"badge badge-canonical\">current</span>
                  <span x-show=\"!inst.has_binary\" class=\"badge badge-scan\">no binary</span>
                </span>
                <button type=\"button\" class=\"row-action\" x-show=\"!inst.is_current && inst.has_binary\"
                        @click=\"activate(inst.tag)\" :disabled=\"installBusy\">activate</button>
              </div>
            </template>
          </div>

          <div class=\"form-grid\">
            <div>
              <label>install tag <span class=\"meta\">(e.g. b9124)</span></label>
              <input type=\"text\" x-model=\"installTag\" placeholder=\"b9124\">
            </div>
            <div>
              <label>flavor <span class=\"meta\" x-show=\"detectedFlavor\">(detected: <span x-text=\"detectedFlavor\"></span>)</span></label>
              <input type=\"text\" x-model=\"installFlavor\" placeholder=\"ubuntu-x64 / macos-arm64 / ubuntu-vulkan-x64\">
            </div>
          </div>

          <p class=\"msg\" :class=\"installMsg.startsWith('error') ? 'err' : 'ok'\" x-show=\"installMsg\" x-text=\"installMsg\" style=\"margin-top:0.75rem\"></p>

          <div style=\"display:flex; gap:0.5rem; justify-content:flex-end; margin-top:0.75rem\">
            <button type=\"button\" @click=\"installNew()\" :disabled=\"installBusy\" x-text=\"installBusy ? '…' : 'install build'\"></button>
          </div>
        </div>
      </div>
    </section>

    <section x-data=\"serviceLogModal()\">
      <h2>Services</h2>
      <div hx-get=\"/ui/services\" hx-trigger=\"load, every 30s\">loading…</div>

      <!-- Service log modal — opens via showServiceLog() from the
           rendered table's \"logs\" button. Polls every 3s while open. -->
      <div class=\"modal-backdrop\" x-show=\"open\" x-cloak @click.self=\"close()\" style=\"display:none\">
        <div class=\"modal-card\" @click.stop style=\"max-width:900px\">
          <h3 style=\"margin:0 0 0.25rem 0\">
            <span x-text=\"profile\"></span> · <span class=\"meta\" x-text=\"node + ' · ' + id.slice(0,8) + '…'\"></span>
          </h3>
          <p class=\"meta note\">
            Last 32 KB of <code>/tmp/witchgrid-&lt;id&gt;.log</code> on <span x-text=\"node\"></span>. Refreshes every 3s.
          </p>
          <p class=\"msg err\" x-show=\"err\" x-text=\"err\"></p>
          <pre id=\"service-log-body\" class=\"code-block\" style=\"max-height:60vh\" x-text=\"body || '(empty — service may not have written anything yet)'\"></pre>
          <div style=\"display:flex; gap:0.5rem; justify-content:flex-end; margin-top:0.75rem\">
            <button type=\"button\" class=\"row-action\" @click=\"refresh()\">refresh</button>
            <button type=\"button\" @click=\"close()\">close</button>
          </div>
        </div>
      </div>

      <!-- Connect modal — opens via showConnect() from the rendered
           table's \"connect\" button. Engine-aware copy-paste recipes. -->
      <div x-data=\"connectModal()\">
        <div class=\"modal-backdrop\" x-show=\"open\" x-cloak @click.self=\"close()\" @keydown.escape.window=\"close()\" style=\"display:none\">
          <div class=\"modal-card\" @click.stop style=\"max-width:760px\">
            <h3 style=\"margin:0 0 0.25rem 0\">
              Connect to <span x-text=\"profile\"></span>
              <span class=\"meta\" x-text=\"'· ' + binary + ' · ' + node + ' :' + port\"></span>
            </h3>
            <p class=\"meta note\" x-show=\"authEnabled\" style=\"color:var(--accent)\">
              🔒 Auth is on — examples include a Bearer header. Export your secret first:
              <code>export WITCHGRID_SECRET=…</code>
            </p>
            <p class=\"meta note\">
              Three ways in, most-robust first: the <strong>control plane</strong> proxy (auto-spawns + follows the
              service across nodes), <strong>resolve-then-connect</strong> (CP off the data path), or a
              <strong>direct</strong> pin to this process.
            </p>

            <template x-for=\"(b, i) in blocks\" :key=\"i\">
              <div class=\"connect-block\">
                <div class=\"connect-block-head\">
                  <span class=\"connect-block-title\" x-text=\"b.title\"></span>
                  <span class=\"badge badge-state-active\" x-show=\"b.recommended\">recommended</span>
                  <button type=\"button\" class=\"row-action connect-copy\" @click=\"copyText(b.code, $event.target)\">copy</button>
                </div>
                <p class=\"meta note\" x-show=\"b.note\" x-text=\"b.note\" style=\"margin:0.15rem 0 0.35rem 0\"></p>
                <pre class=\"code-block\" x-text=\"b.code\"></pre>
              </div>
            </template>

            <div style=\"display:flex; gap:0.5rem; justify-content:flex-end; margin-top:0.75rem\">
              <button type=\"button\" @click=\"close()\">close</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <details class=\"ov-collapse\" data-detail-key=\"ov-spawn\">
      <summary><h2>Spawn</h2> <span class=\"meta\">quick spawn — full guided flow on <a href=\"/deploy\">deploy →</a></span></summary>
      <form class=\"spawn\" x-data=\"spawnForm()\" @submit.prevent=\"submit()\">
        <div>
          <label for=\"prof\">profile</label>
          <select id=\"prof\" x-model=\"profileName\" @change=\"onProfileChange()\" required>
            <option value=\"\">— select —</option>
            <template x-for=\"name in Object.keys(profiles)\" :key=\"name\">
              <option :value=\"name\" x-text=\"name\"></option>
            </template>
          </select>
        </div>
        <div>
          <label for=\"mdl\">model path <span class=\"meta\">(optional — alias resolves via catalog if blank)</span></label>
          <input id=\"mdl\" type=\"text\" x-model=\"model\" placeholder=\"/path/to/model.gguf or leave blank for catalog\">
        </div>
        <button type=\"submit\" :disabled=\"busy\" x-text=\"busy ? '…' : 'spawn'\"></button>

        <p class=\"meta\" style=\"grid-column: 1 / -1; margin: 0\"
           x-show=\"profileName && preview\"
           x-text=\"preview\"></p>

        <!-- Pin placement: visible by default since you almost always
             want it during bring-up. Auto = leave empty. -->
        <div>
          <label for=\"sp-node\">node <span class=\"meta\">(blank = auto)</span></label>
          <select id=\"sp-node\" x-model=\"node_id\">
            <option value=\"\">— auto —</option>
            <template x-for=\"n in nodes\" :key=\"n.node_id\">
              <option :value=\"n.node_id\" x-text=\"n.node_id + ' · ' + n.role + (n.state === 'active' ? '' : ' (' + n.state + ')')\"></option>
            </template>
          </select>
        </div>
        <div>
          <label for=\"sp-gpus\">gpus <span class=\"meta\">(comma-separated, blank = auto)</span></label>
          <input id=\"sp-gpus\" type=\"text\" x-model=\"gpus\" placeholder=\"e.g. 0,2\">
        </div>
        <div>
          <label for=\"sp-port\">port <span class=\"meta\">(blank = auto)</span></label>
          <input id=\"sp-port\" type=\"number\" x-model=\"port\" placeholder=\"e.g. 18080\">
        </div>

        <p class=\"msg\" :class=\"isError ? 'err' : 'ok'\" x-show=\"message\" x-text=\"message\"></p>
      </form>
    </details>

  </main>
  <footer style=\"text-align:center; padding:1.5rem; font-size:0.82rem; color:var(--fg-dim)\">
    made with love 💜 by <a href=\"https://schneewolflabs.com/\" target=\"_blank\" rel=\"noopener\" style=\"color:#a855f7\">schneewolf labs</a>
    <div id=\"wg-footer-info\" class=\"meta\"></div>
  </footer>
</body>
</html>
";

export let CATALOG_HTML = "<!doctype html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\">
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">
  <title>witchgrid — catalog</title>
  <link rel=\"icon\" type=\"image/svg+xml\" href=\"/assets/logo.svg\">
  <script>
    (function () {
      var t = null;
      try { t = localStorage.getItem('witchgrid-theme'); } catch (e) {}
      if (t !== 'light' && t !== 'dark') { t = 'dark'; }
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css\">
  <link rel=\"stylesheet\" href=\"/assets/styles.css\">
  <script src=\"https://unpkg.com/htmx.org@2.0.4\"></script>
  <script defer src=\"https://unpkg.com/alpinejs@3.14.3/dist/cdn.min.js\"></script>
  <script src=\"/assets/dashboard.js\"></script>
</head>
<body>
  <main x-data=\"themeToggle()\">
    <div class=\"topbar\">
      <div class=\"brand\">
        <img src=\"/assets/logo.svg\" alt=\"witchgrid\">
        <h1>witchgrid<span class=\"cursor\">_</span></h1>
        <span id=\"wg-version\" class=\"meta\" style=\"align-self:flex-end; padding-bottom:0.3rem\"></span>
      </div>
      <nav class=\"page-nav\">
        <a href=\"/\">overview</a>
        <a href=\"/catalog\">catalog</a>
        <a href=\"/profiles\">profiles</a>
        <a href=\"/utilities\">utilities</a>
        <a href=\"/deploy\">deploy</a>
        <a href=\"/settings\">settings</a>
      </nav>
      <button class=\"theme-toggle\" @click=\"toggle()\" :title=\"theme === 'dark' ? 'switch to light' : 'switch to dark'\">
        <span x-text=\"theme === 'dark' ? '☀' : '☾'\"></span>
      </button>
    </div>

    <div hx-get=\"/ui/stats\" hx-trigger=\"load, every 30s\" class=\"stats-wrap\">
      <div class=\"stats\">
        <div class=\"stat\"><p class=\"stat-label\">loading</p><p class=\"stat-value\">·</p></div>
      </div>
    </div>

    <div x-data=\"{ tab: 'catalog' }\" @wg-find-quants.window=\"tab='hf'\">
      <div class=\"tabbar\">
        <button type=\"button\" class=\"tab-btn\" :class=\"tab==='catalog' ? 'active' : ''\" @click=\"tab='catalog'\">catalog</button>
        <button type=\"button\" class=\"tab-btn\" :class=\"tab==='hf' ? 'active' : ''\" @click=\"tab='hf'\">huggingface</button>
        <button type=\"button\" class=\"tab-btn\" :class=\"tab==='transfers' ? 'active' : ''\" @click=\"tab='transfers'\">transfers</button>
        <button type=\"button\" class=\"tab-btn\" :class=\"tab==='missing' ? 'active' : ''\" @click=\"tab='missing'\">missing</button>
      </div>

    <div x-show=\"tab==='missing'\">
    <section>
      <h2>Missing</h2>
      <p class=\"meta note\">Aliases referenced by a profile but not on disk anywhere in the fleet. If the profile names an HF source, pull from here.</p>
      <div hx-get=\"/ui/missing\" hx-trigger=\"load, every 30s\">loading…</div>
    </section>
    </div>

    <div x-show=\"tab==='hf'\">
    <section x-data=\"hfPull()\">
      <h2>Pull from HuggingFace</h2>
      <p class=\"meta note-lg\">
        Search HF for a GGUF, pick a quant, send it to a node. Files land
        in the agent's canonical model dir and the catalog rescans
        automatically once the transfer completes.
      </p>

      <form class=\"spawn\" @submit.prevent=\"search()\">
        <div style=\"grid-column: 1 / -1\">
          <label for=\"hfq\">search</label>
          <input id=\"hfq\" type=\"text\" x-model=\"q\" placeholder=\"e.g. hemlock-apothecary-7b\">
        </div>
        <button type=\"submit\" :disabled=\"searching\" x-text=\"searching ? '…' : 'search'\"></button>
        <p class=\"msg err\" x-show=\"err\" x-text=\"err\"></p>
      </form>

      <div class=\"catalog-controls\" style=\"margin-top:0.4rem\">
        <span class=\"meta\">discover</span>
        <label class=\"meta\">sort
          <select x-model=\"discoverSort\">
            <option value=\"trending\">trending</option>
            <option value=\"newest\">newest</option>
            <option value=\"likes\">most liked</option>
            <option value=\"downloads\">most downloaded</option>
          </select>
        </label>
        <label class=\"meta\">from
          <select x-model=\"discoverAuthor\">
            <option value=\"\">anyone</option>
            <template x-for=\"a in trustedAuthors\" :key=\"a\"><option :value=\"a\" x-text=\"a\"></option></template>
          </select>
        </label>
        <button type=\"button\" class=\"row-action\" @click=\"discover()\" :disabled=\"discovering\" x-text=\"discovering ? '…' : 'discover'\"></button>
        <span class=\"meta\">trusted authors set in <a href=\"/settings\">settings</a></span>
      </div>

      <div x-show=\"repos.length > 0\" style=\"margin-top:1rem\">
        <table>
          <thead><tr><th>repo</th><th>downloads</th><th>likes</th><th></th></tr></thead>
          <tbody>
            <template x-for=\"r in repos\" :key=\"r.id\">
              <tr :class=\"r.id === selectedRepo ? 'row-selected' : ''\">
                <td><code x-text=\"r.id\"></code> <span x-show=\"r.trusted\" class=\"badge badge-state-active\" title=\"trusted quanter\">trusted</span></td>
                <td><span class=\"meta\" x-text=\"(r.downloads||0).toLocaleString()\"></span></td>
                <td><span class=\"meta\" x-text=\"r.likes\"></span></td>
                <td><button type=\"button\" class=\"row-action\"
                            @click=\"loadFiles(r.id)\"
                            :disabled=\"loadingFiles\"
                            x-text=\"r.id === selectedRepo ? 'selected' : 'list files'\"></button></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>

      <p class=\"meta\" x-show=\"cardLoading\" style=\"margin-top:1rem\">loading model card…</p>
      <div x-show=\"card\" class=\"hf-card\">
        <template x-if=\"card && card.image\">
          <img class=\"hf-card-art\" :src=\"card.image\" alt=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer\">
        </template>
        <div class=\"hf-card-meta\">
          <strong class=\"hf-card-title\" x-text=\"card?.id\"></strong>
          <p class=\"meta\" x-show=\"card?.summary\" x-text=\"card?.summary\"></p>
          <div class=\"hf-card-stats\">
            <span class=\"badge badge-state-active\" x-show=\"card?.pipeline_tag\" x-text=\"card?.pipeline_tag\"></span>
            <span class=\"badge badge-scan\" x-show=\"card?.license\" x-text=\"'license: ' + (card?.license)\"></span>
            <span class=\"meta\">⬇ <span x-text=\"(card?.downloads || 0).toLocaleString()\"></span></span>
            <span class=\"meta\">♥ <span x-text=\"card?.likes || 0\"></span></span>
          </div>
          <div class=\"hf-card-tags\">
            <template x-for=\"t in (card?.tags || [])\" :key=\"t\"><span class=\"badge badge-scan\" x-text=\"t\"></span></template>
          </div>
        </div>
      </div>

      <div x-show=\"files.length > 0\" style=\"margin-top:1rem\">
        <h3 style=\"margin:0 0 0.5rem 0\">files in <code x-text=\"selectedRepo\"></code></h3>
        <table>
          <thead><tr><th>file</th><th>quant</th><th>size</th><th>alias</th><th>node</th><th></th></tr></thead>
          <tbody>
            <template x-for=\"f in files\" :key=\"f.path\">
              <tr>
                <td>
                  <code x-text=\"f.path\"></code>
                  <span x-show=\"f.sharded\" class=\"badge badge-scan\" style=\"margin-left:0.4rem\">sharded</span>
                </td>
                <td><span class=\"badge badge-state-active\" x-text=\"ggufQuant(f.path)\"></span></td>
                <td><span class=\"meta\" x-text=\"formatSize(f.size)\"></span></td>
                <td><code class=\"meta\" x-text=\"aliasFor(f.path)\"></code></td>
                <td>
                  <select x-model=\"targets[f.path]\" style=\"font-family:ui-monospace,monospace; font-size:0.8rem\">
                    <option value=\"\">target…</option>
                    <template x-for=\"n in nodes\" :key=\"n.node_id\">
                      <option :value=\"n.node_id\" x-text=\"n.node_id\"></option>
                    </template>
                  </select>
                </td>
                <td>
                  <button type=\"button\" class=\"row-action\"
                          @click=\"pull(f)\"
                          :disabled=\"!targets[f.path] || pullingPath === f.path\"
                          x-text=\"pullingPath === f.path ? '…' : 'pull'\"></button>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
        <p class=\"msg\" :class=\"pullMsg.startsWith('error') ? 'err' : 'ok'\" x-show=\"pullMsg\" x-text=\"pullMsg\" style=\"margin-top:0.5rem\"></p>
        <p x-show=\"lastPulled\" style=\"margin-top:0.5rem\">
          <a :href=\"profileCtaUrl()\" class=\"row-action\" style=\"text-decoration:none; display:inline-block\">
            + create profile for <code x-text=\"lastPulled?.alias\"></code>
          </a>
        </p>
        <p class=\"meta\" style=\"margin-top:0.5rem\">Once started, watch progress in <strong>Transfers</strong> below.</p>
      </div>
    </section>
    </div>

    <div x-show=\"tab==='catalog'\">
    <section x-data=\"catalogBrowser()\">
      <h2>Catalog</h2>
      <p class=\"meta note\">Models discovered on each node. Search, expand a model for its GGUF metadata, or copy it to another node.</p>
      <div class=\"catalog-controls\">
        <input type=\"text\" x-model=\"q\" placeholder=\"filter by alias, architecture, or name…\">
        <label class=\"meta\">arch
          <select x-model=\"archFilter\">
            <option value=\"\">all</option>
            <template x-for=\"a in architectures\" :key=\"a\"><option :value=\"a\" x-text=\"a\"></option></template>
          </select>
        </label>
        <label class=\"meta\">sort
          <select x-model=\"sortBy\">
            <option value=\"alias\">alias A→Z</option>
            <option value=\"size\">size ↓</option>
            <option value=\"arch\">architecture</option>
            <option value=\"nodes\">on nodes ↓</option>
          </select>
        </label>
        <span class=\"meta\" x-show=\"!loading\" x-text=\"filtered.length + ' / ' + models.length\"></span>
      </div>

      <details class=\"ov-collapse\" style=\"margin:0 0 1rem\">
        <summary><h2>scan directories</h2> <span class=\"meta\">edit where a node looks for models</span></summary>
        <div style=\"background:var(--bg-1); border:1px solid var(--border); border-radius:8px; padding:1rem; max-width:640px\">
          <label>node</label>
          <select x-model=\"sd.node\" @change=\"loadScanDirs()\" style=\"max-width:320px\">
            <option value=\"\">— select node —</option>
            <template x-for=\"n in nodes\" :key=\"n.node_id\"><option :value=\"n.node_id\" x-text=\"n.node_id\"></option></template>
          </select>
          <div x-show=\"sd.node\" style=\"margin-top:0.75rem\">
            <p class=\"meta\" style=\"margin:0 0 0.5rem\">canonical (pulls land here; set via env, read-only): <code x-text=\"sd.canonical || '—'\"></code></p>
            <label>extra scan dirs <span class=\"meta\">(one path per line)</span></label>
            <textarea x-model=\"sd.extra\" rows=\"3\" placeholder=\"/mnt/models&#10;/data/gguf\"
                      class=\"ta-mono\"></textarea>
            <div style=\"display:flex; gap:0.6rem; align-items:center; margin-top:0.5rem\">
              <button type=\"button\" @click=\"saveScanDirs()\" :disabled=\"sd.busy\" x-text=\"sd.busy ? '…' : 'save + rescan'\"></button>
              <span class=\"meta\" x-text=\"sd.msg\"></span>
            </div>
          </div>
        </div>
      </details>

      <p class=\"meta\" x-show=\"loading\">loading…</p>
      <p class=\"empty\" x-show=\"!loading && filtered.length === 0\"
         x-text=\"q ? 'no models match “' + q + '”' : 'No models in any node catalog. Set WITCHGRID_MODEL_DIR on an agent.'\"></p>
      <div class=\"node-card-procs\" style=\"border-top:none; margin-top:0; padding-top:0\" x-show=\"filtered.length > 0\">
        <template x-for=\"m in filtered\" :key=\"m.alias\">
          <details class=\"proc-item\" @toggle=\"$event.target.open && loadModelCard(m)\">
            <summary class=\"proc-summary\">
              <strong class=\"proc-name\" x-text=\"m.alias\"></strong>
              <span class=\"badge badge-scan\" x-text=\"m.architecture || '?'\"></span>
              <code class=\"proc-port\" x-text=\"fmtSize(m.size_mb)\"></code>
              <span class=\"meta proc-model\" x-text=\"(m.on_nodes ? m.on_nodes.length : 0) + ' node' + ((m.on_nodes && m.on_nodes.length === 1) ? '' : 's')\"></span>
              <span class=\"proc-chevron\">›</span>
            </summary>
            <template x-if=\"modelCards[m.alias] && modelCards[m.alias].image\">
              <div class=\"hf-card\" style=\"margin:0 0 0.6rem\">
                <img class=\"hf-card-art\" style=\"width:96px; height:96px\" :src=\"modelCards[m.alias].image\" alt=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer\">
                <div class=\"hf-card-meta\">
                  <span class=\"meta\" x-show=\"modelCards[m.alias].summary\" x-text=\"modelCards[m.alias].summary\"></span>
                  <div class=\"hf-card-stats\">
                    <span class=\"meta\" x-show=\"modelCards[m.alias].likes\">♥ <span x-text=\"modelCards[m.alias].likes\"></span></span>
                    <span class=\"meta\" x-show=\"modelCards[m.alias].downloads\">⬇ <span x-text=\"(modelCards[m.alias].downloads||0).toLocaleString()\"></span></span>
                  </div>
                </div>
              </div>
            </template>
            <div class=\"detail-grid\">
              <div><span class=\"dk\">name</span><span x-text=\"m.general_name || '—'\"></span></div>
              <div><span class=\"dk\">arch</span><code x-text=\"m.architecture || '—'\"></code></div>
              <div><span class=\"dk\">context</span><code x-text=\"m.claimed_context ? Number(m.claimed_context).toLocaleString() : '—'\"></code></div>
              <div><span class=\"dk\">size</span><span x-text=\"fmtSize(m.size_mb)\"></span></div>
              <div class=\"detail-wide\"><span class=\"dk\">source</span>
                <template x-if=\"m.source_url\"><a :href=\"m.source_url\" target=\"_blank\" x-text=\"m.source_url\"></a></template>
                <template x-if=\"!m.source_url\"><span class=\"meta\">—</span></template>
              </div>
              <div class=\"detail-wide\"><span class=\"dk\">quants</span>
                <button type=\"button\" class=\"row-action\" @click=\"findQuants(m)\">⊕ find other quants / sources</button>
                <span class=\"meta\" style=\"margin-left:0.4rem\">searches HuggingFace for other quantizations of this model</span>
              </div>
              <div class=\"detail-wide\"><span class=\"dk\">spawn</span>
                <template x-if=\"matchingProfiles(m).length > 0\">
                  <span style=\"display:inline-flex; gap:0.4rem; align-items:center; flex-wrap:wrap\">
                    <select x-model=\"spawnSel[m.alias]\" style=\"font-family:ui-monospace,monospace; font-size:0.8rem\">
                      <option value=\"\">profile…</option>
                      <template x-for=\"pn in matchingProfiles(m)\" :key=\"pn\"><option :value=\"pn\" x-text=\"pn\"></option></template>
                    </select>
                    <button type=\"button\" class=\"row-action\" @click=\"spawnModel(m)\" :disabled=\"!spawnSel[m.alias]\">spawn</button>
                    <span class=\"meta\" x-show=\"spawnMsg[m.alias]\" x-text=\"spawnMsg[m.alias]\"></span>
                  </span>
                </template>
                <template x-if=\"matchingProfiles(m).length === 0\">
                  <a class=\"row-action\" :href=\"profileCreateUrl(m)\" style=\"text-decoration:none; display:inline-block\">+ create a profile to spawn this</a>
                </template>
              </div>
              <div class=\"detail-wide\"><span class=\"dk\">on nodes</span>
                <div>
                  <template x-for=\"on in m.on_nodes\" :key=\"on.node_id\">
                    <div class=\"catalog-node\" style=\"display:flex; gap:0.5rem; align-items:center; padding:0.15rem 0\">
                      <strong x-text=\"on.node_id\"></strong>
                      <code class=\"meta\" style=\"flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis\" x-text=\"on.path\"></code>
                      <button type=\"button\" class=\"row-action row-action-danger\" @click=\"askDelete(m.alias, on.node_id, on.path)\">delete</button>
                    </div>
                  </template>
                </div>
              </div>
              <div class=\"detail-wide\" x-show=\"copyTargets(m).length > 0\">
                <span class=\"dk\">copy to</span>
                <select x-model=\"copyTo[m.alias]\" style=\"font-family:ui-monospace,monospace; font-size:0.8rem\">
                  <option value=\"\">target node…</option>
                  <template x-for=\"nid in copyTargets(m)\" :key=\"nid\"><option :value=\"nid\" x-text=\"nid\"></option></template>
                </select>
                <button type=\"button\" class=\"row-action\" @click=\"distribute(m)\" :disabled=\"!copyTo[m.alias]\">pull</button>
                <span class=\"meta\" x-show=\"msg[m.alias]\" x-text=\"msg[m.alias]\" style=\"margin-left:0.5rem\"></span>
              </div>
            </div>
          </details>
        </template>
      </div>

      <!-- delete confirmation modal -->
      <div class=\"modal-backdrop\" x-show=\"del.open\" x-cloak @click.self=\"cancelDelete()\" style=\"display:none\">
        <div class=\"modal-card\" @click.stop style=\"max-width:560px\">
          <h3 style=\"margin:0 0 0.5rem 0\">Delete model?</h3>
          <p class=\"meta note-lg\">
            Permanently removes this file from disk on <strong x-text=\"del.node\"></strong>. This cannot be undone.
          </p>
          <div class=\"detail-grid\" style=\"padding-left:0\">
            <div><span class=\"dk\">alias</span><code x-text=\"del.alias\"></code></div>
            <div class=\"detail-wide\"><span class=\"dk\">path</span><code x-text=\"del.path\"></code></div>
          </div>
          <p class=\"msg err\" x-show=\"del.err\" x-text=\"del.err\" style=\"margin-top:0.5rem\"></p>
          <div style=\"display:flex; gap:0.5rem; justify-content:flex-end; margin-top:1rem\">
            <button type=\"button\" class=\"row-action\" @click=\"cancelDelete()\" :disabled=\"del.busy\">cancel</button>
            <button type=\"button\" class=\"row-action row-action-danger\" @click=\"confirmDelete()\" :disabled=\"del.busy\" x-text=\"del.busy ? '…' : 'delete'\"></button>
          </div>
        </div>
      </div>
    </section>
    </div>

    <div x-show=\"tab==='transfers'\">
    <section>
      <h2>Transfers</h2>
      <p class=\"meta note\">In-flight + recent model pulls/distributions across the fleet. Polls every 5s.</p>
      <div hx-get=\"/ui/transfers\" hx-trigger=\"load, every 5s\">loading…</div>
    </section>
    </div>
    </div>
  </main>
  <footer style=\"text-align:center; padding:1.5rem; font-size:0.82rem; color:var(--fg-dim)\">
    made with love 💜 by <a href=\"https://schneewolflabs.com/\" target=\"_blank\" rel=\"noopener\" style=\"color:#a855f7\">schneewolf labs</a>
    <div id=\"wg-footer-info\" class=\"meta\"></div>
  </footer>

  <script>
    function hfPull() {
      return {
        q: '',
        repos: [], files: [], nodes: [], targets: {},
        selectedRepo: '',
        card: null, cardLoading: false,
        discoverSort: 'trending', discoverAuthor: '', trustedAuthors: [], discovering: false,
        searching: false, loadingFiles: false,
        pullingPath: '', pullMsg: '', err: '',
        async init() {
          try {
            const r = await fetch('/nodes');
            this.nodes = (await r.json()).filter(n => (n.state || 'active') !== 'disabled');
          } catch (e) { /* nodes optional for search */ }
          try {
            const rc = await fetch('/api/config');
            if (rc.ok) {
              const cfg = await rc.json();
              this.trustedAuthors = (cfg.hf_trusted_authors || '').split(',').map(s => s.trim()).filter(Boolean);
            }
          } catch (e) { /* discover author filter just won't list trusted handles */ }
          // \"find other quants\" hand-off from a catalog model: prefill the
          // search with the base model name and run it (repos = sources).
          window.addEventListener('wg-find-quants', (e) => {
            this.q = (e.detail && e.detail.base) || '';
            if (this.q) this.search();
          });
        },
        // Discover: top GGUF repos by sort, optionally from one trusted author.
        // Populates the same `repos` list the search uses → reuses the whole
        // list-files → card-art → pull flow.
        async discover() {
          this.discovering = true; this.err = '';
          this.repos = []; this.files = []; this.selectedRepo = ''; this.card = null;
          try {
            const r = await fetch('/api/hf/discover', {
              method: 'POST', headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ sort: this.discoverSort, author: this.discoverAuthor }),
            });
            const d = await r.json();
            if (!r.ok) { this.err = 'error: ' + (d.error || 'HTTP ' + r.status); }
            else if (d.length === 0) { this.err = 'no models found'; }
            else { this.repos = d; }
          } catch (e) { this.err = 'error: ' + e; }
          this.discovering = false;
        },
        // Extract the quant tag from a GGUF filename (Q4_K_M, IQ4_XS, F16…).
        ggufQuant(path) {
          const m = (path || '').match(/(IQ\\d+[A-Z0-9_]*|Q\\d+_K_[SML]|Q\\d+_K|Q\\d+_\\d+|Q\\d+|BF16|F16|F32)/i);
          return m ? m[1].toUpperCase() : '—';
        },
        async search() {
          if (!this.q.trim()) return;
          this.searching = true; this.err = ''; this.repos = []; this.files = []; this.selectedRepo = ''; this.card = null;
          try {
            const r = await fetch('/api/hf/search', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ q: this.q.trim() }),
            });
            const d = await r.json();
            if (!r.ok) { this.err = 'error: ' + (d.error || 'HTTP ' + r.status); }
            else if (d.length === 0) { this.err = 'no GGUF repos matched'; }
            else { this.repos = d; }
          } catch (e) { this.err = 'error: ' + e; }
          this.searching = false;
        },
        // Scrape the model-card metadata + (HF-hosted, sanitized) image for
        // the \"album art\" panel. Server validates the image source.
        async loadCard(repoId) {
          this.card = null; this.cardLoading = true;
          try {
            const r = await fetch('/api/hf/card', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ repo: repoId }),
            });
            if (r.ok) this.card = await r.json();
          } catch (e) { /* card is best-effort; files still work */ }
          this.cardLoading = false;
        },
        async loadFiles(repoId) {
          this.loadingFiles = true; this.selectedRepo = repoId; this.files = []; this.pullMsg = '';
          this.loadCard(repoId);   // fire-and-forget; album art fills in
          try {
            const r = await fetch('/api/hf/files', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ repo: repoId }),
            });
            const d = await r.json();
            if (!r.ok) { this.err = 'error: ' + (d.error || 'HTTP ' + r.status); }
            else if (d.length === 0) { this.err = 'no .gguf files in repo (?)'; }
            else { this.files = d; this.err = ''; }
          } catch (e) { this.err = 'error: ' + e; }
          this.loadingFiles = false;
        },
        lastPulled: null,
        async pull(f) {
          const target = this.targets[f.path];
          if (!target) { this.pullMsg = 'error: pick a target node'; return; }
          this.pullingPath = f.path; this.pullMsg = '';
          const alias = this.aliasFor(f.path);
          try {
            const r = await fetch('/models/pull_hf', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                repo: this.selectedRepo,
                file: f.path,
                target_node: target,
                alias: alias,
              }),
            });
            const d = await r.json();
            if (!r.ok) {
              this.pullMsg = 'error: ' + (d.error || 'HTTP ' + r.status);
            } else {
              this.pullMsg = 'queued ' + d.alias + ' → ' + target + ' (transfer ' + d.transfer_id + ')';
              // Stash pull info so the CTA can pre-fill the profile
              // editor once the operator clicks through. We don't wait
              // for the transfer to complete — the editor doesn't need
              // the model on disk to save a profile that names the alias.
              this.lastPulled = { alias, repo: this.selectedRepo, file: f.path };
            }
          } catch (e) { this.pullMsg = 'error: ' + e; }
          this.pullingPath = '';
        },
        // Build the URL that opens /profiles with the editor pre-filled
        // for the just-pulled alias + HF source. The profiles page picks
        // up the query string on load via its prefill handler.
        profileCtaUrl() {
          if (!this.lastPulled) return '#';
          const q = new URLSearchParams({
            prefill_alias: this.lastPulled.alias,
            prefill_hf_repo: this.lastPulled.repo,
            prefill_hf_file: this.lastPulled.file,
          });
          return '/profiles?' + q.toString();
        },
        aliasFor(path) {
          let base = path.split('/').pop().replace(/\\.gguf$/i, '');
          const shard = base.indexOf('-00001-of-');
          if (shard > 0) base = base.substring(0, shard);
          return base.toLowerCase();
        },
        formatSize(bytes) {
          if (bytes >= 1073741824) {
            return (bytes / 1073741824).toFixed(2) + ' GB';
          }
          if (bytes >= 1048576) {
            return Math.round(bytes / 1048576) + ' MB';
          }
          return Math.round(bytes / 1024) + ' KB';
        },
      };
    }

    // Searchable, expandable catalog browser (replaces the static table).
    // Pulls /api/catalog (full GGUF metadata) + /nodes (copy-to targets);
    // each model expands to its metadata and a copy-to-node control.
    function catalogBrowser() {
      return {
        models: [], nodes: [], profiles: {}, q: '', sortBy: 'alias', archFilter: '', loading: true,
        copyTo: {}, msg: {}, spawnSel: {}, spawnMsg: {}, modelCards: {},
        async init() {
          await this.load();
          setInterval(() => this.load(), 15000);
        },
        async load() {
          try {
            const [rc, rn, rp] = await Promise.all([fetch('/api/catalog'), fetch('/nodes'), fetch('/api/profiles')]);
            if (rc.ok) this.models = await rc.json();
            if (rn.ok) this.nodes = await rn.json();
            if (rp.ok) this.profiles = await rp.json();
          } catch (e) { /* keep last good data */ }
          this.loading = false;
        },
        // Profiles that resolve to this catalog model (so it can be spawned
        // directly). Matched on model_alias.
        matchingProfiles(m) {
          return Object.keys(this.profiles).filter(n => this.profiles[n] && this.profiles[n].model_alias === m.alias);
        },
        async spawnModel(m) {
          const prof = this.spawnSel[m.alias];
          if (!prof) return;
          this.spawnMsg[m.alias] = 'spawning…';
          try {
            const r = await fetch('/services', {
              method: 'POST', headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ profile: prof }),
            });
            const d = await r.json();
            if (!r.ok) { this.spawnMsg[m.alias] = 'error: ' + (d.error || ('HTTP ' + r.status)); return; }
            const where = d.node_id + ' :' + d.port + (d.device ? ' (' + d.device.toUpperCase() + ')' : '');
            this.spawnMsg[m.alias] = '✓ spawned on ' + where + ' — loading model…';
            // Poll readiness (same helper the overview spawn uses) so the
            // operator sees loading → ready without leaving the catalog.
            if (window.wgPollReady) {
              window.wgPollReady(prof, (phase) => {
                if (phase === 'ready')        this.spawnMsg[m.alias] = '✓ ready — ' + prof + ' serving on :' + d.port;
                else if (phase === 'timeout') this.spawnMsg[m.alias] = 'spawned on ' + where + ' — still loading (see Overview)';
              });
            }
          } catch (e) { this.spawnMsg[m.alias] = 'error: ' + e; }
        },
        profileCreateUrl(m) { return '/profiles?prefill_alias=' + encodeURIComponent(m.alias); },
        get architectures() {
          const s = new Set();
          this.models.forEach(m => { if (m.architecture) s.add(m.architecture); });
          return [...s].sort();
        },
        get filtered() {
          const q = this.q.trim().toLowerCase();
          let list = this.models.filter(m => {
            if (this.archFilter && (m.architecture || '') !== this.archFilter) return false;
            if (!q) return true;
            return (m.alias || '').toLowerCase().includes(q)
                || (m.architecture || '').toLowerCase().includes(q)
                || (m.general_name || '').toLowerCase().includes(q);
          });
          const by = this.sortBy;
          return list.slice().sort((a, b) => {
            if (by === 'size')  return (b.size_mb || 0) - (a.size_mb || 0);
            if (by === 'nodes') return ((b.on_nodes || []).length) - ((a.on_nodes || []).length);
            if (by === 'arch')  return (a.architecture || '').localeCompare(b.architecture || '')
                                     || (a.alias || '').localeCompare(b.alias || '');
            return (a.alias || '').localeCompare(b.alias || '');   // alias A→Z (default)
          });
        },
        copyTargets(m) {
          const have = new Set((m.on_nodes || []).map(o => o.node_id));
          return this.nodes.map(n => n.node_id).filter(id => !have.has(id));
        },
        async distribute(m) {
          const target = this.copyTo[m.alias];
          if (!target) return;
          this.msg[m.alias] = 'queuing…';
          try {
            const r = await fetch('/models/distribute', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ alias: m.alias, target_node: target }),
            });
            const d = await r.json();
            this.msg[m.alias] = d.error ? ('error: ' + d.error) : ('queued ' + d.transfer_id + ' → ' + target);
          } catch (e) { this.msg[m.alias] = 'error: ' + e; }
        },
        fmtSize(mb) {
          if (mb == null) return '—';
          return mb >= 1024 ? (mb / 1024).toFixed(1) + ' GB' : mb + ' MB';
        },

        // Derive the HF repo (org/name) from a catalog model's source_url.
        hfRepoFor(m) {
          const u = m.source_url || '';
          const i = u.indexOf('huggingface.co/');
          if (i < 0) return null;
          let rest = u.slice(i + 'huggingface.co/'.length)
            .replace(/\\/(tree|resolve|blob)\\/.*$/, '').replace(/\\/+$/, '');
          const p = rest.split('/');
          return (p.length >= 2 && p[0] && p[1]) ? p[0] + '/' + p[1] : null;
        },
        // Lazy-load + cache the model card (album art) when a row expands.
        // Server caches the scrape, so repeat expands are instant.
        loadModelCard(m) {
          const repo = this.hfRepoFor(m);
          if (!repo || this.modelCards[m.alias] !== undefined) return;
          this.modelCards[m.alias] = null;   // mark in-flight
          fetch('/api/hf/card', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ repo }),
          }).then(r => r.ok ? r.json() : null)
            .then(c => { this.modelCards[m.alias] = c; })
            .catch(() => {});
        },

        // ── quant suggestions: strip the quant tag to a base model name,
        // then hand off to the HF browser (repos = sources, files = quants). ──
        findQuants(m) {
          const base = (m.general_name || m.alias || '')
            .replace(/[-_. ]?(iq\\d+[a-z0-9_]*|q\\d+_k_[sml]|q\\d+_k|q\\d+_\\d+|q\\d+|f16|f32|bf16)\\b.*$/i, '')
            .replace(/[-_. ]?gguf$/i, '')
            .trim();
          window.dispatchEvent(new CustomEvent('wg-find-quants', { detail: { base: base || m.alias } }));
        },

        // ── delete model (with confirmation modal) ──
        del: { open: false, alias: '', node: '', path: '', busy: false, err: '' },
        askDelete(alias, node, path) { this.del = { open: true, alias, node, path, busy: false, err: '' }; },
        cancelDelete() { this.del.open = false; },
        async confirmDelete() {
          this.del.busy = true; this.del.err = '';
          try {
            const r = await fetch('/models/delete', {
              method: 'POST', headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ node_id: this.del.node, path: this.del.path }),
            });
            const d = await r.json().catch(() => ({}));
            if (!r.ok) { this.del.err = d.error || ('HTTP ' + r.status); this.del.busy = false; return; }
            this.del.open = false; this.del.busy = false;
            await this.load();
          } catch (e) { this.del.err = String(e); this.del.busy = false; }
        },

        // ── per-node scan-dir editor ──
        sd: { node: '', canonical: '', extra: '', msg: '', busy: false },
        async loadScanDirs() {
          if (!this.sd.node) { this.sd.canonical = ''; this.sd.extra = ''; this.sd.msg = ''; return; }
          this.sd.msg = 'loading…';
          try {
            const r = await fetch('/api/scan-dirs', {
              method: 'POST', headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ node_id: this.sd.node }),
            });
            const d = await r.json();
            if (!r.ok) { this.sd.msg = 'error: ' + (d.error || r.status); return; }
            this.sd.canonical = d.canonical || '';
            this.sd.extra = (d.extra || []).join('\\n');
            this.sd.msg = '';
          } catch (e) { this.sd.msg = 'error: ' + e; }
        },
        async saveScanDirs() {
          this.sd.busy = true; this.sd.msg = '';
          const extra = this.sd.extra.split(/\\r?\\n/).map(s => s.trim()).filter(Boolean);
          try {
            const r = await fetch('/api/scan-dirs', {
              method: 'POST', headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ node_id: this.sd.node, extra }),
            });
            const d = await r.json();
            if (!r.ok) { this.sd.msg = 'error: ' + (d.error || r.status); }
            else { this.sd.msg = 'saved · ' + (d.count != null ? d.count + ' models' : 'rescanned'); await this.load(); }
          } catch (e) { this.sd.msg = 'error: ' + e; }
          this.sd.busy = false;
        },
      };
    }
  </script>
</body>
</html>
";

export let TRANSFERS_HTML = "<!doctype html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\">
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">
