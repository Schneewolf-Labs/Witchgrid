				hf_source: {
					repo: "bartowski/Llama-3.2-3B-Instruct-GGUF",
					file: "Llama-3.2-3B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Mid chat — ~5 GB weights, the default workhorse. Comfortable on
		// a 12-16 GB GPU at 32k context with q4_0 KV + flash attention.
		{
			name: "chat-llama3.1-8b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 32768,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18101,
				context: 32768,
				kv_type: "q4_0",
				model_alias: "meta-llama-3.1-8b-instruct-q4_k_m",
				hf_source: {
					repo: "bartowski/Meta-Llama-3.1-8B-Instruct-GGUF",
					file: "Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Large chat — ~9 GB weights. A clear quality step up from 8B;
		// targets a 24 GB GPU at 32k context.
		{
			name: "chat-qwen2.5-14b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 32768,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18102,
				context: 32768,
				kv_type: "q4_0",
				model_alias: "qwen2.5-14b-instruct-q4_k_m",
				hf_source: {
					repo: "bartowski/Qwen2.5-14B-Instruct-GGUF",
					file: "Qwen2.5-14B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// XL chat — ~20 GB weights, trades speed for quality. Tight on a
		// single 24 GB card (drop context if it won't place), comfortable
		// on 32-48 GB. Context kept at 16k so the KV cache fits alongside.
		{
			name: "chat-qwen2.5-32b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 16384,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18103,
				context: 16384,
				kv_type: "q4_0",
				model_alias: "qwen2.5-32b-instruct-q4_k_m",
				hf_source: {
					repo: "bartowski/Qwen2.5-32B-Instruct-GGUF",
					file: "Qwen2.5-32B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Same 8B, tuned for QUALITY over speed: Q6_K weights (~6.6 GB,
		// near-lossless vs Q4_K_M) and an f16-class q8_0 KV cache. Slower
		// and hungrier than chat-llama3.1-8b; reach for it when answer
		// fidelity matters more than tokens/sec or context length.
		{
			name: "chat-llama3.1-8b-quality",
			profile: {
				binary: "llama-server",
				intent: {
					context: 16384,
					kv_cache_k: "q8_0",
					kv_cache_v: "q8_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18104,
				context: 16384,
				kv_type: "q8_0",
				model_alias: "meta-llama-3.1-8b-instruct-q6_k",
				hf_source: {
					repo: "bartowski/Meta-Llama-3.1-8B-Instruct-GGUF",
					file: "Meta-Llama-3.1-8B-Instruct-Q6_K.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Same 8B, tuned for THROUGHPUT: 4 parallel slots so the server
		// handles concurrent requests, with an 8k window per slot (32k of
		// KV total). Trades single-request latency for aggregate
		// tokens/sec across users — the config for a shared serving box.
		// Reuses the Q4_K_M file (shares the alias with chat-llama3.1-8b,
		// so one pull covers both).
		{
			name: "chat-llama3.1-8b-serving",
			profile: {
				binary: "llama-server",
				intent: {
					context: 8192,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 4,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18105,
				context: 8192,
				kv_type: "q4_0",
				model_alias: "meta-llama-3.1-8b-instruct-q4_k_m",
				hf_source: {
					repo: "bartowski/Meta-Llama-3.1-8B-Instruct-GGUF",
					file: "Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Reasoning — DeepSeek-R1 distilled into Qwen 14B (~9 GB weights).
		// Emits <think>…</think> chains, so give it room: 32k context.
		// Consumers should strip/handle the thinking block. Targets 24 GB.
		{
			name: "reason-deepseek-r1-14b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 32768,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18110,
				context: 32768,
				kv_type: "q4_0",
				model_alias: "deepseek-r1-distill-qwen-14b-q4_k_m",
				hf_source: {
					repo: "bartowski/DeepSeek-R1-Distill-Qwen-14B-GGUF",
					file: "DeepSeek-R1-Distill-Qwen-14B-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Coding (accessible) — Qwen2.5-Coder 7B (~4.7 GB weights). Strong
		// code model that fits a 12 GB GPU. 32k context for whole-file work;
		// q8_0 KV to keep code tokens crisp.
		{
			name: "code-qwen2.5-7b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 32768,
					kv_cache_k: "q8_0",
					kv_cache_v: "q8_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18120,
				context: 32768,
				kv_type: "q8_0",
				model_alias: "qwen2.5-coder-7b-instruct-q4_k_m",
				hf_source: {
					repo: "bartowski/Qwen2.5-Coder-7B-Instruct-GGUF",
					file: "Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// Coding (quality) — Qwen2.5-Coder 32B (~20 GB weights). The
		// near-frontier local coding model; targets 32-48 GB. Context at
		// 16k so the KV cache fits beside the weights.
		{
			name: "code-qwen2.5-32b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 16384,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18121,
				context: 16384,
				kv_type: "q4_0",
				model_alias: "qwen2.5-coder-32b-instruct-q4_k_m",
				hf_source: {
					repo: "bartowski/Qwen2.5-Coder-32B-Instruct-GGUF",
					file: "Qwen2.5-Coder-32B-Instruct-Q4_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},
	];
	for (d in defaults) {
		// insert-or-ignore: only fills in default profiles whose name
		// doesn't already exist, so operator edits to a same-named profile
		// survive upgrades. See the note at the top of this function.
		exec(db,
			"insert or ignore into profiles (name, profile_json, version, created_at, updated_at) "
			+ "values (?, ?, 1, ?, ?)",
			[d.name, stringify(d.profile), now, now]);
	}
	print("[cp] ensured " + defaults.length + " default profiles (insert-or-ignore)");
	return null;
}

// How long we keep hardware samples. 1 hour at 30s heartbeat = 120
// samples per (node, metric, series) — tiny on disk, plenty for the
// dashboard's 30-min sparkline window with headroom.
let SAMPLE_RETENTION_SECONDS = 3600;

fn iso_now(): string {
	let r = query(DB, "select datetime('now') as ts", []);
	return r[0].ts;
}

// ── node registry ────────────────────────────────────────────────────

fn handle_register(req): object {
	let payload = parse(req.body);
	let node_id = payload?.node_id;
	let hostname = payload?.hostname;
	if (node_id == null || hostname == null) {
		return { status: 400, body: "{\"error\":\"node_id+hostname required\"}" };
	}

	let hw_json = stringify(payload?.hardware ?? {});
	let runtime_json = null;
	if (payload?.runtime != null) { runtime_json = stringify(payload.runtime); }
	let agent_url = payload?.agent_url;
	// agent_url is where every CP→agent call (spawn, stop, fan-outs) gets
	// sent — refuse anything that isn't a plain http(s) URL so a bogus
	// register can't point the CP's outbound RPC at an arbitrary scheme.
	if (agent_url != null && agent_url != "") {
		let u = "" + agent_url;
		if (!(u.starts_with("http://") || u.starts_with("https://"))
			|| u.length > 2048 || u.find(" ") >= 0
			|| u.find("\r") >= 0 || u.find("\n") >= 0) {
			return { status: 400,
				body: "{\"error\":\"agent_url must be a plain http(s) URL\"}" };
		}
	}
	let now = iso_now();

	// Note: we deliberately do NOT touch `state` on update — that's
	// operator-owned (set via PATCH /api/nodes/{id}). A heartbeat
	// shouldn't undo a manual disable. Insert path defaults to 'active'
	// via the column default.
	// auto_restart: null when the agent is too old to report it, so the
	// upsert coalesces to keep any previously-known value rather than
	// clobbering it to null on every heartbeat.
	let ar = payload?.auto_restart;
	let ar_val = (ar == null) ? null : (ar == true ? 1 : 0);
	let agent_ver = payload?.agent_version;
	exec(DB,
		"insert into nodes (node_id, hostname, role, hardware_json, agent_url, registered_at, last_seen_at, runtime_json, auto_restart, agent_version) "
		+ "values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?) "
		+ "on conflict(node_id) do update set "
		+ "hostname=excluded.hostname, role=excluded.role, "
		+ "hardware_json=excluded.hardware_json, agent_url=excluded.agent_url, "
		+ "last_seen_at=excluded.last_seen_at, "
		+ "runtime_json=excluded.runtime_json, "
		+ "auto_restart=coalesce(excluded.auto_restart, nodes.auto_restart), "
		+ "agent_version=coalesce(excluded.agent_version, nodes.agent_version)",
		[node_id, hostname, payload?.role ?? "worker", hw_json, agent_url, now, now, runtime_json, ar_val, agent_ver]
	);

	// Catalog ingest. Replace-all-for-this-node so deleted models drop
	// out automatically — no separate /unregister-model bookkeeping.
	// Skipping silently when the field is absent keeps us compatible
	// with older agents that haven't been rebuilt yet.
	let models = payload?.models;
	if (models != null) {
		exec(DB, "delete from node_models where node_id = ?", [node_id]);
		for (m in models) {
			exec(DB,
				"insert into node_models (node_id, alias, path, size_mb, "
				+ "architecture, n_layers, n_heads, n_kv_heads, embedding_length, "
				+ "claimed_context, general_name, source_url) "
				+ "values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
				[node_id, m.alias, m.path, m.size_mb,
				 m?.architecture, m?.n_layers, m?.n_heads, m?.n_kv_heads,
				 m?.embedding_length, m?.claimed_context,
				 m?.general_name, m?.source_url]);
		}
	}

	// Unmanaged-process ingest (slice C5). Replace-all-for-this-node
	// so a process that died between heartbeats drops out automatically.
	// Skipping silently when the field is absent keeps us compatible
	// with older agents that haven't been rebuilt yet.
	let unmanaged = payload?.unmanaged_processes;
	if (unmanaged != null) {
		exec(DB, "delete from node_unmanaged_procs where node_id = ?",
			[node_id]);
		for (u in unmanaged) {
			// ports comes as an array from newer agents; persist as JSON.
			// Older agents omit ports/cmdline → store null (rendered as "—").
			let ports_json = null;
			if (u?.ports != null) { ports_json = stringify(u.ports); }
			exec(DB,
				"insert into node_unmanaged_procs "
				+ "(node_id, pid, process_name, vram_mb, gpu_index, "
				+ " owner_uid, owner_name, ports, cmdline, observed_at) "
				+ "values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
				[node_id, u.pid, u.process_name, u.vram_mb,
				 u?.gpu_index, u?.owner_uid, u?.owner_name,
				 ports_json, u?.cmdline, now]);
		}
	}

	// Hardware time-series ingest. One row per metric per heartbeat;
	// the dashboard renders sparklines from these. Prune > 1hr at the
	// same time so the table stays bounded without a separate cron.
	let hw = payload?.hardware ?? {};
	if (hw?.gpus != null) {
		for (g in hw.gpus) {
			exec(DB, "insert into node_samples (node_id, metric, series, value, sampled_at) "
				+ "values (?, 'gpu_free_mb', ?, ?, ?)",
				[node_id, "" + g.index, g.free_mb, now]);
			// power.draw is per-GPU watts; null for cards without a
			// power sensor (most consumer Apple GPUs, some old Teslas).
			if (g?.power_draw_w != null) {
				exec(DB, "insert into node_samples (node_id, metric, series, value, sampled_at) "
					+ "values (?, 'gpu_power_w', ?, ?, ?)",
					[node_id, "" + g.index, g.power_draw_w, now]);
			}
		}
	}
	if (hw?.ram_free_mb != null) {
		exec(DB, "insert into node_samples (node_id, metric, series, value, sampled_at) "
			+ "values (?, 'ram_free_mb', null, ?, ?)",
			[node_id, hw.ram_free_mb, now]);
	}
	if (hw?.disks != null) {
		for (d in hw.disks) {
			exec(DB, "insert into node_samples (node_id, metric, series, value, sampled_at) "
				+ "values (?, 'disk_free_mb', ?, ?, ?)",
				[node_id, d.path, d.free_mb, now]);
		}
	}
	exec(DB, "delete from node_samples where node_id = ? "
		+ "and sampled_at < datetime('now', ?)",
		[node_id, "-" + SAMPLE_RETENTION_SECONDS + " seconds"]);

	return { status: 200, body: stringify({
		node_id: node_id, registered_at: now, welcome: "joined the grid",
		catalog_count: (models != null ? models.length : 0),
	})};
}

fn handle_list_nodes(req): object {
	let rows = query(DB,
		"select node_id, hostname, role, hardware_json, agent_url, "
		+ "registered_at, last_seen_at, state, runtime_json, auto_restart, agent_version "
		+ "from nodes order by registered_at desc", []);
	let out = [];
	for (row in rows) {
		let runtime = null;
		if (row?.runtime_json != null) {
			try { runtime = parse(row.runtime_json); } catch (e) { }
		}
		out.push({
			node_id: row.node_id,
			hostname: row.hostname,
			role: row.role,
			hardware: parse(row.hardware_json),
			agent_url: row.agent_url,
			registered_at: row.registered_at,
			last_seen_at: row.last_seen_at,
			state: row?.state ?? "active",
			runtime: runtime,
			// tri-state: true/false from the agent, null when the agent
			// predates auto_restart reporting.
			auto_restart: (row?.auto_restart == null) ? null : (row.auto_restart == 1),
			agent_version: row?.agent_version,
		});
	}
	return { status: 200, body: stringify(out) };
}

// PATCH /api/nodes/{node_id}  body: {state: "active"|"disabled"|"draining"}
//
// State semantics:
//   active    — placement targets this node normally
//   disabled  — placement skips entirely; existing services keep running
//               but operator should stop them; node still appears in
//               dashboard (with disabled badge) so operator can re-enable
//   draining  — placement skips for new spawns; existing services keep
//               running so in-flight requests finish; meant to be used
//               briefly before disable + restart for upgrades
//
// Disabled / draining nodes still serve catalog blobs + accept stop
// commands. The state only gates NEW spawn placement.
// ── llama_cpp proxies ────────────────────────────────────────────
//
// CP owns no state for llama_cpp installs — each agent does. These
// handlers forward to the chosen agent's /llama_cpp/* endpoints so
// the dashboard can drive them through one URL space (no need for
// the browser to know each agent's bind address).
//
// URL: /api/nodes/{node_id}/llama_cpp/{install,installed,activate}

fn parse_node_lcpp_path(path: string) {
	// path = "/api/nodes/<node_id>/llama_cpp/<action>"
	let prefix = "/api/nodes/";
	if (!path.starts_with(prefix)) { return null; }
	let rest = path.substr(prefix.length, path.length - prefix.length);
	let slash = rest.find("/");
	if (slash < 0) { return null; }
	let node_id = rest.substr(0, slash);
	let after = rest.substr(slash + 1, rest.length - slash - 1);
	if (!after.starts_with("llama_cpp/")) { return null; }
	let action = after.substr(10, after.length - 10);
	return { node_id: node_id, action: action };
}

fn handle_node_llama_cpp(req): object {
	let parsed = parse_node_lcpp_path(req.path);
	if (parsed == null) {
		return { status: 404, body: "{\"error\":\"expected /api/nodes/{id}/llama_cpp/{action}\"}" };
	}
	let agent_url = lookup_agent(parsed.node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + parsed.node_id }) };
	}
	let target = agent_url + "/llama_cpp/" + parsed.action;
	try {
		let resp = null;
		if (req.method == "GET") {
			resp = cp_get(target);
		} else {
			resp = cp_post_json(target, parse(req?.body ?? "{}"));
		}
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

// PUT /api/nodes/{node_id}/auto-restart  body: { auto_restart: bool }
//
// Proxies to the agent's PUT /settings (the agent is the source of
// truth — it owns the watchdog), then mirrors the confirmed value onto
// the nodes row so the dashboard updates immediately instead of waiting
// for the next heartbeat. Returns the agent's response verbatim.
fn handle_node_auto_restart(req): object {
	let prefix = "/api/nodes/";
	let rest = req.path.substr(prefix.length, req.path.length - prefix.length);
	let slash = rest.find("/");
	if (slash < 0) {
		return { status: 404, body: "{\"error\":\"expected /api/nodes/{id}/auto-restart\"}" };
	}
	let node_id = rest.substr(0, slash);
	let payload = null;
	try { payload = parse(req?.body ?? "{}"); } catch (e) {
		return { status: 400, body: "{\"error\":\"bad json\"}" };
	}
	let ar = payload?.auto_restart;
	if (ar == null) {
		return { status: 400, body: "{\"error\":\"auto_restart (bool) required\"}" };
	}
	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + node_id }) };
	}
	try {
		let resp = cp_put_json(agent_url + "/settings", { auto_restart: ar == true });
		if (resp.status_code >= 200 && resp.status_code < 300) {
			exec(DB, "update nodes set auto_restart = ? where node_id = ?",
				[ar == true ? 1 : 0, node_id]);
		}
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

fn handle_patch_node(req): object {
	let prefix = "/api/nodes/";
	let node_id = req.path.substr(prefix.length, req.path.length - prefix.length);
	if (node_id.length == 0) {
		return { status: 400, body: "{\"error\":\"node_id required\"}" };
	}
	let payload = null;
	try { payload = parse(req.body); } catch (e) {
		return { status: 400, body: "{\"error\":\"bad json\"}" };
	}
	let state = payload?.state;
	if (state != "active" && state != "disabled" && state != "draining") {
		return { status: 400, body: stringify({
			error: "state must be one of: active, disabled, draining",
		})};
	}
	let existing = query(DB, "select node_id from nodes where node_id = ?", [node_id]);
	if (existing.length == 0) {
		return { status: 404, body: stringify({ error: "no such node: " + node_id }) };
	}
	exec(DB, "update nodes set state = ? where node_id = ?", [state, node_id]);
	return { status: 200, body: stringify({ node_id: node_id, state: state }) };
}

fn handle_health(req): object {
	return { status: 200, body: stringify({ status: "ok", version: WITCHGRID_VERSION }) };
}

// GET /metrics — Prometheus text exposition. Built purely from the node
// data CP already collects each heartbeat (nodes_for_dashboard reads the
// DB), so a scrape never fans out to agents and stays fast + reliable
// regardless of agent reachability. Public, like /healthz — a scrape
// target, not a secret; lets Prometheus/Grafana watch the fleet's VRAM,
// node liveness, and the auto-restart watchdog state.
fn handle_metrics(req): object {
	let nodes = nodes_for_dashboard();

	// One accumulator per metric so we emit each HELP/TYPE block once and
	// stream all its series under it (Prometheus requires series of the
	// same name to be contiguous). Single pass over nodes/gpus.
	let m_node_up    = "";
	let m_last_seen  = "";
	let m_auto       = "";
	let m_ram_free   = "";
	let m_ram_total  = "";
	let m_cpu_cores  = "";
	let m_gpu_free   = "";
	let m_gpu_total  = "";
	let m_gpu_used   = "";
	let m_gpu_power  = "";

	for (n in nodes) {
		let nl = "{node=\"" + n.node_id + "\"}";
		let up = (n.age_seconds < STALE_NODE_SECONDS) ? "1" : "0";
		m_node_up   = m_node_up   + "witchgrid_node_up" + nl + " " + up + "\n";
		m_last_seen = m_last_seen + "witchgrid_node_last_seen_seconds" + nl + " " + n.age_seconds + "\n";

		let ar = n?.auto_restart;
		if (ar != null) {
			m_auto = m_auto + "witchgrid_node_auto_restart" + nl + " " + (ar == true ? "1" : "0") + "\n";
		}

		let hw = n?.hardware ?? {};
		if (hw?.ram_free_mb != null) {
			m_ram_free = m_ram_free + "witchgrid_node_ram_free_mb" + nl + " " + hw.ram_free_mb + "\n";
		}
		if (hw?.ram_total_mb != null) {
			m_ram_total = m_ram_total + "witchgrid_node_ram_total_mb" + nl + " " + hw.ram_total_mb + "\n";
		}
		if (hw?.cpu_cores != null) {
			m_cpu_cores = m_cpu_cores + "witchgrid_node_cpu_cores" + nl + " " + hw.cpu_cores + "\n";
		}

		let gpus = hw?.gpus ?? [];
		for (g in gpus) {
			let gl = "{node=\"" + n.node_id + "\",gpu=\"" + g.index + "\"}";
			m_gpu_free  = m_gpu_free  + "witchgrid_gpu_free_mb"  + gl + " " + g.free_mb + "\n";
			m_gpu_total = m_gpu_total + "witchgrid_gpu_total_mb" + gl + " " + g.total_mb + "\n";
			m_gpu_used  = m_gpu_used  + "witchgrid_gpu_used_mb"  + gl + " " + (g.total_mb - g.free_mb) + "\n";
			if (g?.power_draw_w != null) {
				m_gpu_power = m_gpu_power + "witchgrid_gpu_power_watts" + gl + " " + g.power_draw_w + "\n";
			}
		}
	}

	let out = ""
		+ "# HELP witchgrid_build_info Witchgrid version, value always 1\n"
		+ "# TYPE witchgrid_build_info gauge\n"
		+ "witchgrid_build_info{version=\"" + WITCHGRID_VERSION + "\"} 1\n"
		+ "# HELP witchgrid_up 1 if the control plane is serving requests\n"
		+ "# TYPE witchgrid_up gauge\n"
		+ "witchgrid_up 1\n"
		+ "# HELP witchgrid_nodes_total Number of registered nodes (fresh or stale)\n"
		+ "# TYPE witchgrid_nodes_total gauge\n"
		+ "witchgrid_nodes_total " + nodes.length + "\n"
		+ "# HELP witchgrid_node_up 1 if the node's last heartbeat is within " + STALE_NODE_SECONDS + "s\n"
		+ "# TYPE witchgrid_node_up gauge\n" + m_node_up
		+ "# HELP witchgrid_node_last_seen_seconds Seconds since the node's last heartbeat\n"
		+ "# TYPE witchgrid_node_last_seen_seconds gauge\n" + m_last_seen
		+ "# HELP witchgrid_node_auto_restart 1 if the agent's auto-restart watchdog is enabled\n"
		+ "# TYPE witchgrid_node_auto_restart gauge\n" + m_auto
		+ "# HELP witchgrid_node_cpu_cores CPU cores reported by the node\n"
		+ "# TYPE witchgrid_node_cpu_cores gauge\n" + m_cpu_cores
		+ "# HELP witchgrid_node_ram_free_mb Free system RAM (MB)\n"
		+ "# TYPE witchgrid_node_ram_free_mb gauge\n" + m_ram_free
		+ "# HELP witchgrid_node_ram_total_mb Total system RAM (MB)\n"
		+ "# TYPE witchgrid_node_ram_total_mb gauge\n" + m_ram_total
		+ "# HELP witchgrid_gpu_free_mb Free VRAM per GPU (MB)\n"
		+ "# TYPE witchgrid_gpu_free_mb gauge\n" + m_gpu_free
		+ "# HELP witchgrid_gpu_total_mb Total VRAM per GPU (MB)\n"
		+ "# TYPE witchgrid_gpu_total_mb gauge\n" + m_gpu_total
		+ "# HELP witchgrid_gpu_used_mb Used VRAM per GPU (MB)\n"
		+ "# TYPE witchgrid_gpu_used_mb gauge\n" + m_gpu_used
		+ "# HELP witchgrid_gpu_power_watts Current GPU power draw (W)\n"
		+ "# TYPE witchgrid_gpu_power_watts gauge\n" + m_gpu_power;

	return { status: 200, body: out,
		headers: { "content-type": "text/plain; version=0.0.4; charset=utf-8" } };
}

// ── agent lookup ─────────────────────────────────────────────────────

// Returns the agent_url for node_id, or null if the node isn't registered
// or registered without an agent_url. Caller must check for null.
fn lookup_agent(node_id: string) {
	let rows = query(DB, "select agent_url from nodes where node_id = ?", [node_id]);
	if (rows.length == 0 || rows[0].agent_url == null) {
		return null;
	}
	return rows[0].agent_url;
}

// 90s = 3x the agent's 30s heartbeat interval. Gives one missed
// heartbeat of slack so a transient network blip doesn't drop a node
// out of placement, but a genuinely-dead agent falls out within a
// minute and a half. Override via WITCHGRID_STALE_NODE_SECONDS (tuning,
// or tests that need fast eviction); keep it ≳ 3x the agent's
// WITCHGRID_HEARTBEAT_SECONDS so a single missed beat doesn't flap.
let _stale_env = getenv("WITCHGRID_STALE_NODE_SECONDS");
let STALE_NODE_SECONDS = (_stale_env == null || _stale_env.length == 0) ? 90 : i32(_stale_env);

fn list_all_agents(): array {
	let rows = query(DB,
		"select node_id, agent_url from nodes "
		+ "where agent_url is not null "
		+ "and last_seen_at > datetime('now', ?)",
		["-" + STALE_NODE_SECONDS + " seconds"]);
	return rows;
}

// ── placement ────────────────────────────────────────────────────────
// First-fit. Walks every registered agent and every GPU on it, picks the
// first GPU whose free_mb ≥ required_mb. No bin-packing across multiple
// GPUs yet (single-GPU spawn only); we'll add tensor-parallel split when
// flammen.ai actually has a model that needs more VRAM than any single
// card on the fleet.

// fetch_profile: pre-v0.7 fan-out across agents (asking each agent's
// /profiles endpoint) is gone. Profiles live in CP's table now.
// Use fetch_profile_by_name() instead — it queries our own DB and
// returns the profile object with __name + __version stamped.
//
// Kept as a thin alias so existing callers don't all need touching.
fn fetch_profile(profile_name: string) {
	return fetch_profile_by_name(profile_name);
}

// Tensor-parallel overhead headroom. llama.cpp spreads weights across
// GPUs but each card still needs its own activation buffer + cuBLAS
// workspace, so the SUM of free VRAM across the chosen subset has to
// exceed the model's needed VRAM by a margin. 10% empirically covers
// the worst case I've seen on a 4-card box (Mahou-12B at 128K wants
// ~17 GB; 2× 4060 Ti split takes ~19 GB sum to be safe).
let MULTI_GPU_OVERHEAD_FRACTION: f64 = 0.10;

// Picks the smallest GPU subset whose summed free VRAM covers needed_mb
// + overhead. Within a given subset size, prefers the one with the most
// total_free as a tiebreaker (more headroom = less risk of OOM during
// tensor-parallel allocation).
//
// gpus: [{index, free_mb, total_mb, ...}]   (the node's full GPU list)
// needed_mb: f64                            (estimated VRAM the model needs)
//
// Returns null if no subset of any size fits, otherwise:
//   {
//     indices:      [i32, ...]   (gpu indices in sorted order)
//     tensor_split: [i32, ...]   (free_mb per gpu, in same order — passed
//                                 verbatim to llama-server's --tensor-split,
//                                 which interprets as relative weights)
//     total_free:   i32          (diagnostic)
//   }
//
// Bitmask enumeration: at N=4 we walk 15 subsets, at N=8 we'd walk 255.
// Both trivial. If we ever care about much larger fleets per box we'd
// switch to a smarter knapsack, but no homelab box has that many GPUs.
fn pick_gpu_subset(gpus, needed_mb: f64) {
	let n = gpus.length;
	if (n == 0) { return null; }
	let needed_with_overhead: f64 = needed_mb * (1.0 + MULTI_GPU_OVERHEAD_FRACTION);

	// Try subset sizes 1..n. Within each size pick the one with most
	// total_free (best headroom). Smallest-set-first dodges the
	// degenerate case where the algorithm spreads a small model across
	// every GPU — one card is cheaper than four.
	let target_size = 1;
	while (target_size <= n) {
		let best_indices = null;
		let best_split = null;
		let best_total: i32 = -1;

		// Walk every bitmask of length n; keep only those with the right
		// popcount AND enough summed free.
		let mask = 1;
		let max_mask = 1;
		let i = 0;
		while (i < n) { max_mask = max_mask * 2; i = i + 1; }

		while (mask < max_mask) {
			// Count bits and collect indices for this mask
			let bit = 0;
			let popcount = 0;
			let indices = [];
			let split = [];
			let total_free: i32 = 0;
			while (bit < n) {
				let m = 1;
				let j = 0;
				while (j < bit) { m = m * 2; j = j + 1; }
				if ((mask & m) != 0) {
					popcount = popcount + 1;
					indices.push(gpus[bit].index);
					split.push(gpus[bit].free_mb);
					total_free = total_free + gpus[bit].free_mb;
				}
				bit = bit + 1;
			}
			if (popcount == target_size && f64(total_free) >= needed_with_overhead) {
				if (total_free > best_total) {
					best_indices = indices;
					best_split = split;
					best_total = total_free;
				}
			}
			mask = mask + 1;
		}

		if (best_indices != null) {
			return {
				indices:      best_indices,
				tensor_split: best_split,
				total_free:   best_total,
			};
		}
		target_size = target_size + 1;
	}
	return null;
}

// Catalog-driven placement. Walks every node that advertises this alias,
// computes VRAM cost from the catalog row's ingredients (no file read on
// CP's side), picks the smallest GPU subset that fits.
//
// Returns:
//   { node_id, agent_url, gpu_indices: [...], tensor_split: [...] | null,
//     est_mb, model_path }                                 -- a placement
//   null                                                    -- alias not in
//                                                              any node's
//                                                              catalog OR no
//                                                              GPU subset fits
//
// gpu_indices is always non-empty. tensor_split is null for single-GPU
// placements (no -ts needed) and an array of relative weights for
// multi-GPU splits. model_path comes back so the spawn proxy knows the
// agent-local path without the caller needing to keep separate state.
fn pick_placement_via_alias(alias: string, profile) {
	let candidates = nodes_with_alias(alias);
	if (candidates.length == 0) { return null; }

	// CPU-only intent: gpu_layers=0 means llama-server runs entirely on
	// CPU (no offload). Skip the GPU-fit search and just take the first
	// active candidate — RAM is plentiful and we don't track per-process
	// RAM accounting today. Returned with empty gpu_indices so the agent
	// spawn doesn't set CUDA_VISIBLE_DEVICES or --tensor-split.
	let cpu_only = (profile?.intent?.gpu_layers == 0);

	for (cand in candidates) {
		// Only consider nodes that have heartbeated recently and exposed
		// an agent_url. Stale nodes shouldn't drive placement decisions.
		// Disabled / draining nodes also drop out (operator-set state
		// in the dashboard or via PATCH /api/nodes/{id}).
		let nodes = query(DB,
			"select agent_url, hardware_json from nodes "
			+ "where node_id = ? "
			+ "and agent_url is not null "
			+ "and state = 'active' "
			+ "and last_seen_at > datetime('now', ?)",
			[cand.node_id, "-" + STALE_NODE_SECONDS + " seconds"]);
		if (nodes.length == 0) { continue; }
		let n = nodes[0];

		let est = estimate_vram_from_ingredients(cand,
			i32(profile.context), profile.kv_type);
		let needed_mb = est.total_mb;

		if (cpu_only) {
			return {
				node_id:      cand.node_id,
				agent_url:    n.agent_url,
				gpu_indices:  [],
				tensor_split: null,
				est_mb:       needed_mb,
				model_path:   cand.path,
			};
		}

		let hw = parse(n.hardware_json);
		let gpus = hw?.gpus ?? [];
		let subset = pick_gpu_subset(gpus, needed_mb);
		if (subset != null) {
			let split = null;
			if (subset.indices.length > 1) { split = subset.tensor_split; }
			return {
				node_id:      cand.node_id,
				agent_url:    n.agent_url,
				gpu_indices:  subset.indices,
				tensor_split: split,
				est_mb:       needed_mb,
				model_path:   cand.path,
			};
		}
	}
	return null;
}

// Returns one of:
//   { node_id, agent_url, gpu_index, est_mb }   -- a placement
//   { error: "...", status: 4xx|5xx }           -- a structured error
//   null                                         -- no fit found, retry later
//
// model_path is the path AS THE AGENT'S BOX SEES IT. For multi-box setups
// where the operator hasn't shared the model directory across all agents,
// CP can't read the file directly. We pre-check `exists` and bail out with
// a structured error rather than calling read_metadata — the runtime's
// file_stat does `exit(1)` on missing files (Hemlock parity gap; interp
// throws catchable, compiled binary doesn't), so a `try` around
// read_metadata wouldn't actually catch the crash.
//
// Long-term fix (mostly delivered by the catalog — see
// pick_placement_via_alias above): push model introspection to the
// agent. This path-based placement remains as the fallback for profiles
// without a model_alias and for explicit operator-supplied paths.
fn pick_placement(model_path: string, profile) {
	if (!exists(model_path)) {
		return { error: "CP cannot read model file at '" + model_path + "'. "
			+ "This usually means the path exists on the agent's box but not on "
			+ "CP's box. Until agent-side model introspection lands, either "
			+ "(a) make the model accessible at the same path on CP's box "
			+ "(NFS / bind mount / scp), or (b) pin placement explicitly with "
			+ "node_id + gpus + port and skip auto-placement.",
			status: 422 };
	}
	let g = read_metadata(model_path);
	let est = estimate_vram_mb(g, i32(profile.context), profile.kv_type);
	let needed_mb = est.total_mb;

	// CPU-only intent: gpu_layers=0 means llama-server runs entirely on
	// CPU (no offload). Skip the GPU-fit search and take the first
	// active node — same rule pick_placement_via_alias applies. Without
	// this, an explicit-model spawn of a CPU profile (e.g. designer-cpu)
	// is wrongly rejected with "no GPU has enough free VRAM" even though
	// it needs zero VRAM. Returned with empty gpu_indices so the agent
	// doesn't set CUDA_VISIBLE_DEVICES / --tensor-split.
	let cpu_only = (profile?.intent?.gpu_layers == 0);

	let rows = query(DB,
		"select node_id, agent_url, hardware_json from nodes "
		+ "where agent_url is not null "
		+ "and state = 'active' "
		+ "and last_seen_at > datetime('now', ?) "
		+ "order by registered_at desc",
		["-" + STALE_NODE_SECONDS + " seconds"]);

	for (row in rows) {
		if (cpu_only) {
			return {
				node_id:      row.node_id,
				agent_url:    row.agent_url,
				gpu_indices:  [],
				tensor_split: null,
				est_mb:       needed_mb,
			};
		}
		let hw = parse(row.hardware_json);
		let gpus = hw?.gpus ?? [];
		let subset = pick_gpu_subset(gpus, needed_mb);
		if (subset != null) {
			let split = null;
			if (subset.indices.length > 1) { split = subset.tensor_split; }
			return {
				node_id:      row.node_id,
				agent_url:    row.agent_url,
				gpu_indices:  subset.indices,
				tensor_split: split,
				est_mb:       needed_mb,
			};
		}
	}
	return null;
}

// Extract the port number from an agent_url like "http://host:8766" or
// "http://host:8766/". Returns 0 if not parseable.
fn extract_port(agent_url: string): i32 {
	let rest = agent_url;
	let scheme = rest.find("://");
	if (scheme >= 0) { rest = rest.substr(scheme + 3, rest.length - scheme - 3); }
	let slash = rest.find("/");
	if (slash >= 0) { rest = rest.substr(0, slash); }
	let colon = rest.find(":");
	if (colon < 0) { return 0; }
	let port_str = rest.substr(colon + 1, rest.length - colon - 1);
	return i32(port_str);
}

// Cap on how many ports we probe before giving up. 50 is plenty —
// realistic usage has at most ~5 collisions before finding a free
// slot. Beyond 50, something's badly wrong and the operator should
// know; we return the default and let the agent's own EADDRINUSE
// surface the real problem.
let PORT_PROBE_MAX_ATTEMPTS = 50;

// Ask the agent's OS whether a port is actually bindable. Used to
// catch non-Witchgrid services (kobold, ooba, sd-webui, etc.) that
// the /services walk wouldn't see. The agent does the bind probe
// from its own host — that's the OS we care about.
//
// Returns true on confirmed-free, false on confirmed-in-use, true
// on probe failure (better to let the spawn try and fail loudly than
// to dance forever past unprobeable ports).
fn port_free_on_agent(agent_url: string, port: i32): bool {
	try {
		let resp = cp_post_json(agent_url + "/port_check", { port: port });
		if (resp.status_code >= 200 && resp.status_code < 300) {
			let body = parse(resp.body);
			return body?.available == true;
		}
		// 404 → old agent without the endpoint. Trust = optimistic.
		return true;
	} catch (e) {
		return true;
	}
}

// Pick a port the chosen agent isn't already using AND that doesn't
// collide with the agent's own listen port AND isn't taken by some
// non-Witchgrid process (kobold, ooba, etc.). Walks ports upward from
// default until we find one that passes both checks.
fn pick_port(agent_url: string, default_port: i32): i32 {
	let used = {};
	let agent_port = extract_port(agent_url);
	if (agent_port > 0) { used["" + agent_port] = true; }
	try {
		let resp = cp_get(agent_url + "/services");
		if (resp.status_code >= 200 && resp.status_code < 300) {
			let services = parse(resp.body);
			for (s in services) { used["" + s.port] = true; }
		}
	} catch (e) { }

	let port = default_port;
	let attempts = 0;
	while (attempts < PORT_PROBE_MAX_ATTEMPTS) {
		if (!used.has("" + port) && port_free_on_agent(agent_url, port)) {
			return port;
		}
		port = port + 1;
		attempts = attempts + 1;
	}
	return default_port;
}

// ── device (CPU/GPU) selection ───────────────────────────────────────
// First-class CPU/GPU toggle. CPU vs GPU is otherwise implicit in a
// profile's intent.gpu_layers (0 = CPU, >0 = offload). Rather than add a
// parallel placement path, we resolve a device choice and OVERRIDE
// gpu_layers before placement + spawn — both pick_placement*() and the
// agent's spawn_service() already branch on gpu_layers == 0, so the
// override flows through end to end.
//
// Resolution order: explicit spawn-request `device` > profile.default_device
// > "auto". "auto" respects the profile's declared gpu_layers (legacy
// behavior). Returns "cpu" | "gpu" | "auto".
fn resolve_device(req_device, profile): string {
	let d = req_device;
	if (d == null || d == "") { d = profile?.default_device; }
	if (d == null || d == "") { d = "auto"; }
	return d;
}

// True for an accepted device token. Used to 400 on garbage from the API.
fn is_valid_device(d): bool {
	return d == "cpu" || d == "gpu" || d == "auto";
}

// Returns a profile with intent.gpu_layers forced per the chosen device.
// fetch_profile_by_name() hands back a fresh parse each call, so mutating
// in place is safe (no shared/cached object to corrupt).
//   cpu  → 0          (no offload; placement skips GPU fit, CVD="")
//   gpu  → keep the profile's layers if it already offloads, else 99
//   auto → unchanged
fn apply_device(profile, device) {
	if (device == "auto" || device == null) { return profile; }
	let intent = profile?.intent;
	if (intent == null) { intent = {}; }
	let layers = intent?.gpu_layers ?? 0;
	if (device == "cpu") {
		intent["gpu_layers"] = 0;
	} else {
		intent["gpu_layers"] = (layers > 0) ? layers : 99;
	}
	profile["intent"] = intent;
	return profile;
}

// Where a profile will actually run, given its (already device-applied)
// intent: "cpu" if no offload, else "gpu". Used to surface placement to
// clients/dashboard without re-deriving from gpu_indices.
fn device_label(profile): string {
	let layers = profile?.intent?.gpu_layers ?? 0;
	if (layers == 0) { return "cpu"; }
	return "gpu";
}

// ── service proxy ────────────────────────────────────────────────────

fn handle_spawn_proxy(req): object {
	let payload = parse(req.body);
	let profile_name = payload?.profile;
	let model = payload?.model;
	if (profile_name == null) {
		return { status: 400, body: "{\"error\":\"profile required\"}" };
	}

	// Model can come from three places, in priority order:
	//   1. Operator-supplied `model:` in the request (explicit override).
	//   2. Catalog lookup via the profile's model_alias.
	//   3. Profile's default_model (legacy escape hatch).
	// We don't resolve here — pick_placement_via_alias does it inline so
	// the same node that wins placement also reports the path. For the
	// explicit model: case, we pass through to the path-based placement.
	let node_id = payload?.node_id;
	let gpus = payload?.gpus;
	let port = payload?.port;
	let tensor_split = payload?.tensor_split;

	// Profile is needed in both branches (placement reads context/
	// kv_type/default_port/etc., and we need to inline the full thing
	// into the agent_payload regardless). Fetch once.
	let profile = fetch_profile_by_name(profile_name);
	if (profile == null) {
		return { status: 400, body: stringify({
			error: "unknown profile: " + profile_name
				+ " (PUT /api/profiles/" + profile_name + " to create)",
		})};
	}

	// First-class CPU/GPU override. Resolve (request > profile default >
	// auto) and rewrite intent.gpu_layers so placement + the agent spawn
	// both honor it. Reject garbage device tokens up front.
	let req_device = payload?.device;
	if (req_device != null && req_device != "" && !is_valid_device(req_device)) {
		return { status: 400, body: stringify({
			error: "invalid device '" + req_device + "' (expected auto|cpu|gpu)",
		})};
	}
	let device = resolve_device(req_device, profile);
	profile = apply_device(profile, device);

	// If the operator didn't pin (node_id, gpus), do capacity-aware
	// placement. Try alias-driven first (catalog → no FS access on CP);
	// fall back to path-driven if no alias resolves.
	if (node_id == null || gpus == null) {

		let pick = null;
		// Prefer explicit model: from the request, then alias, then default_model.
		let resolved_model = model;
		if (resolved_model == null && profile?.model_alias != null) {
			pick = pick_placement_via_alias(profile.model_alias, profile);
			if (pick != null) { resolved_model = pick.model_path; }
		}
		if (pick == null) {
			if (resolved_model == null) { resolved_model = profile?.default_model; }
			if (resolved_model == null) {
				return { status: 400, body: stringify({
					error: "no model resolved for " + profile_name
						+ " (request had no model, profile has no model_alias "
						+ "in catalog, and no default_model)",
				})};
			}
			let path_pick = pick_placement(resolved_model, profile);
			if (path_pick?.error != null) {
				return { status: path_pick.status, body: stringify({ error: path_pick.error }) };
			}
			pick = path_pick;
		}
		if (pick == null) {
			return { status: 503, body: stringify({
				error: "no GPU has enough free VRAM for " + profile_name
					+ " + this model at context " + profile.context,
			})};
		}
		node_id = pick.node_id;
		gpus = pick.gpu_indices;
		tensor_split = pick.tensor_split;
		model = resolved_model;
		if (port == null) { port = pick_port(pick.agent_url, profile.default_port); }
	} else {
		// Pinned (node_id + gpus). Operator must supply the model path —
		// no point doing a catalog lookup since they've already chosen
		// where to spawn it.
		if (model == null) {
			return { status: 400, body: stringify({
				error: "model required when node_id+gpus are pinned",
			})};
		}
	}

	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + node_id }) };
	}

	// Forward to the agent (which doesn't need node_id; it knows it's local).
	// `profile` is the inline JSON object — agents don't have their own
	// PROFILES map anymore (since v0.7), they just run what we hand them.
	// `profile_name` is kept on the wire so service rows / logs / dashboard
	// show the human-friendly identifier.
	let agent_payload = {
		profile_name: profile_name,
		profile:      profile,
		model:        model,
		port:         port,
		gpus:         gpus,
		tensor_split: tensor_split,
	};
	try {
		let resp = cp_post_json(agent_url + "/services", agent_payload);
		// Tag the placement decision into the response body so the client
		// can see what CP picked. Only do this on success.
		if (resp.status_code >= 200 && resp.status_code < 300) {
			let body = parse(resp.body);
			body["node_id"] = node_id;
			body["placed_by"] = "cp";
			body["device"] = device_label(profile);
			return { status: resp.status_code, body: stringify(body) };
		}
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

fn handle_stop_proxy(req): object {
	let payload = parse(req.body);
	let id = payload?.id;
	let node_id = payload?.node_id;
	if (id == null || node_id == null) {
		return { status: 400, body: "{\"error\":\"id+node_id required\"}" };
	}
	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + node_id }) };
	}
	try {
		let resp = cp_post_json(agent_url + "/services/stop", { id: id });
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

// POST /unmanaged/kill { node_id, pid } → proxy to the node's agent to
// SIGTERM an unmanaged process. Best-effort (cross-user kills hit EPERM).
fn handle_kill_unmanaged_proxy(req): object {
	let payload = parse(req.body);
	let pid = payload?.pid;
	let node_id = payload?.node_id;
	if (pid == null || node_id == null) {
		return { status: 400, body: "{\"error\":\"pid+node_id required\"}" };
	}
	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + node_id }) };
	}
	try {
		let resp = cp_post_json(agent_url + "/unmanaged/kill", { pid: pid });
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

// POST /api/scan-dirs { node_id, extra? } → proxy to the node's agent.
// With `extra` (array) it sets the editable scan dirs (+ rescans); without
// it, returns the current dirs. (No query-string parsing in the router,
// so GET-as-POST.)
fn handle_scan_dirs_proxy(req): object {
	let payload = parse(req?.body ?? "{}");
	let node_id = payload?.node_id;
	if (node_id == null) {
		return { status: 400, body: "{\"error\":\"node_id required\"}" };
	}
	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + node_id }) };
	}
	try {
		if (payload.has("extra")) {
			let resp = cp_post_json(agent_url + "/scan-dirs", { extra: payload.extra });
			return { status: resp.status_code, body: resp.body };
		}
		let resp = cp_get(agent_url + "/scan-dirs");
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

// POST /models/delete { node_id, path } → proxy to the node's agent to
// delete a GGUF from disk (agent guards: .gguf + under a scan dir).
fn handle_model_delete_proxy(req): object {
	let payload = parse(req?.body ?? "{}");
	let node_id = payload?.node_id;
	let path = payload?.path;
	if (node_id == null || path == null) {
		return { status: 400, body: "{\"error\":\"node_id+path required\"}" };
	}
	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node_id: " + node_id }) };
	}
	try {
		let resp = cp_post_json(agent_url + "/models/delete", { path: path });
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

fn handle_list_services(req): object {
	// Aggregate from every registered agent. Each service is tagged with
	// its owning node_id so subsequent stop calls know where to route.
	let agents = list_all_agents();
	let merged = [];
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				let entries = parse(resp.body);
				for (e in entries) {
					e["node_id"] = a.node_id;
					merged.push(e);
				}
			}
		} catch (e) {
			// Agent unreachable — skip; we'll surface in /nodes as a stale
			// last_seen_at once heartbeats land.
		}
	}
	return { status: 200, body: stringify(merged) };
}

// ── inference routing ────────────────────────────────────────────────
// /v1/llama/{profile}/{...} → http://{agent_host}:{service_port}/{...}
//
// CP looks up a running service by profile, derives the llama-server URL
// from the agent's host (we already store agent_url) and the service's
// port, then forwards the request directly. Agents stay off the data path
// — every chat reply going through the agent just to reach llama-server
// would tax latency for no architectural benefit.

let LLAMA_PREFIX = "/v1/llama/";

// Strip the URL scheme + port off agent_url, leaving just the host.
//   "http://10.0.0.20:8766" → "10.0.0.20"
//   "http://localhost:8766"     → "localhost"
fn extract_host(agent_url: string): string {
	let rest = agent_url;
	let scheme = rest.find("://");
	if (scheme >= 0) { rest = rest.substr(scheme + 3, rest.length - scheme - 3); }
	let slash = rest.find("/");
	if (slash >= 0) { rest = rest.substr(0, slash); }
	let colon = rest.find(":");
	if (colon >= 0) { rest = rest.substr(0, colon); }
	return rest;
}

// Pick the first running service matching this profile. Returns
// { agent_host, port } or null. Round-robin / placement is a later slice.
fn find_service_for_profile(profile_name: string) {
	let agents = list_all_agents();
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code < 200 || resp.status_code >= 300) { continue; }
			let entries = parse(resp.body);
			for (e in entries) {
				if (e?.profile == profile_name && e?.alive == true) {
					return {
						agent_host: extract_host(a.agent_url),
						port: e.port,
					};
				}
			}
		} catch (err) {
			// Agent unreachable; try next.
		}
	}
	return null;
}

// GET /resolve/{profile-or-alias} — control-plane location lookup.
//
// The data-plane counterpart of the /v1/llama proxy: instead of
// forwarding the inference request, just return WHERE the live
// llama-server is, so a consumer (FlameWorker/FlameGen) can connect
// directly and keep the CP out of the inference hot path entirely.
// Side-effect-free and cheap: alias-resolve + one /services scan, no
// proxying, no auto-spawn (spawn stays an explicit POST /services).
//
// 200 { profile, alias, host, port, base_url } when a matching
// service is running; 404 { error, profile } when it isn't (the
// consumer then decides: spawn via POST /services, or back off and
// re-resolve). Public — it's a location, not a secret, and workers
// must reach it before any bearer is provisioned.
fn handle_resolve(req): object {
	let prefix = "/resolve/";
	if (req.path.length <= prefix.length) {
		return { status: 400,
			body: "{\"error\":\"profile required: /resolve/{profile-or-alias}\"}" };
	}
	let raw = req.path.substr(prefix.length, req.path.length - prefix.length);
	// Tolerate a trailing slash and ignore any extra path segments.
	let slash = raw.find("/");
	let alias = raw;
	if (slash >= 0) { alias = raw.substr(0, slash); }
	if (alias.length == 0) {
		return { status: 400,
			body: "{\"error\":\"profile required: /resolve/{profile-or-alias}\"}" };
	}

	let profile_name = resolve_profile_name(alias);
	let target = find_service_for_profile(profile_name);
	if (target == null) {
		return { status: 404, body: stringify({
			error: "no running service for profile",
			profile: profile_name,
			alias: alias,
		}) };
	}

	let base = "http://" + target.agent_host + ":" + target.port;
	return { status: 200, body: stringify({
		profile:  profile_name,
		alias:    alias,
		host:     target.agent_host,
		port:     target.port,
		base_url: base,
	}) };
}

// GET /api/ready/{profile-or-alias} — one-shot readiness probe so the spawn
// UI can show "loading model… → ready" instead of a bare "spawned" while a
// freshly-spawned model is still loading (POST /services returns once the
// process is up, ~10–15s before the model answers /health). Resolves the
// live service and does a single health probe (path per binary). Public —
// it's a status, not a secret.
fn handle_service_ready(req): object {
	let prefix = "/api/ready/";
	if (req.path.length <= prefix.length) {
		return { status: 400, body: "{\"error\":\"profile required: /api/ready/{profile}\"}" };
	}
	let raw = req.path.substr(prefix.length, req.path.length - prefix.length);
	let slash = raw.find("/");
	let alias = raw;
	if (slash >= 0) { alias = raw.substr(0, slash); }
	let profile_name = resolve_profile_name(alias);
	let target = find_service_for_profile(profile_name);
	if (target == null) {
		return { status: 200, body: stringify({ ready: false, phase: "no-service" }) };
	}
	let profile = fetch_profile_by_name(profile_name);
	let url = "http://" + target.agent_host + ":" + target.port
		+ health_path_for(profile?.binary);
	let ready = false;
	try { let r = get(url, null); if (r.status_code == 200) { ready = true; } } catch (e) { }
	return { status: 200, body: stringify({
		ready: ready,
		phase: (ready ? "ready" : "loading"),
		host:  target.agent_host,
		port:  target.port,
	}) };
}

// Wait for a freshly-spawned llama-server to flip from "Loading model" to
// 200 on /health. Returns true on ready, false on timeout. 60s ceiling
// covers a 12B model on a fast GPU; bigger models on slower disks may
// need more — make configurable when that bites.
let AUTOSPAWN_READY_TIMEOUT_SECONDS = 60;

// Readiness probe path differs per engine: llama-server exposes
// /health; stable-diffusion.cpp's server has no /health — its
// lightest always-available GET once the model is loaded is
// /sdapi/v1/options (returns the loaded checkpoint stem). Caller
// passes the right path based on the profile's binary.
fn health_path_for(binary): string {
	if (binary == "sd-server")      { return "/sdapi/v1/options"; }
	// whisper-server / piper: minimal HTTP surfaces, both return 200
	// on `/` once the listener is bound. piper's model is loaded on
	// first request; whisper's is loaded eagerly when --model is
	// passed at spawn time.
	if (binary == "whisper-server") { return "/"; }
	if (binary == "piper")          { return "/"; }
	return "/health";
}

fn wait_for_service_ready(host: string, port: i32, health_path: string): bool {
	let url = "http://" + host + ":" + port + health_path;
	let waited = 0;
	while (waited < AUTOSPAWN_READY_TIMEOUT_SECONDS) {
		try {
			let r = get(url, null);
			if (r.status_code == 200) { return true; }
			// 503 with "Loading model" body is the normal in-flight state;
			// keep polling. Any other status is a real problem but we'll
			// keep trying until timeout to ride out transient issues.
		} catch (e) {
			// Connection refused while llama-server's still binding the
			// socket. Same — keep polling.
		}
		sleep(1.0);
		waited = waited + 1;
	}
	return false;
}

// Triggered when handle_llama_proxy gets a request for a profile that
// has no running service. Looks up the profile's default_model, runs
// the same placement path as explicit POST /services, posts the spawn
// to the chosen agent, then blocks on /health until the new instance
// answers (or we hit the timeout).
//
// Returns { agent_host, port } on success, or an HTTP-shaped error
// object {status, body} the caller should propagate to the client.
//
// NOTE: this blocks CP's accept loop for the load-time of the model
// (10-15s for 12B-class). Single-threaded HTTP means no other requests
// get served during that window. Acceptable for v1 since auto-spawn
// fires rarely (only on first request after agent restart). When this
// becomes a problem, the fix is to make CP's accept loop spawn each
// request handler on a worker thread.
fn auto_spawn(profile_name: string) {
	let profile = fetch_profile(profile_name);
	if (profile == null) {
		return { error: { status: 503, body: stringify({
			error: "no agent advertises profile: " + profile_name,
		})}};
	}

	// Honor the profile's default_device on the auto-spawn path (no request
	// override exists here — /v1/llama/* is profile-derived).
	profile = apply_device(profile, resolve_device(null, profile));

	// Same priority ladder as handle_spawn_proxy: alias-driven first,
	// then default_model fallback. The /v1/llama/* path has no operator-
	// supplied override; it's all profile-derived.
	let pick = null;
	let resolved_model = null;
	if (profile?.model_alias != null) {
		pick = pick_placement_via_alias(profile.model_alias, profile);
		if (pick != null) { resolved_model = pick.model_path; }
	}
	if (pick == null) {
		if (profile?.default_model == null) {
			let alias = profile?.model_alias;
			let body = {
				error: "no running service for profile " + profile_name
					+ " and no model resolvable (alias '"
					+ (alias ?? "<none>")
					+ "' not in any node's catalog and no default_model)",
			};
			// Enrich with hunt hints when we have an alias to look up.
			// Operator sees "here's the HF coords / here's a peer that
			// has it" right in the error and can POST /models/distribute.
			if (alias != null) {
				body["alias"] = alias;
				body["known_sources"] = known_sources_for(alias, null);
				body["hint"] = "POST /models/distribute "
					+ "{alias, target_node, source_kind?} to fetch it";
			}
			return { error: { status: 503, body: stringify(body) }};
		}
		resolved_model = profile.default_model;
		let path_pick = pick_placement(profile.default_model, profile);
		if (path_pick?.error != null) {
			return { error: { status: path_pick.status,
				body: stringify({ error: path_pick.error }) }};
		}
		pick = path_pick;
	}
	if (pick == null) {
		return { error: { status: 503, body: stringify({
			error: "auto-spawn declined: no GPU has free VRAM for "
				+ profile_name + " at context " + profile.context,
		})}};
	}
	let port = pick_port(pick.agent_url, profile.default_port);
	let agent_payload = {
		profile_name: profile_name,
		profile:      profile,
		model:        resolved_model,
		port:         port,
		gpus:         pick.gpu_indices,
		tensor_split: pick.tensor_split,
	};

	let gpu_csv = "";
	let gi = 0;
	while (gi < pick.gpu_indices.length) {
		if (gi > 0) { gpu_csv = gpu_csv + ","; }
		gpu_csv = gpu_csv + pick.gpu_indices[gi];
		gi = gi + 1;
	}
	print("[autospawn] " + profile_name + " on " + pick.node_id
		+ " gpus=" + gpu_csv + " port=" + port);

	let spawn_resp = null;
	try {
		spawn_resp = cp_post_json(pick.agent_url + "/services", agent_payload);
	} catch (e) {
		return { error: { status: 502, body: stringify({
			error: "auto-spawn: agent unreachable: " + e,
		})}};
	}
	if (spawn_resp.status_code < 200 || spawn_resp.status_code >= 300) {
		return { error: { status: spawn_resp.status_code, body: spawn_resp.body }};
	}

	let host = extract_host(pick.agent_url);
	if (!wait_for_service_ready(host, port, health_path_for(profile?.binary))) {
		return { error: { status: 503, body: stringify({
			error: "auto-spawned service did not become ready in "
				+ AUTOSPAWN_READY_TIMEOUT_SECONDS + "s",
		})}};
	}
	print("[autospawn] " + profile_name + " ready on " + host + ":" + port);
	return { agent_host: host, port: port };
}

fn handle_llama_proxy(req): object {
	// req.path is "/v1/llama/chat-mahou/completion"; split off the profile
	// and the suffix that goes to llama-server.
	let after = req.path.substr(LLAMA_PREFIX.length,
		req.path.length - LLAMA_PREFIX.length);
	let slash = after.find("/");
	let profile_name = "";
	let suffix = "";
	if (slash < 0) {
		profile_name = after;
		suffix = "/";
	} else {
		profile_name = after.substr(0, slash);
		suffix = after.substr(slash, after.length - slash);
	}
	if (profile_name.length == 0) {
		return { status: 400, body: "{\"error\":\"profile required: /v1/llama/{profile}/{path}\"}" };
	}

	// Resolve aliases so a public-facing URL like /v1/llama/flame-chat/...
	// can map to an internal profile (e.g. chat-mahou). When no alias
	// matches, returns the name unchanged so direct profile names
	// continue to work without setup.
	profile_name = resolve_profile_name(profile_name);

	let target = find_service_for_profile(profile_name);
	if (target == null) {
		// Auto-spawn path. Either succeeds (target gets a value), or hands
		// back a {status, body} we propagate to the client unchanged.
		let result = auto_spawn(profile_name);
		if (result?.error != null) {
			return result.error;
		}
		target = result;
	}

	let target_url = "http://" + target.agent_host + ":" + target.port + suffix;
	// Forward as JSON for now — every llama-server endpoint we care about
	// (completion, chat/completions, embeddings) takes JSON. Generalize when
	// we add image gen / multipart paths.
	let headers = ["Content-Type: application/json"];

	// Detect stream:true in the body. llama-server returns SSE
	// (text/event-stream) when stream is true; we need to forward
	// chunks straight through to the client without buffering, so the
	// caller sees tokens as they're produced. Otherwise we buffer
	// (single JSON object response) — same as before.
	//
	// Body parse cost: chat completion bodies are typically <100KB,
	// most under 10KB. Single JSON parse per request is noise vs the
	// inference cost.
	let want_stream = false;
	if (req.body != null && req.body.length > 0) {
		try {
			let payload = parse(req.body);
			if (payload?.stream == true) { want_stream = true; }
		} catch (e) {
			// Non-JSON body — treat as buffered. llama-server only
			// accepts JSON for the endpoints we care about, so a
			// malformed body will fail upstream with a useful error.
		}
	}

	if (want_stream) {
		let s = null;
		try {
			s = http_stream(req.method, target_url, req.body, headers, 600000);
		} catch (e) {
			return { status: 502, body: stringify({
				error: "llama-server unreachable at " + target_url + ": " + e,
			})};
		}
		return {
			status: s.status_code,
			stream_upstream: s,
			headers: { "content-type": "text/event-stream" },
		};
	}

	try {
		// 10-minute budget matches the streaming path. Hemlock 2.4.0
		// dropped the default lws timeout to 5s, which is fine for CP
		// internal calls but kills long buffered generations (a
		// 1000-token completion easily exceeds 30s on a 12B model).
		// Use the explicit-timeout variant to opt back into the longer
		// budget for inference forwarding only.
		let resp = http_request_timeout(req.method, target_url, req.body, headers, 600000);
		// Body might be JSON or text — pass through unchanged. Status from
		// llama-server is the final word.
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({
			error: "llama-server unreachable at " + target_url + ": " + e,
		})};
	}
}

// ── dashboard data fetchers ─────────────────────────────────────────
// Thin wrappers that pull live data the dashboard fragments need.
// Kept here (rather than in dashboard.hml) because they touch the DB
// and the cross-agent fan-out — concerns that belong with CP.

fn nodes_for_dashboard(): array {
	let rows = query(DB,
		"select node_id, hostname, role, hardware_json, agent_url, "
		+ "registered_at, last_seen_at, state, runtime_json, auto_restart, agent_version, "
		+ "cast((julianday('now') - julianday(last_seen_at)) * 86400 as integer) as age_seconds "
		+ "from nodes order by registered_at desc", []);
	let out = [];
	for (row in rows) {
		let runtime = null;
		if (row?.runtime_json != null) {
			try { runtime = parse(row.runtime_json); } catch (e) { }
		}
		out.push({
			node_id: row.node_id,
			hostname: row.hostname,
			role: row.role,
			hardware: parse(row.hardware_json),
			agent_url: row.agent_url,
			last_seen_at: row.last_seen_at,
			age_seconds: row.age_seconds,
			state: row?.state ?? "active",
			runtime: runtime,
			auto_restart: (row?.auto_restart == null) ? null : (row.auto_restart == 1),
			agent_version: row?.agent_version,
		});
	}
	return out;
}

// Fan out to every agent's /services and group the live list by node, so
// the node cards can show each box's managed services inline under its
// hardware. Same source the fleet-wide /ui/services panel uses; a dead
// agent just contributes no entry (its services show as none).
fn services_by_node(): object {
	let agents = list_all_agents();
	let out = {};
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				let entries = parse(resp.body);
				let host = extract_host(a.agent_url);
				let list = [];
				for (e in entries) {
					// Enrich each service with what the dashboard's "connect"
					// modal needs but the agent doesn't carry: the host CP
					// reaches the agent at (→ the service's direct base_url is
					// http://{agent_host}:{port}) and the profile's engine
					// binary (→ which API + example to show). Best-effort: a
					// service whose profile was deleted just renders generic.
					e["agent_host"] = host;
					let prof = fetch_profile(e?.profile);
					e["binary"] = prof?.binary ?? "llama-server";
					list.push(e);
				}
				out[a.node_id] = list;
			}
		} catch (e) { }
	}
	return out;
}

fn handle_ui_nodes(req): object {
	let nodes = nodes_for_dashboard();
	let samples = samples_for_dashboard(nodes);
	let unmanaged = unmanaged_by_node();
	let svcs = services_by_node();
	let body = render_nodes(nodes, samples, unmanaged, svcs, STALE_NODE_SECONDS);
	return { status: 200, body: body,
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// Group rows of node_unmanaged_procs by (node_id, gpu_index) so the
// renderer can drop the relevant entries under the matching GPU row
// without filtering inline. Shape:
//   { node_id → { gpu_index_str → [{pid, process_name, vram_mb, owner_name}, ...] } }
fn unmanaged_by_node(): object {
	let rows = query(DB,
		"select node_id, pid, process_name, vram_mb, gpu_index, owner_name, "
		+ "owner_uid, ports, cmdline "
		+ "from node_unmanaged_procs order by vram_mb desc", []);
	let out = {};
	for (r in rows) {
		if (!out.has(r.node_id)) { out[r.node_id] = {}; }
		let key = "" + (r?.gpu_index ?? -1);
		if (!out[r.node_id].has(key)) { out[r.node_id][key] = []; }
		// ports stored as JSON text by newer agents; null/garbage → [].
		let ports = [];
		if (r?.ports != null) { try { ports = parse(r.ports); } catch (e) { ports = []; } }
		out[r.node_id][key].push({
			pid:          r.pid,
			process_name: r.process_name,
			vram_mb:      r.vram_mb,
			owner_name:   r?.owner_name,
			owner_uid:    r?.owner_uid,
			ports:        ports,
			cmdline:      r?.cmdline,
		});
	}
	return out;
}

fn handle_ui_services(req): object {
	// Reuse the JSON aggregator's logic — call the agents, build the
	// merged list, hand to the renderer. Also fetch the current
	// profiles map so the renderer can flag a "stale" badge on
	// services whose profile_version is older than the live profile.
	let agents = list_all_agents();
	let merged = [];
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				let entries = parse(resp.body);
				for (e in entries) {
					e["node_id"] = a.node_id;
					merged.push(e);
				}
			}
		} catch (e) { }
	}
	let live_profiles = all_profiles_map();
	return { status: 200, body: render_services(merged, live_profiles),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// ── live state stream (SSE) ──────────────────────────────────────────
// /events holds a connection open and pushes a compact snapshot of fleet
// state (services + nodes) whenever it changes, so the dashboard updates
// in near-real-time instead of polling every 5s. serve() runs each
// connection in its own detached task, so this loop doesn't block other
// requests; a failed write (client/tab gone) ends the loop and frees the
// task. Cheap by design: re-snapshot every SSE_POLL_SECONDS, push only on
// change, keepalive comment otherwise.
let SSE_POLL_SECONDS: f64 = 2.0;
let SSE_KEEPALIVE_TICKS = 8;            // ~16s without a change → keepalive

// Compact, hashable view of what the dashboard renders: per-service
// (id, profile, node, port, alive, device) and per-node (id, role, up).
fn events_snapshot(): object {
	let agents = list_all_agents();
	let svcs = [];
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				for (e in parse(resp.body)) {
					svcs.push({ id: e.id, profile: e.profile, node: a.node_id,
						port: e.port, alive: e.alive, device: e?.device,
						state: e?.state });
				}
			}
		} catch (e) { }
	}
	let nrows = query(DB,
		"select node_id, role, (last_seen_at > datetime('now', ?)) as up from nodes",
		["-" + STALE_NODE_SECONDS + " seconds"]);
	let nodes = [];
	for (r in nrows) {
		nodes.push({ node_id: r.node_id, role: r.role, up: (r.up == 1) });
	}
	return { services: svcs, nodes: nodes };
}

// One-shot snapshot (same shape /events streams). Lets the dashboard paint
// the health banner immediately on load without waiting for the first SSE
// frame; also handy for scripts that want fleet state without a stream.
fn handle_state(req): object {
	return { status: 200, body: stringify(events_snapshot()),
		headers: { "content-type": "application/json" } };
}

fn handle_events(req): object {
	let emit = fn(stream): null {
		// We own the connection: write the SSE preamble ourselves. No
		// Content-Length (open-ended); x-accel-buffering off so reverse
		// proxies don't sit on frames.
		try {
			stream.write("HTTP/1.1 200 OK\r\n");
			stream.write("content-type: text/event-stream\r\n");
			stream.write("cache-control: no-cache\r\n");
			stream.write("connection: keep-alive\r\n");
			stream.write("x-accel-buffering: no\r\n");
			stream.write("\r\n");
			stream.write("retry: 3000\n\n");
		} catch (e) { return null; }

		let last_payload = "";
		let ticks = 0;
		loop {
			let payload = stringify(events_snapshot());
			let ok = true;
			if (payload != last_payload) {
				last_payload = payload;
				ticks = 0;
				try { stream.write("event: state\ndata: " + payload + "\n\n"); }
				catch (e) { ok = false; }
			} else {
				ticks = ticks + 1;
				if (ticks >= SSE_KEEPALIVE_TICKS) {
					ticks = 0;
					try { stream.write(": keepalive\n\n"); } catch (e) { ok = false; }
				}
			}
			if (!ok) { break; }      // client/tab gone
			sleep(SSE_POLL_SECONDS);
		}
		return null;
	};
	return { sse_handler: emit };
}

// Profiles live in CP's table since v0.7. all_profiles_map() (defined
// near the CRUD handlers below) returns the same shape that the
// agent-fan-out used to return — name → profile object.
fn handle_ui_profiles(req): object {
	return { status: 200, body: render_profiles(all_profiles_map()),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// Per-node capability map: { node_id → { binary → { flag → flag_info } } }
// Each agent introspects its own binaries at boot; CP just fans out.
fn aggregated_capabilities(): object {
	let agents = list_all_agents();
	let out = {};
	for (a in agents) {
		try {
			let resp = cp_get(a.agent_url + "/capabilities");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				out[a.node_id] = parse(resp.body);
			}
		} catch (e) { }
	}
	return out;
}

fn handle_ui_capabilities(req): object {
	return { status: 200, body: render_capabilities(aggregated_capabilities()),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// JSON variant of /ui/capabilities for the profile editor's
// capability-aware warnings. Same aggregated shape, JSON instead of
// rendered HTML. Public so the editor JS can fetch it freely.
fn handle_list_capabilities(req): object {
	return { status: 200, body: stringify(aggregated_capabilities()),
		headers: { "content-type": "application/json" } };
}

// ── catalog ──────────────────────────────────────────────────────────
// Aggregated GGUF catalog across every registered node. Each alias may
// appear on multiple nodes; the operator (or placement) picks where to
// run.

// Look up nodes that have a given alias on disk. Used by placement to
// resolve model_alias → (node, path). Returns rows with the placement
// ingredients pre-extracted so we don't re-parse hardware_json per call.
fn nodes_with_alias(alias: string): array {
	let rows = query(DB,
		"select node_id, path, size_mb, architecture, n_layers, n_heads, "
		+ "n_kv_heads, embedding_length, claimed_context, source_url "
		+ "from node_models where alias = ?", [alias]);
	return rows;
}

// Aggregated catalog grouped by alias, for the dashboard + JSON endpoint.
fn catalog_grouped(): array {
	let rows = query(DB,
		"select alias, node_id, path, size_mb, architecture, "
		+ "claimed_context, general_name, source_url "
		+ "from node_models order by alias asc, node_id asc", []);
	let by_alias = {};
	let order = [];
	for (row in rows) {
		if (!by_alias.has(row.alias)) {
			by_alias[row.alias] = {
				alias: row.alias,
				size_mb: row.size_mb,
				architecture: row.architecture,
				claimed_context: row.claimed_context,
				general_name: row.general_name,
				source_url: row.source_url,
				on_nodes: [],
			};
			order.push(row.alias);
		}
		by_alias[row.alias].on_nodes.push({
			node_id: row.node_id,
			path:    row.path,
		});
	}
	let out = [];
	for (a in order) { out.push(by_alias[a]); }
	return out;
}

fn handle_list_catalog(req): object {
	return { status: 200, body: stringify(catalog_grouped()) };
}

fn handle_ui_catalog(req): object {
	return { status: 200,
		body: render_catalog(catalog_grouped(), nodes_for_dashboard()),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

fn handle_ui_transfers(req): object {
	return { status: 200, body: render_transfers(aggregated_transfers()),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// Build the missing-models list: aliases that any profile names but
// no node has on disk. Each row carries known_sources + the profiles
// that reference it so the UI can render an actionable hint.
fn missing_models(): array {
	let profiles = all_profiles_map();
	let names = profiles.keys();
	let aliases_to_profiles = {};
	for (n in names) {
		let p = profiles[n];
		let alias = p?.model_alias;
		if (alias == null) { continue; }
		if (!aliases_to_profiles.has(alias)) {
			aliases_to_profiles[alias] = [];
		}
		aliases_to_profiles[alias].push(n);
	}

	let out = [];
	let alias_keys = aliases_to_profiles.keys();
	for (alias in alias_keys) {
		let on = nodes_with_alias(alias);
		if (on.length > 0) { continue; }  // someone has it; not missing
		out.push({
			alias:         alias,
			profiles:      aliases_to_profiles[alias],
			known_sources: known_sources_for(alias, null),
		});
	}
	return out;
}

fn handle_ui_missing(req): object {
	return { status: 200,
		body: render_missing(missing_models(), nodes_for_dashboard()),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// ── distribution ─────────────────────────────────────────────────────
//
// Resolve known sources for an alias: peer (any node that has it on
// disk EXCEPT the target node itself) + hf (any profile with this
// model_alias and an hf_source). Used both by /models/distribute (to
// auto-pick a source) and by routing 404s (to enrich the error body
// with hunt hints).
fn known_sources_for(alias: string, target_node) {
	let out = { peer: [], hf: [] };

	// Peer: every other node that has the alias on disk, paired with
	// its agent_url so the target can hit /models/{alias}/blob there.
	let rows = query(DB,
		"select nm.node_id as node_id, nm.path as path, n.agent_url as agent_url "
		+ "from node_models nm "
		+ "join nodes n on nm.node_id = n.node_id "
		+ "where nm.alias = ? "
		+ "and n.agent_url is not null "
		+ "and n.last_seen_at > datetime('now', ?)",
		[alias, "-" + STALE_NODE_SECONDS + " seconds"]);
	for (row in rows) {
		if (row.node_id == target_node) { continue; }  // can't pull from self
		out.peer.push({
			node_id:   row.node_id,
			agent_url: row.agent_url,
			blob_url:  row.agent_url + "/models/" + alias + "/blob",
		});
	}

	// HF: scan aggregated profiles for any that name this alias and
	// include an hf_source. Same alias may show up in multiple
	// profiles; first match wins.
	let profiles = all_profiles_map();
	let names = profiles.keys();
	for (n in names) {
		let p = profiles[n];
		if (p?.model_alias == alias && p?.hf_source != null) {
			out.hf.push({
				profile: n,
				repo:    p.hf_source.repo,
				file:    p.hf_source.file,
			});
		}
	}
	return out;
}

fn handle_distribute(req): object {
	let payload = parse(req.body);
	let alias = payload?.alias;
	let target_node = payload?.target_node;
	if (alias == null || target_node == null) {
		return { status: 400, body: stringify({
			error: "alias + target_node required",
		})};
	}
	// alias becomes a filename on the target node — validate at the edge.
	if (!valid_pull_alias(alias)) {
		return { status: 400, body: stringify({
			error: "invalid alias: single segment of [A-Za-z0-9._-], no '..'",
		})};
	}
	let target_url = lookup_agent(target_node);
	if (target_url == null) {
		return { status: 404, body: stringify({
			error: "no agent for target_node: " + target_node,
		})};
	}

	let sources = known_sources_for(alias, target_node);
	let source_kind = payload?.source_kind;
	let pull_body = null;

	// Operator-supplied source_kind narrows; absence means "auto-pick".
	// Auto-pick prefers peer (LAN, faster) over HF (internet).
	if (source_kind == "peer" || (source_kind == null && sources.peer.length > 0)) {
		if (sources.peer.length == 0) {
			return { status: 422, body: stringify({
				error: "no peer source for alias '" + alias + "'",
				known_sources: sources,
			})};
		}
		pull_body = { alias: alias, source: { kind: "peer",
			url: sources.peer[0].blob_url } };
	} else if (source_kind == "huggingface" || source_kind == null) {
		if (sources.hf.length == 0) {
			return { status: 422, body: stringify({
				error: "no source available for alias '" + alias
					+ "' (no peer has it on disk and no profile names "
					+ "an hf_source for this alias)",
				known_sources: sources,
			})};
		}
		pull_body = { alias: alias, source: { kind: "huggingface",
			repo: sources.hf[0].repo, file: sources.hf[0].file } };
	} else {
		return { status: 400, body: stringify({
			error: "unknown source_kind: " + source_kind
				+ " (expected 'peer' or 'huggingface')",
		})};
	}

	try {
		let resp = cp_post_json(target_url + "/models/pull", pull_body);
		// Enrich the response with what we picked so the UI can show
		// "pulling from {repo} via HF" or "pulling from schneewolf via peer".
		if (resp.status_code >= 200 && resp.status_code < 300) {
			let body = parse(resp.body);
			body["target_node"] = target_node;
			body["source"] = pull_body.source;
			return { status: resp.status_code, body: stringify(body) };
		}
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({
			error: "target agent unreachable: " + e,
		})};
	}
}

// ── HuggingFace search + pull (v0.7+ slice C4) ───────────────────────
//
// CP-side proxies for the HF public API so the dashboard can let an
// operator type a name → pick a repo → pick a quant file → pull it
// onto a node. The agent already knows how to do `kind=huggingface`
// downloads; this just resolves the (repo, file) pair from a search
// query and brokers a single round-trip.
//
// All three endpoints take JSON bodies via POST rather than query
// strings because the router does exact path matching and HF repo
// IDs contain '/' which makes path-segment encoding awkward.

let HF_API_BASE = "https://huggingface.co/api";

// HF API fetches go through curl rather than the in-process http client:
// lws's TLS client wedges after the first HTTPS request in a process
// (first request 200, every subsequent one fails instantly), which broke
// repeated catalog searches. curl opens a fresh connection per call.
// Args pass via exec_argv (array form, no shell) so the URL can't inject.
// -w appends "\n<http_code>" so the last line is the status; everything
// before the final newline is the response body.
fn hf_get(url: string): object {
	let r = exec_argv(["curl", "-sSL", "--max-time", "30",
		"-w", "\n%{http_code}", url]);
	if (r.exit_code != 0) {
		throw "curl exit " + r.exit_code + ": " + r.output;
	}
	let out = r.output;
	let nl = -1;
	let i = 0;
	while (i < out.length) { if (out.substr(i, 1) == "\n") { nl = i; } i = i + 1; }
	let body = (nl >= 0) ? out.substr(0, nl) : out;
	let code_str = (nl >= 0) ? out.substr(nl + 1, out.length - nl - 1).trim() : "";
	let code = 0;
	try { code = i32(code_str); } catch (e) { code = 0; }
	return { status_code: code, body: body };
}

fn handle_hf_search(req): object {
	let payload = parse(req?.body ?? "{}");
	let q = payload?.q;
	if (q == null || q == "") {
		return { status: 400, body: stringify({ error: "q required" })};
	}
	// HF supports search + filter=gguf to narrow to GGUF-bearing repos.
	// limit=20 is plenty for a UI picker.
	// URL-encode the query — unencoded spaces/specials make a malformed
	// URL that fails instantly (the "HF unreachable" report). Use the
	// explicit-timeout GET (bare get() carries Hemlock's 5s default).
	let url = HF_API_BASE + "/models?search=" + url_encode(q) + "&filter=gguf&limit=20";
	try {
		let resp = hf_get(url);
		if (resp.status_code != 200) {
			return { status: 502, body: stringify({
				error: "HF search " + resp.status_code, body: resp.body }) };
		}
		let raw = parse(resp.body);
		let slim = [];
		for (m in raw) {
			slim.push({
				id:        m?.id,
				downloads: m?.downloads ?? 0,
				likes:     m?.likes ?? 0,
				updated:   m?.lastModified,
			});
		}
		return { status: 200, body: stringify(slim) };
	} catch (e) {
		return { status: 502, body: stringify({
			error: "HF unreachable: " + e })};
	}
}

fn handle_hf_files(req): object {
	let payload = parse(req?.body ?? "{}");
	let repo = payload?.repo;
	if (repo == null || repo == "") {
		return { status: 400, body: stringify({ error: "repo required" })};
	}
	// repo is "org/name" — slashes are real path separators, so it goes in
	// as-is. Validate first so a crafted repo can't inject extra URL path/
	// query segments against the HF API.
	if (!valid_hf_repo(repo)) {
		return { status: 400, body: stringify({ error: "invalid repo (expected org/name)" })};
	}
	let url = HF_API_BASE + "/models/" + repo + "/tree/main?recursive=true";
	try {
		let resp = hf_get(url);
		if (resp.status_code != 200) {
			return { status: 502, body: stringify({
				error: "HF tree " + resp.status_code, body: resp.body }) };
		}
		let raw = parse(resp.body);
		// Filter to .gguf files only; tag whether the file is sharded
		// so the picker can warn (multi-part GGUFs need all parts +
		// llama.cpp picks them up by base path).
		let ggufs = [];
		for (e in raw) {
			if (e?.type == "file" && e?.path != null
				&& e.path.ends_with(".gguf")) {
				ggufs.push({
					path: e.path,
					size: e?.size ?? 0,
					sharded: e.path.find("-of-") >= 0,
				});
			}
		}
		return { status: 200, body: stringify(ggufs) };
	} catch (e) {
		return { status: 502, body: stringify({
			error: "HF unreachable: " + e })};
	}
}

// ── model-card scrape (album-art metadata) ───────────────────────────
// POST /api/hf/card { repo } → repo metadata + the first model-card image,
// for an "album art" view. SECURITY:
//   - repo is char-validated (org/name only) so it can't smuggle path
//     tricks into the upstream URL.
//   - the image URL must resolve to a HuggingFace host AND a raster
//     extension — no SVG (no script-in-image), no arbitrary remote hosts
//     (no SSRF / tracking pixels). Anything else is dropped to "".
//   - all text is returned as plain text; the UI renders it via x-text
//     (textContent), so there's no HTML/script injection path.

fn valid_hf_repo(repo): bool {
	if (repo == null || repo.length == 0 || repo.length > 120) { return false; }
	if (repo.substr(0, 1) == "-") { return false; }   // no flag injection downstream
	let slashes = 0;
	let i = 0;
	while (i < repo.length) {
		let c = repo.substr(i, 1);
		let ok = (c >= "A" && c <= "Z") || (c >= "a" && c <= "z")
			|| (c >= "0" && c <= "9") || c == "/" || c == "-" || c == "_" || c == ".";
		if (!ok) { return false; }
		if (c == "/") { slashes = slashes + 1; }
		i = i + 1;
	}
	if (slashes != 1) { return false; }
	// Both segments must be non-empty and not dot-only — "org/.." would
	// otherwise pass the char filter and traverse the upstream URL path.
	let sl = repo.find("/");
	let org = repo.substr(0, sl);
	let name = repo.substr(sl + 1, repo.length - sl - 1);
	if (org.length == 0 || name.length == 0) { return false; }
	if (org == "." || org == ".." || name == "." || name == "..") { return false; }
	return true;
}

// A pull alias becomes a filename component on the target node
// (canonical/<alias>.gguf). Mirror the agent's valid_alias() so a bad
// alias is rejected at the CP edge too. Single safe segment only.
fn valid_pull_alias(alias): bool {
	if (alias == null || alias.length == 0 || alias.length > 128) { return false; }
	if (alias.find("/") >= 0) { return false; }
	if (alias.find("..") >= 0) { return false; }
	if (alias.substr(0, 1) == "-") { return false; }
	let i = 0;
	while (i < alias.length) {
		let c = alias.substr(i, 1);
		let ok = (c >= "A" && c <= "Z") || (c >= "a" && c <= "z")
			|| (c >= "0" && c <= "9") || c == "." || c == "_" || c == "-";
		if (!ok) { return false; }
		i = i + 1;
	}
	return true;
}

// A repo-relative file path inside an HF tree (may be nested). Same
// charset as a repo, plus must reject '..' anywhere and a leading '-'.
fn valid_hf_file(file): bool {
	if (file == null || file.length == 0 || file.length > 256) { return false; }
	if (file.substr(0, 1) == "-") { return false; }
	if (file.find("..") >= 0) { return false; }
	let i = 0;
	while (i < file.length) {
		let c = file.substr(i, 1);
		let ok = (c >= "A" && c <= "Z") || (c >= "a" && c <= "z")
			|| (c >= "0" && c <= "9") || c == "/" || c == "-" || c == "_" || c == ".";
		if (!ok) { return false; }
		i = i + 1;
	}
	return true;
}

fn hf_host_ok(url): bool {
	if (url == null || url.find("https://") != 0) { return false; }
	let rest = url.substr(8, url.length - 8);
	let slash = rest.find("/");
	let host = (slash < 0) ? rest : rest.substr(0, slash);
	let colon = host.find(":");
	if (colon >= 0) { host = host.substr(0, colon); }
	if (host == "huggingface.co") { return true; }
	let suf = ".huggingface.co";
	if (host.length > suf.length
		&& host.substr(host.length - suf.length, suf.length) == suf) { return true; }
	return false;
}

fn raster_ext_ok(url): bool {
	let u = url.to_lower();
	let qm = u.find("?");
	if (qm >= 0) { u = u.substr(0, qm); }
	return u.ends_with(".png") || u.ends_with(".jpg") || u.ends_with(".jpeg")
		|| u.ends_with(".webp") || u.ends_with(".gif");
}

// First markdown ![](url) or HTML <img src> in the README (earliest wins).
fn readme_first_image(readme): string {
	let md = "";
	let a = readme.find("![");
	if (a >= 0) {
		let r = readme.substr(a, readme.length - a);
		let op = r.find("](");
		if (op >= 0) {
			let after = r.substr(op + 2, r.length - op - 2);
			let cp = after.find(")");
			let sp = after.find(" ");
			let e = cp;
			if (sp >= 0 && (cp < 0 || sp < cp)) { e = sp; }
			if (e > 0) { md = after.substr(0, e).trim(); }
		}
	}
	let html = "";
	let b = readme.find("<img");
	if (b >= 0) {
		let r = readme.substr(b, readme.length - b);
		let s = r.find("src=");
		if (s >= 0) {
			let after = r.substr(s + 4, r.length - s - 4);
			let q = after.substr(0, 1);
			if (q == "\"" || q == "'") {
				let inner = after.substr(1, after.length - 1);
				let eq = inner.find(q);
				if (eq > 0) { html = inner.substr(0, eq).trim(); }
			}
		}
	}
	if (md != "" && html != "") { return (a <= b) ? md : html; }
	if (md != "") { return md; }
	return html;
}

fn resolve_card_image(raw, repo): string {
	if (raw == null || raw == "") { return ""; }
	let url = raw;
	if (url.find("http") != 0) {
		let rel = url;
		if (rel.find("/") == 0) { rel = rel.substr(1, rel.length - 1); }
		url = "https://huggingface.co/" + repo + "/resolve/main/" + rel;
	}
	if (!hf_host_ok(url)) { return ""; }
	if (!raster_ext_ok(url)) { return ""; }
	return url;
}

fn card_summary(readme): string {
	let body = readme;
	if (body.find("---") == 0) {
		let after = body.substr(3, body.length - 3);
		let end = after.find("\n---");
		if (end >= 0) { body = after.substr(end + 4, after.length - end - 4); }
	}
	let lines = body.split("\n");
	let pick = "";
	for (line in lines) {
		let t = line.trim();
		if (t.length < 40) { continue; }
		let c0 = t.substr(0, 1);
		if (c0 == "#" || c0 == "!" || c0 == "[" || c0 == "<" || c0 == "|"
			|| c0 == "-" || c0 == "`" || c0 == ">" || c0 == "*") { continue; }
		pick = t; break;
	}
	// drop any HTML tags (defence-in-depth; UI also escapes via x-text)
	let out = "";
	let depth = 0;
	let i = 0;
	while (i < pick.length) {
		let c = pick.substr(i, 1);
		if (c == "<") { depth = depth + 1; }
		else if (c == ">") { if (depth > 0) { depth = depth - 1; } }
		else if (depth == 0) { out = out + c; }
		i = i + 1;
	}
	out = out.trim();
	if (out.length > 280) { out = out.substr(0, 277) + "..."; }
	return out;
}

fn handle_hf_card(req): object {
	let payload = parse(req?.body ?? "{}");
	let repo = payload?.repo;
	if (!valid_hf_repo(repo)) {
		return { status: 400, body: stringify({ error: "invalid repo" }) };
	}
	// Cache hit (fresh within 14d) → serve the stored card, no HF round-trip.
	let cached = query(DB,
		"select card_json from hf_card_cache where repo = ? "
		+ "and fetched_at > datetime('now', '-14 days')", [repo]);
	if (cached.length > 0) {
		return { status: 200, body: cached[0].card_json,
			headers: { "content-type": "application/json" } };
	}
	let meta = {};
	try {
		let resp = hf_get(HF_API_BASE + "/models/" + repo);
		if (resp.status_code == 200) { meta = parse(resp.body); }
	} catch (e) { }
	let tags = meta?.tags ?? [];
	let license = "";
	let disp_tags = [];
	for (t in tags) {
		let ts = "" + t;
		if (ts.find("license:") == 0) { license = ts.substr(8, ts.length - 8); }
		else if (disp_tags.length < 8) { disp_tags.push(ts); }
	}
	let image = "";
	let summary = "";
	try {
		let rr = hf_get("https://huggingface.co/" + repo + "/raw/main/README.md");
		if (rr.status_code == 200) {
			image = resolve_card_image(readme_first_image(rr.body), repo);
			summary = card_summary(rr.body);
		}
	} catch (e) { }
	let card = stringify({
		id: repo,
		downloads: meta?.downloads ?? 0,
		likes: meta?.likes ?? 0,
		pipeline_tag: meta?.pipeline_tag,
		license: license,
		tags: disp_tags,
		summary: summary,
		image: image,
	});
	exec(DB,
		"insert into hf_card_cache (repo, card_json, fetched_at) values (?, ?, ?) "
		+ "on conflict(repo) do update set card_json=excluded.card_json, fetched_at=excluded.fetched_at",
		[repo, card, iso_now()]);
	return { status: 200, body: card, headers: { "content-type": "application/json" } };
}

fn valid_hf_author(a): bool {
	if (a == null || a.length == 0 || a.length > 60) { return false; }
	let i = 0;
	while (i < a.length) {
		let c = a.substr(i, 1);
		let ok = (c >= "A" && c <= "Z") || (c >= "a" && c <= "z")
			|| (c >= "0" && c <= "9") || c == "-" || c == "_" || c == ".";
		if (!ok) { return false; }
		i = i + 1;
	}
	return true;
}

// POST /api/hf/discover { sort, author? } → top GGUF repos by trending /
// newest / likes / downloads, optionally scoped to one author. Marks each
// result trusted=true if its author is in the configured trusted list.
// sort + author are allowlisted/char-validated before hitting the API.
fn handle_hf_discover(req): object {
	let payload = parse(req?.body ?? "{}");
	let sort_in = payload?.sort ?? "trending";
	let sort = "trendingScore";
	if (sort_in == "newest") { sort = "createdAt"; }
	else if (sort_in == "likes") { sort = "likes"; }
	else if (sort_in == "downloads") { sort = "downloads"; }
	let url = HF_API_BASE + "/models?filter=gguf&sort=" + sort + "&direction=-1&limit=24";
	let author = payload?.author;
	if (author != null && author != "") {
		if (!valid_hf_author(author)) {
			return { status: 400, body: stringify({ error: "invalid author" }) };
		}
		url = url + "&author=" + author;
	}
	// trusted set from settings
	let trusted = {};
	let csv = setting_get("hf_trusted_authors", "");
	for (a in csv.split(",")) {
		let aa = a.trim().to_lower();
		if (aa != "") { trusted[aa] = true; }
	}
	try {
		let resp = hf_get(url);
		if (resp.status_code != 200) {
			return { status: 502, body: stringify({ error: "HF discover " + resp.status_code }) };
		}
		let raw = parse(resp.body);
		let out = [];
		for (m in raw) {
			let id = m?.id ?? "";
			let auth = "";
			let sl = id.find("/");
			if (sl > 0) { auth = id.substr(0, sl); }
			out.push({
				id:        id,
				author:    auth,
				downloads: m?.downloads ?? 0,
				likes:     m?.likes ?? 0,
				updated:   m?.lastModified,
				trusted:   trusted.has(auth.to_lower()),
			});
		}
		return { status: 200, body: stringify(out) };
	} catch (e) {
		return { status: 502, body: stringify({ error: "HF unreachable: " + e }) };
	}
}

// Default alias for a freshly-pulled HF file: filename minus `.gguf`,
// lowercased, dashes for underscores. Operator can override in the
// pull body. Sharded files (`…-00001-of-00003.gguf`) lose the shard
// suffix so all parts share an alias.
fn default_alias_for_hf(file: string): string {
	let base = file;
	let slash = base.find("/");
	while (slash >= 0) {
		base = base.substr(slash + 1, base.length - slash - 1);
		slash = base.find("/");
	}
	if (base.ends_with(".gguf")) {
		base = base.substr(0, base.length - 5);
	}
	let shard = base.find("-00001-of-");
	if (shard > 0) { base = base.substr(0, shard); }
	return base.to_lower();
}

fn handle_pull_hf(req): object {
	let payload = parse(req?.body ?? "{}");
	let repo = payload?.repo;
	let file = payload?.file;
	let target_node = payload?.target_node;
	if (repo == null || file == null || target_node == null) {
		return { status: 400, body: stringify({
			error: "repo + file + target_node required" })};
	}
	// Validate here too (belt + suspenders — the agent re-checks at the
	// filesystem boundary, but reject early so a bad request never reaches
	// a node). repo/file flow into `hf download` argv + a local path.
	if (!valid_hf_repo(repo)) {
		return { status: 400, body: stringify({ error: "invalid repo (expected org/name)" })};
	}
	if (!valid_hf_file(file)) {
		return { status: 400, body: stringify({ error: "invalid file path" })};
	}
	let alias = payload?.alias;
	if (alias == null || alias == "") { alias = default_alias_for_hf(file); }
	if (!valid_pull_alias(alias)) {
		return { status: 400, body: stringify({
			error: "invalid alias: single segment of [A-Za-z0-9._-], no '..'" })};
	}

	let target_url = lookup_agent(target_node);
	if (target_url == null) {
		return { status: 404, body: stringify({
			error: "no agent for target_node: " + target_node })};
	}
	let pull_body = { alias: alias,
		source: { kind: "huggingface", repo: repo, file: file } };
	try {
		let resp = cp_post_json(target_url + "/models/pull", pull_body);
		if (resp.status_code >= 200 && resp.status_code < 300) {
			let body = parse(resp.body);
			body["target_node"] = target_node;
			body["alias"] = alias;
			body["source"] = pull_body.source;
			return { status: resp.status_code, body: stringify(body) };
		}
		return { status: resp.status_code, body: resp.body };
	} catch (e) {
		return { status: 502, body: stringify({
			error: "target agent unreachable: " + e })};
	}
}

// ── placement preview ───────────────────────────────────────────────
//
// POST /api/placement_preview { profile_name } → preview of where an
// auto-spawn for this profile WOULD land right now (without spawning).
// Drives the spawn form's "would land on schneewolf GPU 2..." hint.
// Returns one of:
//   { ok: true,  node_id, gpu_indices, est_mb, free_mb_on_picked_gpus, model_path }
//   { ok: false, reason }   -- placement declined; reason is operator-readable
fn handle_placement_preview(req): object {
	let payload = parse(req?.body ?? "{}");
	let profile_name = payload?.profile_name;
	if (profile_name == null || profile_name == "") {
		return { status: 400, body: stringify({ error: "profile_name required" }) };
	}
	let profile = fetch_profile(profile_name);
	if (profile == null) {
		return { status: 404, body: stringify({
			ok: false, reason: "no profile named " + profile_name }) };
	}

	// Honor the device selector so the preview matches what a spawn would do.
	let req_device = payload?.device;
	if (req_device != null && req_device != "" && !is_valid_device(req_device)) {
		return { status: 400, body: stringify({
			error: "invalid device '" + req_device + "' (expected auto|cpu|gpu)" }) };
	}
	profile = apply_device(profile, resolve_device(req_device, profile));

	// Alias path — same logic as auto_spawn() takes. Only previews the
	// alias case; default_model fallback would need pick_placement which
	// stats the file from CP's box and isn't meaningful as a preview.
	let alias = profile?.model_alias;
	if (alias == null) {
		return { status: 200, body: stringify({
			ok: false,
			reason: "profile has no model_alias; placement preview only "
				+ "covers the catalog path. Spawn will fall back to "
				+ "default_model resolution.",
		})};
	}
	let pick = pick_placement_via_alias(alias, profile);
	if (pick == null) {
		// Why no fit? Either no node has the alias, or no GPU has room.
		let candidates = nodes_with_alias(alias);
		if (candidates.length == 0) {
			return { status: 200, body: stringify({
				ok: false,
				reason: "alias '" + alias + "' is not on any node's disk. "
					+ "Pull it via the catalog page first.",
			})};
		}
		// Have the alias, missing VRAM. Estimate the need.
		let est = estimate_vram_from_ingredients(candidates[0],
			i32(profile.context), profile.kv_type);
		return { status: 200, body: stringify({
			ok: false,
			reason: "no node has free VRAM to fit the model + KV cache "
				+ "(~" + i32(est.total_mb) + " MB needed)",
			est_mb: est.total_mb,
		})};
	}

	// Compute free_mb on the picked GPUs so the dashboard can show
	// the headroom that'd remain after the spawn.
	// Aggregate either free vram on the picked GPUs (normal) or free
	// RAM on the node (cpu_only profiles), so the preview hint shows
	// the right capacity number for each placement mode.
	let nodes = query(DB,
		"select hardware_json from nodes where node_id = ?", [pick.node_id]);
	let free_total: i64 = 0;
	let cpu_only = (pick.gpu_indices.length == 0);
	if (nodes.length > 0) {
		let hw = parse(nodes[0].hardware_json);
		if (cpu_only) {
			free_total = i64(hw?.ram_free_mb ?? 0);
		} else {
			let gpus = hw?.gpus ?? [];
			for (g in gpus) {
				for (idx in pick.gpu_indices) {
					if (g.index == idx) { free_total = free_total + g.free_mb; }
				}
			}
		}
	}

	return { status: 200, body: stringify({
		ok:                    true,
		node_id:               pick.node_id,
		gpu_indices:           pick.gpu_indices,
		cpu_only:              cpu_only,
		est_mb:                pick.est_mb,
		free_mb_on_picked_gpus: free_total,
		model_path:            pick.model_path,
	})};
}

// GET /services/log/{node_id}/{service_id} — proxy the agent's
// /services/log/{id}, returns raw text. Dashboard pulls this into
// a modal for tail-ing without SSH.
fn handle_service_log(req): object {
	let prefix = "/services/log/";
	let rest = req.path.substr(prefix.length, req.path.length - prefix.length);
	let slash = rest.find("/");
	if (slash <= 0) {
		return { status: 400, body: "{\"error\":\"expected /services/log/{node}/{id}\"}" };
	}
	let node_id = rest.substr(0, slash);
	let id = rest.substr(slash + 1, rest.length - slash - 1);
	let agent_url = lookup_agent(node_id);
	if (agent_url == null) {
		return { status: 404, body: stringify({ error: "no agent for node: " + node_id }) };
	}
	try {
		let resp = cp_get(agent_url + "/services/log/" + id);
		return { status: resp.status_code, body: resp.body,
			headers: { "content-type": "text/plain; charset=utf-8" } };
	} catch (e) {
		return { status: 502, body: stringify({ error: "agent unreachable: " + e }) };
	}
}

// ── transfers aggregator ─────────────────────────────────────────────
fn aggregated_transfers(): array {
	let agents = list_all_agents();
	let merged = [];
	for (a in agents) {
		try {
			let resp = cp_get(a.agent_url + "/models/transfers");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				let entries = parse(resp.body);
				for (e in entries) {
					e["node_id"] = a.node_id;
					merged.push(e);
				}
			}
		} catch (e) { }
	}
	return merged;
}

fn handle_list_transfers(req): object {
	return { status: 200, body: stringify(aggregated_transfers()) };
}

// ── bench ────────────────────────────────────────────────────────
//
// Operator-triggered benchmark. Pin-spawn a profile on a target
// node, fire N timed completion requests, record aggregate stats,
// stop the service. All async — POST returns 202 + bench_id, then
// the operator polls /api/bench/{id} for progress.

let BENCH_READY_TIMEOUT_SECONDS = 120;
let BENCH_REQUEST_TIMEOUT_MS    = 120000;

// Median of an array of numbers. Mutates input via sort. Empty array
// → 0. We use median (not mean) because a single slow first request
// — typical when the model is still warming up its sampler state —
// shouldn't dominate the perceived per-token throughput number.
fn median(xs: array): f64 {
	if (xs.length == 0) { return 0.0; }
	xs.sort();
	let n: i32 = i32(xs.length);
	let mid: i32 = n / 2;
	if (n % 2 == 1) { return f64(xs[mid]); }
	return (f64(xs[mid - 1]) + f64(xs[mid])) / 2.0;
}

fn fetch_node_build_hash(node_id: string) {
	let rows = query(DB,
		"select runtime_json from nodes where node_id = ?", [node_id]);
	if (rows.length == 0 || rows[0]?.runtime_json == null) { return null; }
	let rt = parse(rows[0].runtime_json);
	return rt?.llama_server?.build_hash;
}

// The actual bench task. Runs detached on a worker thread.
async fn bench_task(bench_id: string, target_node: string,
                    profile_name: string, prompt: string,
                    n_predict: i32, repetitions: i32): null {
	// Fetch profile so we can do the spawn. fetch_profile is the
	// same lookup the routing proxy uses; null = unknown profile.
	let profile = fetch_profile_by_name(profile_name);
	if (profile == null) {
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["unknown profile: " + profile_name, bench_id]);
		return null;
	}
	let agent_url = lookup_agent(target_node);
	if (agent_url == null) {
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["no agent for node: " + target_node, bench_id]);
		return null;
	}

	// Resolve the model. Same priority as handle_spawn_proxy: alias
	// → catalog row's path on this node, else profile.default_model.
	let model_path = null;
	let resolved_gpus = null;
	let resolved_split = null;
	if (profile?.model_alias != null) {
		// Look up the alias on the TARGET node (placement is forced).
		let rows = query(DB,
			"select path from node_models where node_id = ? and alias = ?",
			[target_node, profile.model_alias]);
		if (rows.length > 0) { model_path = rows[0].path; }
	}
	if (model_path == null) { model_path = profile?.default_model; }
	let mp = model_path;
	if (mp == null) {
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["no model resolvable for profile " + profile_name + " on node " + target_node,
			 bench_id]);
		return null;
	}

	// For multi-GPU placement on this target, defer to pick_gpu_subset
	// like the routing proxy does (operator can pin in a future flag,
	// but for now bench picks intelligently).
	let nodes = query(DB,
		"select hardware_json from nodes where node_id = ?", [target_node]);
	if (nodes.length > 0) {
		let hw = parse(nodes[0].hardware_json);
		let gpus = hw?.gpus ?? [];
		let est = estimate_vram_from_ingredients_or_path(profile, mp, target_node);
		let subset = pick_gpu_subset(gpus, est);
		if (subset != null) {
			resolved_gpus = subset.indices;
			if (subset.indices.length > 1) { resolved_split = subset.tensor_split; }
		}
	}
	if (resolved_gpus == null) {
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["bench: no GPU subset on " + target_node + " fits this profile",
			 bench_id]);
		return null;
	}

	// Capture build_hash NOW so the bench result is pinned to the
	// exact build that ran it (operator might activate a different
	// build mid-way — we want the recorded one).
	let build_hash = fetch_node_build_hash(target_node);
	db_exec(DB,
		"update bench_runs set status='spawning', build_hash=? where id=?",
		[build_hash, bench_id]);

	let port = pick_port(agent_url, profile.default_port);
	let agent_payload = {
		profile_name: profile_name,
		profile:      profile,
		model:        mp,
		port:         port,
		gpus:         resolved_gpus,
		tensor_split: resolved_split,
	};

	let spawn_resp = null;
	try {
		spawn_resp = cp_post_json(agent_url + "/services", agent_payload);
	} catch (e) {
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["spawn failed: " + e, bench_id]);
		return null;
	}
	if (spawn_resp.status_code < 200 || spawn_resp.status_code >= 300) {
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["spawn HTTP " + spawn_resp.status_code + ": " + spawn_resp.body, bench_id]);
		return null;
	}
	let svc = parse(spawn_resp.body);
	let svc_id = svc.id;
	let host = extract_host(agent_url);

	if (!wait_for_service_ready(host, port, "/health")) {
		try { cp_post_json(agent_url + "/services/stop", { id: svc_id }); } catch (e) { }
		db_exec(DB, "update bench_runs set status='error', error=? where id=?",
			["service didn't become ready in " + AUTOSPAWN_READY_TIMEOUT_SECONDS + "s", bench_id]);
		return null;
	}

	db_exec(DB, "update bench_runs set status='running' where id=?", [bench_id]);

	// Fire repetitions sequentially. Concurrent fire would inflate
	// per-request latency through queueing on the single-slot
	// llama-server we spawned (parallel_slots: 1 in the chat profile);
	// sequential gives us realistic per-request numbers.
	let llama_url = "http://" + host + ":" + port + "/completion";
	let body_json = stringify({
		prompt:    prompt,
		n_predict: n_predict,
		stream:    false,
	});
	let headers = ["Content-Type: application/json"];
	let ttft_samples = [];
	let total_samples = [];
	let tokens_samples = [];
	let toksec_samples = [];
	let first_output = null;
	let r = 0;
	while (r < repetitions) {
		let t0 = unix_ms();
		let resp = null;
		try {
			resp = http_request_timeout("POST", llama_url, body_json, headers, BENCH_REQUEST_TIMEOUT_MS);
		} catch (e) {
			eprint("[bench " + bench_id + "] rep " + r + " failed: " + e);
			r = r + 1;
			continue;
		}
		let t_total = unix_ms() - t0;
		if (resp.status_code < 200 || resp.status_code >= 300) {
			eprint("[bench " + bench_id + "] rep " + r + " HTTP " + resp.status_code);
			r = r + 1;
			continue;
		}
		let body = parse(resp.body);
		// llama-server's /completion response includes a `timings`
		// block with per-token detail. Use it when available; falls
		// back to wall-clock if not.
		let timings = body?.timings;
		let predicted_n = body?.tokens_predicted ?? 0;
		let predicted_ms = (timings?.predicted_ms ?? f64(t_total));
		let prompt_ms = timings?.prompt_ms ?? 0.0;
		// TTFT ≈ time spent processing the prompt before the first
		// output token. With stream:false we don't see real TTFT
		// (the whole response arrives at once) — use prompt_ms as a
		// proxy.
		ttft_samples.push(i32(prompt_ms));
		total_samples.push(t_total);
		tokens_samples.push(predicted_n);
		if (predicted_ms > 0.0 && predicted_n > 0) {
			toksec_samples.push(f64(predicted_n) * 1000.0 / predicted_ms);
		}
		if (first_output == null) {
			let content = body?.content ?? "";
			if (content.length > 500) { content = content.substr(0, 500); }
			first_output = content;
		}
		r = r + 1;
	}

	// Stop the service before recording — we want the row to be
	// final state, not a "complete but service is still draining"
	// confusion.
	try { cp_post_json(agent_url + "/services/stop", { id: svc_id }); } catch (e) { }

	let ttft_med    = median(ttft_samples);
	let total_med   = median(total_samples);
	let tokens_med  = median(tokens_samples);
	let toksec_med  = 0.0;
	if (toksec_samples.length > 0) {
		toksec_med = median(toksec_samples);
	}
	let now = iso_now();
	db_exec(DB,
		"update bench_runs "
		+ "set status='complete', ttft_ms_median=?, tok_per_sec_median=?, "
		+ "total_ms_median=?, tokens_predicted_median=?, output_excerpt=?, "
		+ "completed_at=? "
		+ "where id=?",
		[ttft_med, toksec_med, total_med, i32(tokens_med),
		 (first_output ?? ""), now, bench_id]);
	print("[bench] " + bench_id + " complete: median "
		+ i32(toksec_med) + " tok/s on " + target_node);
	return null;
}

// Compute an estimated VRAM number for this (profile, model) on this
// node. Tries the catalog row's pre-extracted ingredients first; if
// the alias isn't in this node's catalog (e.g. operator passed a
// raw default_model path), falls back to a conservative 1.5x file
// size estimate so we at least pick *some* GPU.
fn estimate_vram_from_ingredients_or_path(profile, model_path, target_node: string): f64 {
	let alias = profile?.model_alias;
	if (alias != null) {
		let rows = query(DB,
			"select size_mb, architecture, n_layers, n_heads, n_kv_heads, embedding_length "
			+ "from node_models where node_id = ? and alias = ?",
			[target_node, alias]);
		if (rows.length > 0) {
			let est = estimate_vram_from_ingredients(rows[0],
				i32(profile.context), profile.kv_type);
			return est.total_mb;
		}
	}
	return 1.5 * 8000.0;  // ~12 GB best-effort fallback
}

fn handle_create_bench(req): object {
	let payload = null;
	try { payload = parse(req.body); } catch (e) {
		return { status: 400, body: "{\"error\":\"bad json\"}" };
	}
	let target_node  = payload?.target_node;
	let profile_name = payload?.profile_name;
	let prompt       = payload?.prompt;
	let n_predict    = payload?.n_predict ?? 100;
	let repetitions  = payload?.repetitions ?? 3;
	if (target_node == null || profile_name == null || prompt == null) {
		return { status: 400, body: stringify({
			error: "target_node, profile_name, prompt required",
		})};
	}
	let r = query(DB, "select hex(randomblob(8)) as id", []);
	let id = r[0].id;
	let now = iso_now();
	exec(DB,
		"insert into bench_runs "
		+ "(id, node_id, profile_name, prompt, n_predict, repetitions, status, started_at) "
		+ "values (?, ?, ?, ?, ?, ?, 'queued', ?)",
		[id, target_node, profile_name, prompt, n_predict, repetitions, now]);
	let t = spawn(bench_task, id, target_node, profile_name, prompt, n_predict, repetitions);
	detach(t);
	return { status: 202, body: stringify({
		bench_id: id, target_node: target_node, profile_name: profile_name,
	})};
}

fn bench_row_to_obj(row): object {
	return {
		id:                       row.id,
		node_id:                  row.node_id,
		profile_name:             row.profile_name,
		build_hash:               row?.build_hash,
		prompt:                   row.prompt,
		n_predict:                row.n_predict,
		repetitions:              row.repetitions,
		ttft_ms_median:           row?.ttft_ms_median,
		tok_per_sec_median:       row?.tok_per_sec_median,
		total_ms_median:          row?.total_ms_median,
		tokens_predicted_median:  row?.tokens_predicted_median,
		output_excerpt:           row?.output_excerpt,
		status:                   row.status,
		error:                    row?.error,
		started_at:               row.started_at,
		completed_at:             row?.completed_at,
	};
}

fn handle_list_bench(req): object {
	let rows = query(DB,
		"select id, node_id, profile_name, build_hash, prompt, n_predict, "
		+ "repetitions, ttft_ms_median, tok_per_sec_median, total_ms_median, "
		+ "tokens_predicted_median, output_excerpt, status, error, "
		+ "started_at, completed_at "
		+ "from bench_runs order by started_at desc limit 100", []);
	let out = [];
	for (row in rows) { out.push(bench_row_to_obj(row)); }
	return { status: 200, body: stringify(out) };
}

fn handle_get_bench(req): object {
	let prefix = "/api/bench/";
	let id = req.path.substr(prefix.length, req.path.length - prefix.length);
	if (id.length == 0) {
		return { status: 400, body: "{\"error\":\"bench id required\"}" };
	}
	let rows = query(DB,
		"select id, node_id, profile_name, build_hash, prompt, n_predict, "
		+ "repetitions, ttft_ms_median, tok_per_sec_median, total_ms_median, "
		+ "tokens_predicted_median, output_excerpt, status, error, "
		+ "started_at, completed_at "
		+ "from bench_runs where id = ?", [id]);
	if (rows.length == 0) {
		return { status: 404, body: stringify({ error: "no such bench: " + id }) };
	}
	return { status: 200, body: stringify(bench_row_to_obj(rows[0])) };
}

// ── profile CRUD ─────────────────────────────────────────────────
//
// Profiles live in CP's sqlite (since v0.7). Spawn flow inlines the
// full profile JSON into the agent_payload — agents don't need to
// know what profiles exist, they just run what CP tells them.

// Returns the parsed profile object for `name`, or null if absent.
// Used by spawn/auto_spawn to inline profile data into agent calls.
fn fetch_profile_by_name(name: string) {
	let r = query(DB,
		"select profile_json, version from profiles where name = ?",
		[name]);
	if (r.length == 0) { return null; }
	let p = parse(r[0].profile_json);
	p["__name"] = name;
	p["__version"] = r[0].version;
	return p;
}

// Map of name → profile object (with __name + __version stamped),
// for callers that want the full set (dashboard, spawn form).
fn all_profiles_map(): object {
	let rows = query(DB,
		"select name, profile_json, version from profiles order by name asc",
		[]);
	let out = {};
	for (row in rows) {
		let p = parse(row.profile_json);
		p["__name"] = row.name;
		p["__version"] = row.version;
		out[row.name] = p;
	}
	return out;
}

fn handle_list_profiles_v2(req): object {
	return { status: 200, body: stringify(all_profiles_map()) };
}

fn handle_get_profile(req): object {
	// req.path = "/api/profiles/{name}" — strip prefix to get name.
	let prefix = "/api/profiles/";
	let name = req.path.substr(prefix.length, req.path.length - prefix.length);
	if (name.length == 0) {
		return { status: 400, body: "{\"error\":\"profile name required\"}" };
	}
	let p = fetch_profile_by_name(name);
	if (p == null) {
		return { status: 404, body: stringify({ error: "no such profile: " + name }) };
	}
	return { status: 200, body: stringify(p) };
}

// POST /api/profiles  body: { name, profile: {...} }
// Refuses if name is taken; use PUT to update.
fn handle_create_profile(req): object {
	let payload = null;
	try { payload = parse(req.body); } catch (e) {
		return { status: 400, body: "{\"error\":\"bad json\"}" };
	}
	let name = payload?.name;
	let profile = payload?.profile;
	if (name == null || profile == null) {
		return { status: 400, body: "{\"error\":\"name + profile required\"}" };
	}
	let existing = query(DB, "select name from profiles where name = ?", [name]);
	if (existing.length > 0) {
		return { status: 409, body: stringify({
			error: "profile '" + name + "' already exists; PUT to update",
		})};
	}
	let now = iso_now();
	exec(DB,
		"insert into profiles (name, profile_json, version, created_at, updated_at) "
		+ "values (?, ?, 1, ?, ?)",
		[name, stringify(profile), now, now]);
	return { status: 201, body: stringify({ name: name, version: 1 }) };
}

// PUT /api/profiles/{name}  body: profile object (the full thing)
// Bumps version. Existing services keep their old profile (no auto-restart);
// next spawn picks up the new version.
fn handle_update_profile(req): object {
	let prefix = "/api/profiles/";
	let name = req.path.substr(prefix.length, req.path.length - prefix.length);
	if (name.length == 0) {
		return { status: 400, body: "{\"error\":\"profile name required\"}" };
	}
	let profile = null;
	try { profile = parse(req.body); } catch (e) {
		return { status: 400, body: "{\"error\":\"bad json\"}" };
	}
	if (profile == null) {
		return { status: 400, body: "{\"error\":\"profile body required\"}" };
	}
	let existing = query(DB,
		"select version from profiles where name = ?", [name]);
	if (existing.length == 0) {
		return { status: 404, body: stringify({ error: "no such profile: " + name }) };
	}
	let new_version = existing[0].version + 1;
	let now = iso_now();
	exec(DB,
		"update profiles set profile_json = ?, version = ?, updated_at = ? "
		+ "where name = ?",
		[stringify(profile), new_version, now, name]);
	return { status: 200, body: stringify({ name: name, version: new_version }) };
}

// DELETE /api/profiles/{name}
// Refuses if any agent has an alive service running this profile —
// avoids leaving running services with no metadata. Operator stops
// the services first.
fn handle_delete_profile(req): object {
	let prefix = "/api/profiles/";
	let name = req.path.substr(prefix.length, req.path.length - prefix.length);
	if (name.length == 0) {
		return { status: 400, body: "{\"error\":\"profile name required\"}" };
	}
	let existing = query(DB, "select name from profiles where name = ?", [name]);
	if (existing.length == 0) {
		return { status: 404, body: stringify({ error: "no such profile: " + name }) };
	}
	// Check fleet for live services using this profile.
	let agents = list_all_agents();
	let in_use = [];
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				let services = parse(resp.body);
				for (s in services) {
					if (s?.profile == name && s?.alive == true) {
						in_use.push(a.node_id);
					}
				}
			}
		} catch (e) { }
	}
	if (in_use.length > 0) {
		return { status: 409, body: stringify({
			error: "profile '" + name + "' has live services on: "
				+ in_use.join(", ") + ". Stop them first.",
		})};
	}
	exec(DB, "delete from profiles where name = ?", [name]);
	return { status: 204, body: "" };
}

// Fetch the last N samples for one (node, metric, series) ordered
// oldest → newest, for sparkline rendering. Returns an array of i32
// values. Empty array when there's no history yet (just-registered
// node, or before the next heartbeat lands).
fn fetch_samples(node_id: string, metric: string, series, limit: i32): array {
	let rows = null;
	if (series == null) {
		rows = query(DB,
			"select value from node_samples "
			+ "where node_id = ? and metric = ? and series is null "
			+ "order by sampled_at desc limit ?",
			[node_id, metric, limit]);
	} else {
		rows = query(DB,
			"select value from node_samples "
			+ "where node_id = ? and metric = ? and series = ? "
			+ "order by sampled_at desc limit ?",
			[node_id, metric, series, limit]);
	}
	// Reverse to oldest-first for the sparkline path.
	let out = [];
	let i = rows.length - 1;
	while (i >= 0) { out.push(rows[i].value); i = i - 1; }
	return out;
}

// Build the samples-per-node map the dashboard needs to render
// sparklines inline with the nodes table. Shape:
//   { node_id → {
//       gpu: { idx_str → [values...] },
//       ram: [values...],
//       disk: { path → [values...] },
//   }}
// SAMPLE_HISTORY_POINTS is the visual history length. 60 points at
// 30s heartbeat = 30 minutes of context — enough to see a load
// pattern emerge without overwhelming a 200px-wide sparkline.
let SAMPLE_HISTORY_POINTS = 60;

fn samples_for_dashboard(nodes_data): object {
	let out = {};
	for (n in nodes_data) {
		let bundle = { gpu: {}, gpu_power: {}, ram: [], disk: {} };
		let gpus = n.hardware?.gpus ?? [];
		for (g in gpus) {
			bundle.gpu["" + g.index] = fetch_samples(n.node_id,
				"gpu_free_mb", "" + g.index, SAMPLE_HISTORY_POINTS);
			bundle.gpu_power["" + g.index] = fetch_samples(n.node_id,
				"gpu_power_w", "" + g.index, SAMPLE_HISTORY_POINTS);
		}
		bundle.ram = fetch_samples(n.node_id, "ram_free_mb", null,
			SAMPLE_HISTORY_POINTS);
		let disks = n.hardware?.disks ?? [];
		for (d in disks) {
			bundle.disk[d.path] = fetch_samples(n.node_id,
				"disk_free_mb", d.path, SAMPLE_HISTORY_POINTS);
		}
		out[n.node_id] = bundle;
	}
	return out;
}

// ── stats strip ──────────────────────────────────────────────────
// Top-of-page summary tiles. Pure aggregation over the existing
// /nodes + /catalog data, plus a fan-out to agents for service count.
fn compute_stats(): object {
	let agents = list_all_agents();
	let total_gpus = 0;
	let total_vram_free_mb: i64 = 0;
	let total_vram_mb: i64 = 0;
	let nodes = nodes_for_dashboard();
	for (n in nodes) {
		let gpus = n.hardware?.gpus ?? [];
		total_gpus = total_gpus + gpus.length;
		for (g in gpus) {
			total_vram_free_mb = total_vram_free_mb + g.free_mb;
			total_vram_mb = total_vram_mb + g.total_mb;
		}
	}
	let catalog = catalog_grouped();
	let total_catalog_mb: i64 = 0;
	for (e in catalog) { total_catalog_mb = total_catalog_mb + e.size_mb; }

	let running = 0;
	for (a in agents) {
		try {
			let resp = cp_get_fast(a.agent_url + "/services");
			if (resp.status_code >= 200 && resp.status_code < 300) {
				let entries = parse(resp.body);
				for (e in entries) { if (e?.alive == true) { running = running + 1; } }
			}
		} catch (e) { }
	}

	return {
		nodes:            nodes.length,
		nodes_live:       agents.length,
		total_gpus:       total_gpus,
		vram_free_mb:     total_vram_free_mb,
		vram_total_mb:    total_vram_mb,
		catalog_models:   catalog.length,
		catalog_total_mb: total_catalog_mb,
		services_running: running,
	};
}

fn handle_ui_stats(req): object {
	return { status: 200, body: render_stats(compute_stats()),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

// (handle_list_profiles removed — replaced by handle_list_profiles_v2
// which reads from CP's own profiles table since v0.7. Spawn form
// fetches /api/profiles, which routes to v2 directly.)

// Static assets — HTML shell + CSS + JS + logo, all baked into the
// binary at build time via scripts/embed_assets.sh. Served with a
// modest cache lifetime (the only way to change them is to rebuild
// and redeploy, but we still want operators iterating on the dashboard
// to see fresh bytes within seconds, not a day).
let ASSET_CACHE = "public, max-age=60";

fn html_response(body: string): object {
	return { status: 200, body: body,
		headers: { "content-type": "text/html; charset=utf-8",
			"cache-control": ASSET_CACHE } };
}

fn handle_page_overview(req): object  { return html_response(OVERVIEW_HTML); }
fn handle_page_catalog(req): object   { return html_response(PAGE_CATALOG); }
fn handle_page_transfers(req): object { return html_response(PAGE_TRANSFERS); }
fn handle_page_profiles(req): object  { return html_response(PAGE_PROFILES); }
fn handle_page_bench(req): object     { return html_response(PAGE_BENCH); }
fn handle_page_deploy(req): object    { return html_response(PAGE_DEPLOY); }
fn handle_page_settings(req): object  { return html_response(PAGE_SETTINGS); }

// /ui/bench fragment — newest 100 bench rows.
fn handle_ui_bench(req): object {
	let rows = query(DB,
		"select id, node_id, profile_name, build_hash, prompt, n_predict, "
		+ "repetitions, ttft_ms_median, tok_per_sec_median, total_ms_median, "
		+ "tokens_predicted_median, output_excerpt, status, error, "
		+ "started_at, completed_at "
		+ "from bench_runs order by started_at desc limit 100", []);
	return { status: 200, body: render_bench(rows),
		headers: { "content-type": "text/html; charset=utf-8" } };
}

fn handle_dashboard_css(req): object {
	return { status: 200, body: SHELL_CSS,
		headers: { "content-type": "text/css; charset=utf-8",
			"cache-control": ASSET_CACHE } };
}
fn handle_dashboard_js(req): object {
	return { status: 200, body: SHELL_JS,
		headers: { "content-type": "application/javascript; charset=utf-8",
			"cache-control": ASSET_CACHE } };
}
fn handle_logo(req): object {
	return { status: 200, body: LOGO,
		headers: { "content-type": "image/svg+xml",
			"cache-control": ASSET_CACHE } };
}

// ── MCP server (cp/mcp.hml) ──────────────────────────────────────────
//
// Each tool wraps an existing CP handler by synthesizing the request it
// expects and passing its { status, body } straight back to the MCP layer.
// No new business logic lives here — the MCP surface is a thin adapter
// over the same HTTP API the dashboard uses, so it inherits its behavior
// (and tests) for free.

// Synthesize the in-process request each wrapped handler expects.
fn mcp_req(verb: string, target: string, body: string): object {
	return { method: verb, path: target, body: body, headers: {} };
}

// Tool dispatch. mcp.hml validates the tool name against mcp_tools() then
// calls this with (name, arguments). One function (passed to mcp_handle as
// an argument, like serve()'s auth_check) keeps function values off the
// object-literal path hemlockc can't lower, and `stringify` runs here in a
// plain module function rather than a captured closure. Each arm wraps an
// existing CP handler — no new business logic.
fn mcp_invoke(name: string, args): object {
	if (name == "list_nodes") {
		return handle_list_nodes(mcp_req("GET", "/nodes", ""));
	}
	if (name == "list_services") {
		return handle_list_services(mcp_req("GET", "/services", ""));
	}
	if (name == "list_profiles") {
		return handle_list_profiles_v2(mcp_req("GET", "/api/profiles", ""));
	}
	if (name == "list_catalog") {
		return handle_list_catalog(mcp_req("GET", "/api/catalog", ""));
	}
	if (name == "fleet_status") {
		return handle_state(mcp_req("GET", "/api/state", ""));
	}
	if (name == "resolve_profile") {
		let profile = args?.profile ?? "";
		return handle_resolve(mcp_req("GET", "/resolve/" + profile, ""));
	}
	if (name == "spawn_service") {
		return handle_spawn_proxy(mcp_req("POST", "/services", stringify(args)));
	}
	if (name == "stop_service") {
		return handle_stop_proxy(mcp_req("POST", "/services/stop", stringify(args)));
	}
	return { status: 404, body: stringify({ error: "unknown tool: " + name }) };
}

// The tool catalog — pure data (name + description + JSON Schema). Read-only
// introspection + the two mutating fleet actions (spawn/stop). Kept
// deliberately small: this is the operator's control surface, not the
// consumer inference path (that stays on /v1/llama/* with its own flow).
fn mcp_tools(): array {
	return [
		{
			name: "list_nodes",
			description: "List every registered node in the fleet with its "
				+ "hardware (GPUs, VRAM, RAM), liveness, and state.",
			schema: { "type": "object", properties: {}, additionalProperties: false },
		},
		{
			name: "list_services",
			description: "List running inference services across the fleet, "
				+ "each tagged with the node it runs on, its profile, port, and pid.",
			schema: { "type": "object", properties: {}, additionalProperties: false },
		},
		{
			name: "list_profiles",
			description: "List the configured service profiles (chat, image, "
				+ "embedding, etc.) the fleet can spawn, with their intent + model.",
			schema: { "type": "object", properties: {}, additionalProperties: false },
		},
		{
			name: "list_catalog",
			description: "List the GGUF model catalog aggregated across all nodes, "
				+ "by alias, with which nodes hold each model on disk.",
			schema: { "type": "object", properties: {}, additionalProperties: false },
		},
		{
			name: "fleet_status",
			description: "Get a single snapshot of overall fleet state (nodes + "
				+ "services + recent events) as the dashboard sees it.",
			schema: { "type": "object", properties: {}, additionalProperties: false },
		},
		{
			name: "resolve_profile",
			description: "Resolve a profile (or alias) to a live inference "
				+ "endpoint (host, port, base_url). Returns 404 if nothing is "
				+ "running for it. Use this to find where to send inference.",
			schema: {
				"type": "object",
				properties: {
					profile: { "type": "string",
						description: "Profile name or alias, e.g. 'chat-mahou'." },
				},
				required: ["profile"],
				additionalProperties: false,
			},
		},
		{
			name: "spawn_service",
			description: "Spawn a service for a profile. Omit node_id/gpus to let "
				+ "the control plane do capacity-aware placement; pin them (and "
				+ "supply model) to place manually. Returns the spawned service.",
			schema: {
				"type": "object",
				properties: {
					profile: { "type": "string",
						description: "Profile name to spawn (required)." },
					node_id: { "type": "string",
						description: "Pin to a specific node. Optional; placement picks one if omitted." },
					gpus:    { "type": "array", items: { "type": "integer" },
						description: "GPU indices to use when pinning a node. Optional." },
					model:   { "type": "string",
						description: "Explicit GGUF path override. Required only when node_id+gpus are pinned." },
					port:    { "type": "integer",
						description: "Port override. Optional; one is picked if omitted." },
					device:  { "type": "string", "enum": ["auto", "cpu", "gpu"],
						description: "Force CPU/GPU placement. Optional, defaults to the profile's setting." },
				},
				required: ["profile"],
				additionalProperties: false,
			},
		},
		{
			name: "stop_service",
			description: "Stop a running service by its id and node_id "
				+ "(both from list_services).",
			schema: {
				"type": "object",
				properties: {
					id:      { "type": "string", description: "Service id (required)." },
					node_id: { "type": "string", description: "Owning node id (required)." },
				},
				required: ["id", "node_id"],
				additionalProperties: false,
			},
		},
	];
}

fn handle_mcp(req): object {
	let server_info = { name: "witchgrid-cp", version: WITCHGRID_VERSION };
	return mcp_handle(req, mcp_tools(), mcp_invoke, server_info);
}

// GET /mcp — we don't offer a server-initiated SSE stream (every reply is
// a buffered POST response), so advertise that with 405 per the Streamable
// HTTP spec instead of leaving the client hanging on an open GET.
fn handle_mcp_get(req): object {
	return { status: 405,
		headers: { "content-type": "application/json", "allow": "POST" },
		body: "{\"error\":\"GET not supported; POST JSON-RPC to /mcp\"}" };
}

// ── boot ─────────────────────────────────────────────────────────────

fn main(): null {
	DB_PATH = resolve_data_path(DB_PATH);
	if (!exists(DB_PATH)) {
		print("[cp] creating NEW database at " + DB_PATH
			+ " — if unexpected, check CWD or set WITCHGRID_DATA_DIR "
			+ "(a stray fresh DB drops every node/profile/service from view)");
	}
	DB = open_db(DB_PATH);
	// Concurrency + durability pragmas, set before any table work:
	//   busy_timeout — a momentarily-locked DB waits up to 5s and retries
	//     instead of throwing "database is locked". The detached
	//     db_backup_loop runs `vacuum into` while the HTTP loop writes
	//     nodes/services/samples; without this they collide.
	//   journal_mode=WAL — readers don't block the writer and vice versa,
	//     and it's the crash-safe journal the systemd unit already assumes
	//     ("give sqlite time to release the WAL lock") but nothing enabled.
	//   synchronous=NORMAL — the standard, safe WAL pairing.
	exec(DB, "PRAGMA busy_timeout=5000", []);
	exec(DB, "PRAGMA journal_mode=WAL", []);
	exec(DB, "PRAGMA synchronous=NORMAL", []);
	init_db(DB);
	print("[cp] sqlite ready: " + DB_PATH);
	print("[cp] witchgrid control plane " + WITCHGRID_VERSION);
	init_auth();

	// Detached background task: sqlite auto-backup loop. No-op when
	// db_backup_interval_min=0 (the default); flips on as soon as the
	// operator sets a positive interval via PUT /api/settings.
	let bk = spawn(db_backup_loop);
	detach(bk);

	// Route auth tiers (see cp_auth_check):
	//   public: true        — always open: /healthz + the static dashboard
	//                         shell/assets (baked into the binary, no
	//                         fleet data).
	//   scope: "read"       — dashboard fragments + read-only JSON: open
	//                         by default, bearer-gated when
	//                         WITCHGRID_AUTH_PROTECT_READ is set (no
	//                         operator cookie yet — slice 2).
	//   scope: "inference"  — /v1/llama/*: open by default, bearer-gated
	//                         when WITCHGRID_AUTH_PROTECT_INFERENCE is
	//                         set (per-consumer tokens are slice 3).
	//   (no flag)           — mutating control surface, always gated.
	let routes = [
		{ method: "POST", path: "/register",      handler: handle_register },
		{ method: "GET",  path: "/nodes",         handler: handle_list_nodes,         scope: "read" },
		{ method: "PATCH", path: "/api/nodes/",   prefix: true, handler: handle_patch_node },
		// Node-scoped llama_cpp proxies (since v0.7 C2). Method = *
		// so GET (list installed) + POST (install/activate) hit the
		// same handler which dispatches by action segment.
		{ method: "*",     path: "/api/nodes/",   prefix: true, handler: fn(req): object {
			// Sub-resource dispatch under /api/nodes/{id}/...:
			//   /llama_cpp/{action}  → install-layer proxy
			//   /auto-restart        → watchdog toggle proxy (PUT)
			if (req.path.find("/llama_cpp/") >= 0) {
				return handle_node_llama_cpp(req);
			}
			if (req.path.find("/auto-restart") >= 0) {
				return handle_node_auto_restart(req);
			}
			return { status: 404, body: "{\"error\":\"not found\"}" };
		} },
		{ method: "GET",  path: "/healthz",       handler: handle_health,             public: true },
		{ method: "GET",  path: "/metrics",       handler: handle_metrics,            scope: "read" },
		// MCP server (Model Context Protocol over Streamable HTTP). Lets an
		// AI assistant introspect + drive the fleet as MCP tools. NOT public:
		// it spawns/stops services, so it sits behind the shared bearer like
		// the rest of the operator API. Clients pass Authorization: Bearer
		// <WITCHGRID_SHARED_SECRET>.
		{ method: "POST", path: "/mcp",           handler: handle_mcp },
		{ method: "GET",  path: "/mcp",           handler: handle_mcp_get },
		{ method: "POST", path: "/services",      handler: handle_spawn_proxy },
		{ method: "GET",  path: "/services",      handler: handle_list_services },
		{ method: "POST", path: "/services/stop", handler: handle_stop_proxy },
		{ method: "POST", path: "/unmanaged/kill", handler: handle_kill_unmanaged_proxy },
		{ method: "GET",  path: "/services/log/", prefix: true, handler: handle_service_log, scope: "read" },
		// Control-plane location lookup — consumers resolve a profile/
		// alias to a live llama-server host:port and connect directly
		// (CP stays off the inference data path). public: a location,
		// not a secret, and workers hit it before any bearer exists.
		{ method: "GET",  path: "/resolve/",      prefix: true, handler: handle_resolve, scope: "read" },
		// Dashboard shell + static assets (all baked into the binary)
		{ method: "GET",  path: "/",                       handler: handle_page_overview,    public: true },
		{ method: "GET",  path: "/catalog",                handler: handle_page_catalog,     public: true },
		{ method: "GET",  path: "/transfers",              handler: handle_page_transfers,   public: true },
		{ method: "GET",  path: "/profiles",               handler: handle_page_profiles,    public: true },
		{ method: "GET",  path: "/bench",                  handler: handle_page_bench,       public: true },
		{ method: "GET",  path: "/utilities",              handler: handle_page_bench,       public: true },
		{ method: "GET",  path: "/deploy",                 handler: handle_page_deploy,      public: true },
		{ method: "GET",  path: "/settings",               handler: handle_page_settings,    public: true },
		{ method: "GET",  path: "/assets/styles.css",      handler: handle_dashboard_css,    public: true },
		{ method: "GET",  path: "/assets/dashboard.js",    handler: handle_dashboard_js,     public: true },
		{ method: "GET",  path: "/assets/logo.svg",        handler: handle_logo,             public: true },
		// Dashboard live fragments + JSON profiles (the form needs structured data)
		{ method: "GET",  path: "/ui/nodes",        handler: handle_ui_nodes,         scope: "read" },
		{ method: "GET",  path: "/ui/services",     handler: handle_ui_services,      scope: "read" },
		{ method: "GET",  path: "/ui/profiles",     handler: handle_ui_profiles,      scope: "read" },
		{ method: "GET",  path: "/ui/capabilities", handler: handle_ui_capabilities,  scope: "read" },
		// Live state stream (SSE) — pushes fleet snapshots on change so the
		// dashboard updates without polling. Public, like the /ui fragments.
		{ method: "GET",  path: "/events",          handler: handle_events,           scope: "read" },
		{ method: "GET",  path: "/api/state",        handler: handle_state,            scope: "read" },
		{ method: "GET",  path: "/api/ready/",       prefix: true, handler: handle_service_ready, scope: "read" },
		{ method: "GET",  path: "/api/capabilities", handler: handle_list_capabilities, scope: "read" },
		// JSON API — moved under /api/ prefix in v0.6 because the
		// human-facing pages now own /catalog, /transfers, /profiles
		// at the URL roots. Spawn form's onProfileChange() fetch
		// updated to match.
		// Profiles CRUD lives under /api/profiles[/{name}] since v0.7
		// (CP-owned storage, was baked into agent binaries before).
		{ method: "GET",  path: "/api/profiles",    handler: handle_list_profiles_v2, scope: "read" },
		{ method: "POST", path: "/api/profiles",    handler: handle_create_profile },
		{ method: "GET",  path: "/api/settings",    handler: handle_list_settings,    scope: "read" },
		{ method: "GET",  path: "/api/config",      handler: handle_get_config,       scope: "read" },
		{ method: "PUT",  path: "/api/settings",    handler: handle_update_settings },
		{ method: "GET",  path: "/api/profile-aliases",  handler: handle_list_profile_aliases,   scope: "read" },
		{ method: "PUT",  path: "/api/profile-aliases",  handler: handle_upsert_profile_alias },
		{ method: "DELETE", path: "/api/profile-aliases/", prefix: true, handler: handle_delete_profile_alias },
		{ method: "GET",  path: "/api/profiles/",   prefix: true, handler: handle_get_profile,    scope: "read" },
		{ method: "PUT",  path: "/api/profiles/",   prefix: true, handler: handle_update_profile },
		{ method: "DELETE", path: "/api/profiles/", prefix: true, handler: handle_delete_profile },
		{ method: "GET",  path: "/api/catalog",     handler: handle_list_catalog,     scope: "read" },
		{ method: "GET",  path: "/ui/catalog",      handler: handle_ui_catalog,       scope: "read" },
		{ method: "POST", path: "/models/distribute", handler: handle_distribute },
		{ method: "POST", path: "/models/delete",   handler: handle_model_delete_proxy },
		{ method: "POST", path: "/api/scan-dirs",   handler: handle_scan_dirs_proxy },
		// HF search + pull (slice C4) — operator types a name in the
		// catalog page, picks a quant, kicks off a transfer to a node.
		{ method: "POST", path: "/api/hf/search",   handler: handle_hf_search },
		{ method: "POST", path: "/api/hf/files",    handler: handle_hf_files },
		{ method: "POST", path: "/api/hf/card",     handler: handle_hf_card },
		{ method: "POST", path: "/api/hf/discover", handler: handle_hf_discover },
		{ method: "POST", path: "/models/pull_hf",  handler: handle_pull_hf },
		{ method: "POST", path: "/api/placement_preview", handler: handle_placement_preview, scope: "read" },
		{ method: "GET",  path: "/api/transfers",   handler: handle_list_transfers,   scope: "read" },
		// Bench (v0.7+ slice C3): operator-triggered benchmarks of
		// (node × profile × build) combos. POST kicks off async,
		// GETs read history.
		{ method: "POST", path: "/api/bench",       handler: handle_create_bench },
		{ method: "GET",  path: "/api/bench",       handler: handle_list_bench,       scope: "read" },
		{ method: "GET",  path: "/api/bench/",      prefix: true, handler: handle_get_bench,      scope: "read" },
		{ method: "GET",  path: "/ui/bench",        handler: handle_ui_bench,         scope: "read" },
		{ method: "GET",  path: "/ui/transfers",    handler: handle_ui_transfers,     scope: "read" },
		{ method: "GET",  path: "/ui/missing",      handler: handle_ui_missing,       scope: "read" },
		{ method: "GET",  path: "/ui/stats",        handler: handle_ui_stats,         scope: "read" },
		// Inference routing — prefix-matches anything under /v1/llama/.
		// method "*" means any HTTP method is forwarded. Open by default;
		// WITCHGRID_AUTH_PROTECT_INFERENCE gates it behind the shared
		// bearer (per-consumer API tokens are slice 3).
		{ method: "*",    path: "/v1/llama/",     handler: handle_llama_proxy,
		  prefix: true, scope: "inference" },
	];

	// Graceful shutdown: on a termination signal, checkpoint the WAL (TRUNCATE
	// empties the -wal file) and exit cleanly, so the next start is from a
	// compact, fully-merged DB. Requires the Hemlock signal fix (async runtime
	// now masks signals on worker threads + delivers to the main thread, and
	// runs 0-/1-arg handlers; ≥ the build with hemlang/hemlock#587). WAL is
	// crash-durable regardless, so an incomplete checkpoint only ever falls
	// back to today's recover-on-next-open behavior.
	on_shutdown(fn(sig) {
		print("[cp] signal " + sig + " — checkpointing WAL and exiting");
		try { exec(DB, "PRAGMA wal_checkpoint(TRUNCATE)", []); } catch (e) { }
		try { close_db(DB); } catch (e) { }
		exit(0);
	});

	serve(HOST, PORT, routes, cp_auth_check);
	close_db(DB);
	return null;
}

main();
