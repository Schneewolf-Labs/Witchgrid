// cp.hml — Witchgrid control plane.
//
// Owns the node registry. Service-supervisor work happens on agents
// (one per node, see ../agent/); CP routes spawn/list/stop requests to
// the agent that owns each service.
//
// Endpoints:
//   POST /register         { node_id, hostname, role, hardware,
//                            agent_url }                         → 200
//   GET  /nodes                                                  → [...]
//   GET  /healthz                                                → ok
//
//   POST /services         { node_id, profile, model, port?,
//                            gpus? }                             → 201
//                          (proxied to the named agent)
//   GET  /services                                               → [...]
//                          (aggregated from every registered agent;
//                           each entry tagged with node_id)
//   POST /services/stop    { id, node_id }                       → 204
//                          (proxied to the named agent)
//
//   * /v1/llama/{profile}/{...}                                  → proxy
//                          (routes to a running llama-server with the
//                           given profile; CP forwards the request
//                           directly to llama-server, agents stay off
//                           the inference data path)
//
// Run:    hemlock cp.hml
// Build:  hemlockc cp.hml -o witchgrid-cp && ./witchgrid-cp

import { open_db, exec, exec as db_exec, query, close_db } from "@stdlib/sqlite";
import { parse, stringify } from "@stdlib/json";
import { post_json, post, get, request as http_request, stream as http_stream, request_timeout as http_request_timeout, url_encode } from "@stdlib/http";
import { sleep, time_ms as unix_ms } from "@stdlib/time";
import { exists, make_dirs, list_dir, remove_file } from "@stdlib/fs";
import { getenv, setenv, unsetenv } from "@stdlib/env";
import { sha256 } from "@stdlib/hash";
import { serve } from "./http_server";
import { mcp_handle } from "./mcp";
import { WITCHGRID_VERSION } from "../version";
import { on_shutdown } from "@stdlib/signal";
import { exit, exec_argv } from "@stdlib/process";
import { read_metadata, estimate_vram_mb, estimate_vram_from_ingredients } from "./gguf";
import { render_nodes, render_services, render_profiles, render_capabilities, render_catalog, render_stats, render_transfers, render_missing, render_bench,
         OVERVIEW_HTML, PAGE_CATALOG, PAGE_TRANSFERS, PAGE_PROFILES, PAGE_BENCH, PAGE_DEPLOY, PAGE_SETTINGS,
         SHELL_CSS, SHELL_JS, LOGO } from "./dashboard";

let DB_PATH = "witchgrid.db";
// Bind address/port. Default 0.0.0.0:8765 (LAN-first). Override with
// WITCHGRID_CP_HOST / WITCHGRID_CP_PORT — e.g. bind 127.0.0.1 and front it
// with an authenticating reverse proxy for anything beyond a trusted LAN.
let _cp_host_env = getenv("WITCHGRID_CP_HOST");
let HOST = (_cp_host_env == null || _cp_host_env.length == 0) ? "0.0.0.0" : _cp_host_env;
let _cp_port_env = getenv("WITCHGRID_CP_PORT");
let PORT = (_cp_port_env == null || _cp_port_env.length == 0) ? 8765 : i32(_cp_port_env);

// Resolve where the sqlite DB lives. WITCHGRID_DATA_DIR pins it to an
// absolute, CWD-independent location (created if missing); unset keeps the
// historical CWD-relative filename. main() logs the resolved path and warns
// loudly before creating a fresh DB — the "started from the wrong directory
// → empty registry, didn't notice" foot-gun (test-cases-todo #15). The CP
// is especially exposed: a stray fresh DB means every node + profile +
// running service vanishes from its view.
fn resolve_data_path(name: string): string {
	let dir = getenv("WITCHGRID_DATA_DIR");
	if (dir == null || dir.length == 0) { return name; }
	let d = dir;
	while (d.length > 1 && d.substr(d.length - 1, 1) == "/") {
		d = d.substr(0, d.length - 1);
	}
	if (!exists(d)) {
		try { make_dirs(d); } catch (e) {
			eprint("[cp] could not create WITCHGRID_DATA_DIR " + d + ": " + e);
		}
	}
	return d + "/" + name;
}

// ── auth (slice 1: shared bearer for CP↔agent) ─────────────────────
//
// Single shared secret, env-injected. When set, every inbound request
// EXCEPT routes flagged `public: true` (and, unless the protect knobs
// below are on, routes flagged scope: "read" / scope: "inference")
// must carry
//   Authorization: Bearer <secret>
// or it gets a 401. Same secret is sent on every CP→agent call so the
// agent can validate us in turn.
//
// Unset (the default) = legacy mode: no checks, just a [auth] DISABLED
// warning at boot. This lets the operator roll out updated agents
// before flipping the switch on CP. Once every node is on a binary
// that knows the secret, set it on CP last.
//
// Comparison goes through sha256 to bound timing-leak surface to a
// fixed-length digest regardless of secret length. Not strict CT but
// the threat model is LAN/WireGuard, not a remote network attacker.
//
// Read fresh from env on every call rather than caching in a let:
// Hemlock spawn() snapshots module state at spawn time, so async
// tasks (per-accept worker, bench task) would see whatever the let
// was BEFORE init_auth ran. Re-reading dodges that.
fn shared_secret(): string {
	let s = getenv("WITCHGRID_SHARED_SECRET");
	if (s == null) { return ""; }
	return s;
}

// ── auth options ───────────────────────────────────────────────────
//
// Both no-ops unless WITCHGRID_SHARED_SECRET is also set (the secret
// stays optional — LAN-first default is unchanged):
//
//   WITCHGRID_AUTH_PROTECT_READ       gate the read-only surface too
//                                     (/nodes, /ui/*, /api/state, SSE,
//                                     /metrics, /resolve/*, logs, …).
//                                     The browser dashboard can't send
//                                     the bearer yet, so its live views
//                                     401 — front it with a header-
//                                     injecting reverse proxy.
//   WITCHGRID_AUTH_PROTECT_INFERENCE  gate /v1/llama/* (the inference
//                                     data plane) behind the same
//                                     bearer. Off = any LAN client can
//                                     run inference even with a secret
//                                     set (the historical behavior).
//
// Read fresh from env per request, same rationale as shared_secret().
fn env_truthy(name: string): bool {
	let v = getenv(name);
	if (v == null) { return false; }
	let s = v.trim().to_lower();
	return s == "1" || s == "true" || s == "yes" || s == "on";
}

fn auth_protect_read(): bool {
	return env_truthy("WITCHGRID_AUTH_PROTECT_READ");
}

fn auth_protect_inference(): bool {
	return env_truthy("WITCHGRID_AUTH_PROTECT_INFERENCE");
}

// curl auth config: cp_get_fast shells out to curl for the dashboard
// fan-outs, and `-H "Authorization: Bearer <secret>"` in argv leaks the
// secret to every local user via /proc/<pid>/cmdline (world-readable)
// on every fan-out. Instead the bearer lives in a 0600 curl config file
// (`-K <path>`) under the data dir. The content reaches the writing
// shell via the environment — also not argv-visible — so the secret
// never appears on any command line. Rewritten on every boot; removed
// when auth is off.
fn curl_auth_cfg_path(): string {
	return resolve_data_path("curl_auth.cfg");
}

fn write_curl_auth_cfg(): null {
	let path = curl_auth_cfg_path();
	let secret = shared_secret();
	if (secret == "") {
		try { if (exists(path)) { remove_file(path); } } catch (e) { }
		return null;
	}
	// curl config syntax: header = "value" — escape \ and " in the value.
	let esc = "";
	let i = 0;
	while (i < secret.length) {
		let c = secret.substr(i, 1);
		if (c == "\\" || c == "\"") { esc = esc + "\\"; }
		esc = esc + c;
		i = i + 1;
	}
	setenv("WITCHGRID_CURL_CFG_LINE",
		"header = \"Authorization: Bearer " + esc + "\"");
	setenv("WITCHGRID_CURL_CFG_PATH", path);
	try {
		// rm first so the file is recreated under umask 077 even if an
		// old copy exists with looser permissions.
		let r = exec_argv(["sh", "-c",
			"umask 077 && rm -f \"$WITCHGRID_CURL_CFG_PATH\""
			+ " && printf '%s\\n' \"$WITCHGRID_CURL_CFG_LINE\""
			+ " > \"$WITCHGRID_CURL_CFG_PATH\""]);
		if (r.exit_code != 0) {
			eprint("[auth] could not write curl auth config at " + path
				+ " (exit " + r.exit_code
				+ ") — fan-outs fall back to header-in-argv");
		}
	} catch (e) {
		eprint("[auth] could not write curl auth config at " + path
			+ ": " + e + " — fan-outs fall back to header-in-argv");
	}
	unsetenv("WITCHGRID_CURL_CFG_LINE");
	unsetenv("WITCHGRID_CURL_CFG_PATH");
	return null;
}

fn init_auth(): null {
	let s = shared_secret();
	if (s.length > 0) {
		print("[auth] enabled (shared bearer; "
			+ s.length + "-char secret)");
		print("[auth] read surface (/nodes, /ui/*, /api/state, …): "
			+ (auth_protect_read()
				? "bearer required (WITCHGRID_AUTH_PROTECT_READ)"
				: "public — set WITCHGRID_AUTH_PROTECT_READ=1 to gate"));
		print("[auth] inference plane (/v1/llama/*): "
			+ (auth_protect_inference()
				? "bearer required (WITCHGRID_AUTH_PROTECT_INFERENCE)"
				: "public — set WITCHGRID_AUTH_PROTECT_INFERENCE=1 to gate"));
	} else {
		print("[auth] DISABLED — set WITCHGRID_SHARED_SECRET on CP "
			+ "and every agent to enable");
		if (auth_protect_read() || auth_protect_inference()) {
			eprint("[auth] WARNING: WITCHGRID_AUTH_PROTECT_READ/"
				+ "_INFERENCE set without WITCHGRID_SHARED_SECRET "
				+ "— they have no effect until a secret is set");
		}
	}
	write_curl_auth_cfg();
	return null;
}

fn auth_match(provided: string): bool {
	let secret = shared_secret();
	if (secret == "") { return true; }
	if (provided == null || provided.length == 0) { return false; }
	let prefix = "Bearer ";
	if (provided.length < prefix.length) { return false; }
	if (provided.substr(0, prefix.length) != prefix) { return false; }
	let raw = provided.substr(prefix.length, provided.length - prefix.length);
	return sha256(raw) == sha256(secret);
}

// Dispatcher hook. Returns null when the request may proceed, or a
// 401 response object when not. Three route tiers (when SHARED_SECRET
// is set):
//
//   public: true        always open — health, static dashboard shell/
//                       assets (baked-in, no fleet data).
//   scope: "read"       data-bearing read-only surface — open by
//                       default, gated when WITCHGRID_AUTH_PROTECT_READ
//                       is set.
//   scope: "inference"  /v1/llama/* data plane — open by default, gated
//                       when WITCHGRID_AUTH_PROTECT_INFERENCE is set.
//   (no flag)           the mutating control surface — always needs
//                       the bearer.
//
// Two acceptable token locations:
//   1. `Authorization: Bearer <secret>` header — preferred path used
//      by curl, browser fetch(), the dashboard, future API consumers.
//   2. `_auth_token` field in the JSON body — workaround used by
//      CP↔agent (Hemlock's libwebsockets POST wrapper drops arbitrary
//      headers; only Content-Type makes it through). Body fallback
//      is the in-band equivalent. To remove once a Hemlock POST-with-
//      headers runtime fn lands.
fn cp_auth_check(req, route) {
	if (shared_secret() == "") { return null; }
	if (route?.public == true) { return null; }
	let scope = route?.scope;
	if (scope == "read" && !auth_protect_read()) { return null; }
	if (scope == "inference" && !auth_protect_inference()) { return null; }
	let header = req?.headers?["authorization"] ?? "";
	if (auth_match(header)) { return null; }
	// Body fallback for Hemlock-originated POSTs.
	if (req?.body != null && req.body.length > 0
		&& req.body.length < 1048576) {
		try {
			let payload = parse(req.body);
			let tok = payload?._auth_token;
			if (tok != null && auth_match("Bearer " + tok)) { return null; }
		} catch (e) { }
	}
	return { status: 401,
		body: "{\"error\":\"unauthorized\"}",
		headers: { "content-type": "application/json",
			"www-authenticate": "Bearer realm=\"witchgrid\"" } };
}

// Outbound auth — every CP→agent call goes through these wrappers
// so they pick up the bearer automatically when the secret is set.
// Same response shape as the underlying @stdlib/http calls.
//
// POSTs add `_auth_token` to the body (Hemlock workaround); GETs
// use the headers list (which Hemlock's libwebsockets wrapper does
// pass through for GET).
//
// Both go through the explicit-timeout variants with a 60s budget.
// Hemlock 2.4.0 dropped the default lws timeout to 5s — fine for
// short ad-hoc calls, but spawning a 12B model needs 5-30s for the
// agent's bind probe to return after CUDA init + safetensors load.
let CP_AGENT_TIMEOUT_MS = 60000;

fn cp_post_json(url: string, data) {
	let secret = shared_secret();
	let payload = data;
	if (secret != "" && payload != null) { payload["_auth_token"] = secret; }
	let body = stringify(payload);
	let h = ["Content-Type: application/json"];
	if (secret != "") { h.push("Authorization: Bearer " + secret); }
	return http_request_timeout("POST", url, body, h, CP_AGENT_TIMEOUT_MS);
}
fn cp_get(url: string) {
	let h = [];
	let secret = shared_secret();
	if (secret != "") { h.push("Authorization: Bearer " + secret); }
	return http_request_timeout("GET", url, "", h, CP_AGENT_TIMEOUT_MS);
}
// Short-timeout GET for DASHBOARD fan-outs (events/services snapshots).
// These hit every agent; one slow/just-unreachable node (e.g. a box that
// fell asleep but is still inside the 90s stale window) would otherwise
// stall the whole snapshot ~20s on the OS connect timeout — making the
// dashboard (and the SSE stream every page opens) appear to hang.
//
// Uses curl, NOT the lws client: lws's request timeout does NOT bound the
// TCP connect, so a SYN black-hole still blocks ~20s. curl --connect-timeout
// caps it hard at 3s. All fan-out callers try/catch, so a connect failure
// (curl exit 28) just skips that node from the snapshot.
fn cp_get_fast(url: string): object {
	let args = ["curl", "-sS", "--connect-timeout", "3", "--max-time", "6",
		"-w", "\n%{http_code}"];
	let secret = shared_secret();
	if (secret != "") {
		// Bearer via the 0600 config file (see write_curl_auth_cfg) so
		// the secret stays out of /proc/<pid>/cmdline. Header-in-argv
		// only as a fallback when the config couldn't be written.
		let cfg = curl_auth_cfg_path();
		if (exists(cfg)) {
			args.push("-K"); args.push(cfg);
		} else {
			args.push("-H"); args.push("Authorization: Bearer " + secret);
		}
	}
	args.push(url);
	let r = exec_argv(args);
	if (r.exit_code != 0) { throw "curl exit " + r.exit_code + " for " + url; }
	let out = r.output;
	let nl = -1;
	let i = 0;
	while (i < out.length) { if (out.substr(i, 1) == "\n") { nl = i; } i = i + 1; }
	let body = (nl >= 0) ? out.substr(0, nl) : out;
	let code_str = (nl >= 0) ? out.substr(nl + 1, out.length - nl - 1).trim() : "";
	let code = 0;
	try { code = i32(code_str); } catch (e) { code = 0; }
	return { status_code: code, body: body };
}
fn cp_put_json(url: string, data) {
	let secret = shared_secret();
	let payload = data;
	if (secret != "" && payload != null) { payload["_auth_token"] = secret; }
	let body = stringify(payload);
	let h = ["Content-Type: application/json"];
	if (secret != "") { h.push("Authorization: Bearer " + secret); }
	return http_request_timeout("PUT", url, body, h, CP_AGENT_TIMEOUT_MS);
}

// One global db handle — cp.hml is small enough to live with it.
let DB = null;

fn init_db(db): null {
	exec(db, "create table if not exists nodes ("
		+ "node_id text primary key,"
		+ "hostname text not null,"
		+ "role text not null,"
		+ "hardware_json text not null,"
		+ "agent_url text,"
		+ "registered_at text not null,"
		+ "last_seen_at text not null,"
		+ "state text not null default 'active',"  // active | disabled | draining
		+ "runtime_json text"                       // {llama_server: {...}}
		+ ")", []);
	// Migrations for DBs that predate v0.7 columns (state, runtime_json).
	// SQLite errors if the column exists; wrap in try to make idempotent.
	try { exec(db, "alter table nodes add column state text not null default 'active'", []); } catch (e) { }
	try { exec(db, "alter table nodes add column runtime_json text", []); } catch (e) { }
	// auto_restart: the agent's watchdog toggle, mirrored from each
	// heartbeat (1/0, null for agents too old to report it). Display +
	// the toggle endpoint read this; the agent stays the source of truth.
	try { exec(db, "alter table nodes add column auto_restart integer", []); } catch (e) { }
	// agent_version: the witchgrid agent build each node runs, mirrored from
	// register. null = an agent too old to report it (→ "update" hint). Lets
	// the dashboard surface fleet version drift instead of it being silent.
	try { exec(db, "alter table nodes add column agent_version text", []); } catch (e) { }
	// Per-node GGUF catalog. Replaced wholesale on each /register so we
	// don't accumulate stale entries when an operator deletes a model
	// from disk. Indexed on alias for the placement-time "which nodes
	// have this model?" lookup.
	exec(db, "create table if not exists node_models ("
		+ "node_id text not null,"
		+ "alias text not null,"
		+ "path text not null,"
		+ "size_mb integer not null,"
		+ "architecture text,"
		+ "n_layers integer,"
		+ "n_heads integer,"
		+ "n_kv_heads integer,"
		+ "embedding_length integer,"
		+ "claimed_context integer,"
		+ "general_name text,"
		+ "source_url text,"
		+ "primary key (node_id, alias)"
		+ ")", []);
	exec(db, "create index if not exists ix_node_models_alias on node_models(alias)", []);

	// Hardware time-series for sparklines. One row per (metric, series)
	// per heartbeat. Pruned to last 1hr each ingest. Tiny table —
	// 1 node × (4 GPUs + 1 RAM + N disks) × 120 samples ≈ 700 rows.
	//
	//   metric: 'gpu_free_mb' | 'ram_free_mb' | 'disk_free_mb'
	//   series: gpu_index as text, disk path, or null for ram
	exec(db, "create table if not exists node_samples ("
		+ "node_id text not null,"
		+ "metric text not null,"
		+ "series text,"
		+ "value integer not null,"
		+ "sampled_at text not null"
		+ ")", []);
	exec(db, "create index if not exists ix_samples_lookup "
		+ "on node_samples(node_id, metric, series, sampled_at)", []);

	// Unmanaged GPU processes (slice C5). Replace-all-per-node every
	// heartbeat — same model as node_models. These are processes
	// nvidia-smi sees holding vram that witchgrid did NOT spawn
	// (e.g. another user's llama-server, jupyter). Surfaced in the
	// dashboard so operators understand "free vram" properly.
	exec(db, "create table if not exists node_unmanaged_procs ("
		+ "node_id text not null,"
		+ "pid integer not null,"
		+ "process_name text not null,"
		+ "vram_mb integer not null,"
		+ "gpu_index integer,"
		+ "owner_uid integer,"
		+ "owner_name text,"
		+ "ports text,"               // JSON array of listening ports (newer agents)
		+ "cmdline text,"             // full argv (newer agents)
		+ "observed_at text not null,"
		+ "primary key (node_id, pid)"
		+ ")", []);
	// Migrate pre-existing DBs: add the ports/cmdline columns if absent.
	// sqlite errors when the column already exists — swallow that.
	try { exec(db, "alter table node_unmanaged_procs add column ports text", []); } catch (e) { }
	try { exec(db, "alter table node_unmanaged_procs add column cmdline text", []); } catch (e) { }

	// Profiles. CP-owned now (was baked into agent binaries pre-v0.7).
	// CRUD via /api/profiles[/{name}]; spawns get the full profile JSON
	// inline so agents don't need to know what profiles exist.
	// version bumps on every PUT; agents tag their service rows with
	// the version that was current at spawn time.
	// Bench runs. CP-orchestrated benchmarks of (node × profile ×
	// build) combos. Each run pin-spawns the profile on a target
	// node, fires N timed completion requests, records aggregate
	// stats, stops the service. Results live forever (operator can
	// purge manually) — disk cost is rounding error.
	exec(db, "create table if not exists bench_runs ("
		+ "id text primary key,"
		+ "node_id text not null,"
		+ "profile_name text not null,"
		+ "build_hash text,"                     // captured at spawn time from /nodes
		+ "prompt text not null,"
		+ "n_predict integer not null,"
		+ "repetitions integer not null,"
		+ "ttft_ms_median real,"                 // time-to-first-token median across reps
		+ "tok_per_sec_median real,"             // tokens/sec median across reps
		+ "total_ms_median real,"
		+ "tokens_predicted_median integer,"
		+ "output_excerpt text,"                 // first rep's output, first 500 chars
		+ "status text not null,"                // queued|spawning|running|complete|error
		+ "error text,"
		+ "started_at text not null,"
		+ "completed_at text"
		+ ")", []);

	exec(db, "create table if not exists profiles ("
		+ "name text primary key,"
		+ "profile_json text not null,"
		+ "version integer not null default 1,"
		+ "created_at text not null,"
		+ "updated_at text not null"
		+ ")", []);

	// Profile aliases — public-facing names that resolve to a real
	// profile. Lets operators rename profiles without breaking
	// consumer URLs (e.g. FlameWorker pointing at
	// /v1/llama/flame-chat/completion). The alias is the URL token,
	// the target is the actual profiles.name. Many aliases can point
	// at one profile; one alias points at one profile (it's not a
	// fan-out / load-balancer).
	exec(db, "create table if not exists profile_aliases ("
		+ "alias_name text primary key,"
		+ "target_profile text not null,"
		+ "created_at text not null,"
		+ "updated_at text not null"
		+ ")", []);

	// Runtime-tunable settings — config that an operator should be
	// able to flip without restarting CP (or even SSHing). Single
	// table, key/value, all values stored as strings; consumers
	// parse to the type they want.
	exec(db, "create table if not exists cp_settings ("
		+ "key text primary key,"
		+ "value text not null,"
		+ "updated_at text not null"
		+ ")", []);

	// Cache of scraped HF model cards (metadata + validated image URL), so
	// browsing/expanding the same repo doesn't re-hit HuggingFace each time.
	// Keyed by repo; refreshed when older than the TTL (see handle_hf_card).
	exec(db, "create table if not exists hf_card_cache ("
		+ "repo text primary key,"
		+ "card_json text not null,"
		+ "fetched_at text not null"
		+ ")", []);

	seed_default_profiles(db);
	seed_default_settings(db);
	reap_stale_bench_runs(db);
	return null;
}

// Settings defaults. Insert-or-ignore so an operator's prior edits
// survive a CP upgrade — only fills in keys that don't exist yet.
fn seed_default_settings(db): null {
	let now = iso_now();
	let defaults = [
		// 0 disables backups. Reasonable production value: 60 (hourly).
		{ k: "db_backup_interval_min", v: "0" },
		// Where backups land. Path is relative to CP's working dir
		// (next to witchgrid.db) so it works without changes when
		// the operator hasn't thought about storage layout.
		{ k: "db_backup_dir",          v: "./backups" },
		// How many .bak files to keep. Older ones get pruned after
		// each new backup. Default 24 = one day at hourly cadence.
		{ k: "db_backup_keep",         v: "24" },
		// Stamped after each successful backup; surfaced in the
		// dashboard so operators can see the loop is alive.
		{ k: "db_backup_last_at",      v: "" },
		{ k: "db_backup_last_path",    v: "" },
		// Trusted HuggingFace quant authors — drives the catalog discovery
		// filter. Comma-separated org/user handles.
		{ k: "hf_trusted_authors",     v: "bartowski,mradermacher,TheBloke,unsloth,QuantFactory,lmstudio-community" },
	];
	for (d in defaults) {
		exec(db,
			"insert or ignore into cp_settings (key, value, updated_at) "
			+ "values (?, ?, ?)",
			[d.k, d.v, now]);
	}
	return null;
}

// ── profile aliases (consumer-facing name indirection) ─────────────
//
// Resolves a public-facing name to a real profile. If the name is
// in profile_aliases, returns the target_profile. Otherwise returns
// the name unchanged so direct profile names still work — aliases
// are additive, never replace the "look up by literal name" path.

fn resolve_profile_name(name: string): string {
	let r = query(DB,
		"select target_profile from profile_aliases where alias_name = ?",
		[name]);
	if (r.length == 0) { return name; }
	return r[0].target_profile;
}

fn handle_list_profile_aliases(req): object {
	let rows = query(DB,
		"select alias_name, target_profile, created_at, updated_at "
		+ "from profile_aliases order by alias_name", []);
	let out = [];
	for (r in rows) { out.push(r); }
	return { status: 200, body: stringify(out) };
}

// PUT /api/profile-aliases — body { alias_name, target_profile }.
// Upsert by alias_name. Validates that target_profile actually
// exists; returns 422 otherwise so the operator catches typos
// before consumers start hitting 503s.
fn handle_upsert_profile_alias(req): object {
	let payload = parse(req?.body ?? "{}");
	let alias = payload?.alias_name;
	let target = payload?.target_profile;
	if (alias == null || alias == "" || target == null || target == "") {
		return { status: 400, body: stringify({
			error: "alias_name + target_profile required" })};
	}
	let exists_p = query(DB, "select 1 from profiles where name = ?", [target]);
	if (exists_p.length == 0) {
		return { status: 422, body: stringify({
			error: "no profile named '" + target + "' — alias must "
				+ "point at an existing profile" })};
	}
	// Reject self-aliases (trivially confusing) and aliases that
	// shadow an existing profile name (would never be hit since
	// resolve_profile_name only fires when name is in the alias
	// table — but easier to just refuse than explain later).
	if (alias == target) {
		return { status: 422, body: stringify({
			error: "alias_name == target_profile is a no-op" })};
	}
	let exists_a = query(DB, "select 1 from profiles where name = ?", [alias]);
	if (exists_a.length > 0) {
		return { status: 422, body: stringify({
			error: "alias '" + alias + "' shadows an existing profile name" })};
	}
	let now = iso_now();
	exec(DB,
		"insert into profile_aliases (alias_name, target_profile, created_at, updated_at) "
		+ "values (?, ?, ?, ?) "
		+ "on conflict(alias_name) do update set "
		+ "target_profile=excluded.target_profile, "
		+ "updated_at=excluded.updated_at",
		[alias, target, now, now]);
	return { status: 200, body: stringify({
		alias_name: alias, target_profile: target })};
}

fn handle_delete_profile_alias(req): object {
	let prefix = "/api/profile-aliases/";
	let alias = req.path.substr(prefix.length, req.path.length - prefix.length);
	if (alias.length == 0) {
		return { status: 400, body: "{\"error\":\"alias name required\"}" };
	}
	exec(DB, "delete from profile_aliases where alias_name = ?", [alias]);
	return { status: 204, body: "" };
}

// ── settings (cp_settings table) ────────────────────────────────────

fn setting_get(key: string, default_value: string): string {
	let r = query(DB, "select value from cp_settings where key = ?", [key]);
	if (r.length == 0) { return default_value; }
	return r[0].value;
}

fn setting_set(key: string, value: string): null {
	exec(DB,
		"insert into cp_settings (key, value, updated_at) values (?, ?, ?) "
		+ "on conflict(key) do update set value=excluded.value, updated_at=excluded.updated_at",
		[key, value, iso_now()]);
	return null;
}

fn handle_list_settings(req): object {
	let rows = query(DB, "select key, value, updated_at from cp_settings order by key", []);
	let out = {};
	for (r in rows) {
		out[r.key] = { value: r.value, updated_at: r.updated_at };
	}
	return { status: 200, body: stringify(out),
		headers: { "content-type": "application/json" } };
}

// GET /api/config — unified config snapshot for the settings page:
// the editable cp_settings plus the read-only, env-derived runtime knobs
// (bind, auth posture, stale threshold, version). The secret itself is
// never exposed — only whether auth is on.
fn handle_get_config(req): object {
	let settings = {};
	let rows = query(DB, "select key, value from cp_settings order by key", []);
	for (r in rows) { settings[r.key] = r.value; }
	let cfg = {
		version:            WITCHGRID_VERSION,
		host:               HOST,
		port:               PORT,
		auth_enabled:       shared_secret().length > 0,
		auth_protect_read:      auth_protect_read(),
		auth_protect_inference: auth_protect_inference(),
		stale_node_seconds: STALE_NODE_SECONDS,
		hf_trusted_authors: setting_get("hf_trusted_authors", ""),
		settings:           settings,
	};
	return { status: 200, body: stringify(cfg),
		headers: { "content-type": "application/json" } };
}

// PUT /api/settings — body is { key1: value1, key2: value2 }. All
// values stored as strings; consumers parse to their own type.
// Allowed keys gated by an explicit allowlist so the operator can't
// accidentally set arbitrary keys (and to make removal safe later).
let SETTING_KEYS_ALLOWED = ["db_backup_interval_min", "db_backup_dir", "db_backup_keep", "hf_trusted_authors"];

fn handle_update_settings(req): object {
	let payload = parse(req?.body ?? "{}");
	let updated = [];
	for (k in payload.keys()) {
		let allowed = false;
		for (a in SETTING_KEYS_ALLOWED) { if (a == k) { allowed = true; } }
		if (!allowed) { continue; }
		setting_set(k, "" + payload[k]);
		updated.push(k);
	}
	return { status: 200, body: stringify({ updated: updated }) };
}

// ── sqlite auto-backup ──────────────────────────────────────────────
//
// Background task that VACUUMs CP's sqlite into a fresh .bak file
// every db_backup_interval_min minutes. 0 disables the loop. Runs on
// CP boot; reads settings each tick so live edits take effect on
// the next interval boundary. Pruning keeps the most recent
// db_backup_keep files; older ones get unlinked.
//
// VACUUM INTO is atomic from SQLite's POV — produces a clean copy
// of the DB at a consistent point in time, no torn pages even if
// CP is mid-write. The dest file must NOT exist (sqlite refuses to
// overwrite), so each backup gets a unique unix-ms suffix.

fn safe_dir_path(d: string): bool {
	// Only allow paths made of alphanumerics, /, ., -, _ to keep
	// SQL injection out of the VACUUM INTO statement (which can't
	// be parameterized). Operator-controlled but operator-trusted —
	// this is defence-in-depth, not a security boundary.
	if (d.length == 0 || d.length > 256) { return false; }
	let i = 0;
	while (i < d.length) {
		let c = d[i];
		let ok = (c >= 'a' && c <= 'z')
			|| (c >= 'A' && c <= 'Z')
			|| (c >= '0' && c <= '9')
			|| c == '/' || c == '.' || c == '-' || c == '_';
		if (!ok) { return false; }
		i = i + 1;
	}
	return true;
}

async fn db_backup_loop(): null {
	loop {
		// Read settings every tick so changes apply on the next
		// boundary without bouncing CP.
		let interval_str = setting_get("db_backup_interval_min", "0");
		let interval_min: i32 = i32(interval_str);
		if (interval_min < 1) {
			// Disabled. Poll the setting once a minute so an
			// operator flipping it on doesn't have to wait the
			// previous interval to elapse.
			sleep(60.0);
			continue;
		}

		sleep(f64(interval_min) * 60.0);

		let dir = setting_get("db_backup_dir", "./backups");
		if (!safe_dir_path(dir)) {
			eprint("[backup] refused: db_backup_dir contains unsafe chars: " + dir);
			continue;
		}
		// Ensure the dir exists (mkdir -p style).
		try { make_dirs(dir); } catch (e) {
			eprint("[backup] mkdir " + dir + " failed: " + e);
			continue;
		}

		let stamp_str = "" + unix_ms();
		let dest = dir + "/witchgrid.db.bak." + stamp_str;
		try {
			exec(DB, "vacuum into '" + dest + "'", []);
			print("[backup] wrote " + dest);
			setting_set("db_backup_last_at", iso_now());
			setting_set("db_backup_last_path", dest);
		} catch (e) {
			eprint("[backup] vacuum failed: " + e);
			continue;
		}

		// Prune oldest beyond keep. Scan dir, filter to our prefix,
		// sort by name (timestamp suffix sorts correctly), drop tail.
		let keep_str = setting_get("db_backup_keep", "24");
		let keep: i32 = i32(keep_str);
		if (keep < 1) { keep = 1; }
		try {
			let entries = list_dir(dir);
			let baks = [];
			let prefix = "witchgrid.db.bak.";
			for (e in entries) {
				if (e.starts_with(prefix)) { baks.push(e); }
			}
			// Sort lexicographically — timestamps are zero-padded
			// unix millis so newest = highest. After sort, oldest
			// at index 0.
			baks.sort();
			let to_drop: i32 = baks.length - keep;
			let i: i32 = 0;
			while (i < to_drop) {
				try { remove_file(dir + "/" + baks[i]); }
				catch (e) { eprint("[backup] prune failed: " + e); }
				i = i + 1;
			}
			if (to_drop > 0) {
				print("[backup] pruned " + to_drop + " old backup(s)");
			}
		} catch (e) {
			eprint("[backup] prune scan failed: " + e);
		}
	}
	return null;
}

// Bench reaper. Anything left in 'running' for >10 min is almost
// certainly the victim of a CP restart (or an agent that vanished
// mid-bench), not an actively-progressing run. Mark it errored so
// the dashboard doesn't show phantom in-flight rows. Cosmetic but
// closes the "is this still going or did CP eat it?" question.
//
// Threshold: 10 min covers the longest realistic bench (e.g. 10
// repetitions × 30s/each + spawn overhead) with headroom. Real
// in-flight runs that briefly exceed it get marked errored on
// restart but their output_excerpt + medians stay populated if the
// task did get partway — operator can rerun.
fn reap_stale_bench_runs(db): null {
	let r = query(db,
		"select count(*) as n from bench_runs "
		+ "where status = 'running' "
		+ "and started_at < datetime('now', '-10 minutes')", []);
	let stale = r[0].n;
	if (stale > 0) {
		exec(db,
			"update bench_runs "
			+ "set status = 'error', "
			+ "    error = 'crashed mid-run during CP restart', "
			+ "    completed_at = datetime('now') "
			+ "where status = 'running' "
			+ "and started_at < datetime('now', '-10 minutes')", []);
		print("[cp] reaped " + stale + " stale bench_runs row(s)");
	}
	return null;
}

// Built-in profile defaults. Seeded into the profiles table on first
// CP boot (when the table is empty). After that, the operator owns
// the set — edits via the dashboard don't get clobbered by a CP
// restart. To re-seed, drop the rows manually and restart.
fn seed_default_profiles(db): null {
	// insert-or-ignore per name (see the loop below) rather than an
	// all-or-nothing "skip if any profile exists" guard. This means a CP
	// upgrade picks up newly-curated default profiles without clobbering
	// any an operator has edited (name is the PK; ON CONFLICT DO NOTHING
	// leaves an existing row untouched). Same precedent as
	// seed_default_settings. Trade-off: a default an operator deliberately
	// deleted reappears on the next boot — re-delete it, or set its
	// visibility to taste.
	let now = iso_now();
	let defaults = [
		{
			name: "chat-mahou",
			profile: {
				binary: "llama-server",
				intent: {
					context: 131072,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18080,
				context: 131072,
				kv_type: "q4_0",
				model_alias: "mahou-1.5-mistral-nemo-12b.q5_k_m",
				hf_source: {
					repo: "flammenai/Mahou-1.5-mistral-nemo-12B-GGUF",
					file: "Mahou-1.5-mistral-nemo-12b.Q5_K_M.gguf",
				},
				// default_model intentionally null — the path is
				// deployment-specific. Operators set it via the
				// dashboard editor if they want a legacy-path
				// fallback; model_alias + catalog resolution is the
				// modern path that doesn't pin to a filesystem
				// layout.
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// FlameGen designer profile. Tuned to match flammen.ai
			// production: CPU-only (gpu_layers: 0) so it can share a
			// box with chat without competing for VRAM, --jinja flag
			// required because FlameGen calls /v1/chat/completions
			// (not raw /completion) so llama-server needs to apply
			// the model's chat template server-side. ~38s per design
			// at Q8_0 on 8 threads — fine for the async creation
			// pipeline, would need GPU placement for sub-10s latency.
			name: "designer-cpu",
			profile: {
				binary: "llama-server",
				intent: {
					context: 4096,
					kv_cache_k: "q8_0",
					kv_cache_v: "q8_0",
					parallel_slots: 1,
					gpu_layers: 0,
				},
				extra_flags: ["--jinja"],
				default_port: 18081,
				context: 4096,
				kv_type: "q8_0",
				model_alias: "flamedesigner-qwen2.5-3b-v1.q8_0",
				hf_source: {
					repo: "mradermacher/FlameDesigner-Qwen2.5-3B-v1-GGUF",
					file: "FlameDesigner-Qwen2.5-3B-v1.Q8_0.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// Match flammen.ai production: CPU memory summarizer, q3_k_m
			// to keep RAM use reasonable, 16k context (the summary windows
			// are short — 32k was overkill). Pairs with chat-mahou via
			// the match_memories ingest path; runs on the same box as
			// designer-cpu so memory summarization doesn't compete with
			// chat for VRAM.
			name: "memory-phoenix",
			profile: {
				binary: "llama-server",
				intent: {
					context: 16384,
					kv_cache_k: "q4_0",
					kv_cache_v: "q4_0",
					parallel_slots: 1,
					gpu_layers: 0,
				},
				extra_flags: [],
				default_port: 18085,
				context: 16384,
				kv_type: "q4_0",
				model_alias: "phoenix-qwen2.5-7b-v1.q3_k_m",
				hf_source: {
					repo: "mradermacher/Phoenix-Qwen2.5-7B-v1-GGUF",
					file: "Phoenix-Qwen2.5-7B-v1.Q3_K_M.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// FlameGen image profile — stable-diffusion.cpp serving the
			// NikuMixXL4 SDXL anime checkpoint (converted to q8_0 GGUF).
			// sd-server has no context/kv/gpu-layers concepts so intent
			// is empty; --diffusion-fa enables flash attention. FlameGen
			// talks the A1111-compatible /sdapi/v1/txt2img on the
			// resolved base_url (resolve-then-connect, like designer).
			// context/kv_type are harmless scalars for CP code paths
			// that read profile.context / profile.kv_type.
			name: "image-niku",
			profile: {
				binary: "sd-server",
				intent: {},
				extra_flags: ["--diffusion-fa"],
				default_port: 19080,
				context: 0,
				kv_type: "f16",
				model_alias: "nikumixxl4.q8_0",
				hf_source: null,
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// Text-to-speech starter — piper serving an English voice.
			// Counterpart to audio-whisper-base; together they close the
			// audio loop (STT in / chat / TTS out). piper's HTTP server
			// expects --model <abs path to .onnx> at spawn (model files
			// aren't catalog-able, like sd-cpp/whisper-cpp); clone this
			// profile and point at a different rhasspy/piper-voices
			// model for a different voice/language.
			name: "tts-piper-en",
			profile: {
				binary: "piper",
				intent: {},
				extra_flags: ["--http"],
				default_port: 19095,
				context: 0,
				kv_type: "f16",
				model_alias: "piper-en_US-lessac-medium",
				hf_source: {
					repo: "rhasspy/piper-voices",
					file: "en/en_US/lessac/medium/en_US-lessac-medium.onnx",
				},
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// Speech-to-text starter — whisper.cpp serving the base.en
			// GGUF (~150 MB, fast on CPU and tiny on a GPU). Consumers
			// hit the OpenAI-compatible /v1/audio/transcriptions on the
			// resolved base_url. Whisper model files aren't catalog-able
			// (no LLM arch metadata, same situation as the SDXL GGUF in
			// image-niku) — spawn with the explicit `model: <abs path>`
			// pin or override default_model. Operators wanting a bigger
			// model duplicate this profile and point at e.g.
			// whisper-medium-q5_1.gguf or whisper-large-v3.gguf.
			name: "audio-whisper-base",
			profile: {
				binary: "whisper-server",
				intent: {},
				extra_flags: [],
				default_port: 19090,
				context: 0,
				kv_type: "f16",
				model_alias: "whisper-base-en.q5_1",
				hf_source: {
					repo: "ggml-org/whisper.cpp",
					file: "ggml-base.en-q5_1.bin",
				},
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// Embedding server — pure llama-server config, no engine
			// code. --embeddings flips the server into embedding mode;
			// --pooling mean suits sentence-embedding models. CPU
			// (gpu_layers 0) like designer/phoenix — embeddings are
			// cheap and shouldn't compete for VRAM. Consumers hit
			// /v1/embeddings on the resolved base_url (resolve-then-
			// connect, same as chat).
			name: "embed-nomic",
			profile: {
				binary: "llama-server",
				intent: {
					context: 8192,
					parallel_slots: 1,
					gpu_layers: 0,
				},
				extra_flags: ["--embeddings", "--pooling", "mean"],
				default_port: 18090,
				context: 8192,
				kv_type: "f16",
				model_alias: "nomic-embed-text-v1.5.q8_0",
				hf_source: {
					repo: "nomic-ai/nomic-embed-text-v1.5-GGUF",
					file: "nomic-embed-text-v1.5.Q8_0.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},
		{
			// Multimodal (vision) — also just a llama-server profile
			// pointed at a VL GGUF. No special flag: the agent
			// autoloads the model's co-located mmproj projector at
			// spawn (prefers the f16 projector). Consumers send
			// image_url content to /v1/chat/completions.
			name: "vision-qwen",
			profile: {
				binary: "llama-server",
				intent: {
					context: 32768,
					kv_cache_k: "f16",
					kv_cache_v: "f16",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
				},
				extra_flags: [],
				default_port: 18095,
				context: 32768,
				kv_type: "f16",
				model_alias: "qwen2.5-vl-7b-instruct.q8_0",
				hf_source: {
					repo: "ggml-org/Qwen2.5-VL-7B-Instruct-GGUF",
					file: "Qwen2.5-VL-7B-Instruct-Q8_0.gguf",
				},
				default_model: null,
				default_device: "auto",
			},
		},

		// ─── General-purpose starter profiles ─────────────────────────
		// Vendor-neutral, broadly-useful llama-server configs pointed at
		// well-known GGUFs from bartowski (a default-trusted quanter). The
		// flammen.ai profiles above are real production config kept as
		// worked examples; these are the "what would I actually run"
		// starters: VRAM tiers for general chat, a reasoning model, a
		// coding model, plus two trade-off variants on the 8B workhorse.
		// All default_device "auto" (GPU when present; clone with
		// device=cpu for a CPU-only node). All Q4_K_M unless the name says
		// otherwise — the quality/size sweet spot. VRAM figures in the
		// comments are weights + a modest KV at the stated context.

		// Small chat — ~2 GB weights. Runs on a CPU box or any 8 GB GPU,
		// fast. The "always fits" baseline. q8_0 KV (cheap at 3B) keeps
		// quality high.
		{
			name: "chat-llama3.2-3b",
			profile: {
				binary: "llama-server",
				intent: {
					context: 32768,
					kv_cache_k: "q8_0",
					kv_cache_v: "q8_0",
					parallel_slots: 1,
					gpu_layers: 99,
					flash_attention: true,
