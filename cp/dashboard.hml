// dashboard.hml — single-page operator UI for CP.
//
// GET /            full HTML shell (htmx + pico css from CDN, no build step)
// GET /ui/nodes    htmx fragment: registered nodes + per-GPU free VRAM
// GET /ui/services htmx fragment: running services across all agents
// GET /ui/profiles htmx fragment: known profiles + auto-spawn status
//
// Each fragment auto-refreshes every 5 seconds via hx-trigger=load,every 5s.
// Operators can stop a service via the inline button (POST /services/stop
// → CP proxies to the owning agent → SIGTERM).
//
// Design choices: zero build step. htmx + Pico from CDN. Hand-rolled HTML
// strings instead of jinja templates because the surface is tiny and one
// fewer stdlib dep keeps the binary lean. Refactor when we add a third
// page that wants real templating.

import { parse, stringify } from "@stdlib/json";

// ── helpers ──────────────────────────────────────────────────────────

// HTML-escape user-controlled strings (node names, model paths, etc.)
// before interpolation. Five-char escape covers everything that breaks
// out of an attribute or text node.
fn esc(s): string {
	if (s == null) { return ""; }
	let t = "" + s;
	t = t.replace_all("&", "&amp;");
	t = t.replace_all("<", "&lt;");
	t = t.replace_all(">", "&gt;");
	t = t.replace_all("\"", "&quot;");
	t = t.replace_all("'", "&#39;");
	return t;
}

// Format MB as either "1234 MB" or "12.3 GB" depending on size.
// All intermediates explicitly cast to i32 to keep Hemlock from
// formatting i64s as "5.0" — was getting "15.5.0 GB" before.
fn fmt_mb(mb): string {
	let n = f64(mb);
	if (n >= 1024.0) {
		let tenths: i32 = i32(n * 10.0 / 1024.0);
		let whole:  i32 = tenths / 10;
		let frac:   i32 = tenths - whole * 10;
		return "" + whole + "." + frac + " GB";
	}
	return "" + i32(n) + " MB";
}

// Compose a CSS color token from VRAM utilization. Used for the free-mb
// progress bars — green when plenty free, amber when getting tight, red
// when nearly full.
fn vram_color(free_mb, total_mb): string {
	let pct = (f64(free_mb) / f64(total_mb)) * 100.0;
	if (pct >= 50.0) { return "var(--pico-color-green-500)"; }
	if (pct >= 15.0) { return "var(--pico-color-amber-500)"; }
	return "var(--pico-color-red-500)";
}

// HTTP wrapper — sets content-type so the browser doesn't squint.
fn html_resp(body: string): object {
	return {
		status: 200,
		body: body,
		headers: { "content-type": "text/html; charset=utf-8" },
	};
}

// ── shell page ───────────────────────────────────────────────────────

let SHELL = "<!doctype html>\n"
	+ "<html lang=\"en\">\n"
	+ "<head>\n"
	+ "  <meta charset=\"utf-8\">\n"
	+ "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
	+ "  <title>witchgrid</title>\n"
	+ "  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css\">\n"
	+ "  <script src=\"https://unpkg.com/htmx.org@2.0.4\"></script>\n"
	+ "  <style>\n"
	+ "    main { padding: 1rem 2rem; max-width: 1200px; }\n"
	+ "    h1 { font-family: 'Courier New', monospace; letter-spacing: -1px; margin: 0 0 0.5rem; }\n"
	+ "    .meta { color: var(--pico-muted-color); font-size: 0.85em; }\n"
	+ "    section { margin-top: 2rem; }\n"
	+ "    table { font-size: 0.9em; }\n"
	+ "    table th { text-transform: uppercase; font-size: 0.75em; letter-spacing: 0.05em; color: var(--pico-muted-color); }\n"
	+ "    .gpu-row { display: flex; align-items: center; gap: 0.5rem; margin: 2px 0; font-family: monospace; font-size: 0.85em; }\n"
	+ "    .gpu-bar { flex: 1; height: 8px; background: var(--pico-card-background-color); border-radius: 4px; overflow: hidden; max-width: 200px; }\n"
	+ "    .gpu-bar > div { height: 100%; transition: width 0.3s; }\n"
	+ "    .gpu-name { min-width: 180px; opacity: 0.8; font-size: 0.85em; }\n"
	+ "    .gpu-mem { min-width: 110px; text-align: right; font-variant-numeric: tabular-nums; }\n"
	+ "    .stale { color: var(--pico-color-red-500); font-weight: bold; }\n"
	+ "    .alive-yes { color: var(--pico-color-green-500); }\n"
	+ "    .alive-no { color: var(--pico-color-red-500); }\n"
	+ "    .empty { color: var(--pico-muted-color); font-style: italic; padding: 1rem 0; }\n"
	+ "    .id { font-family: monospace; font-size: 0.85em; opacity: 0.7; }\n"
	+ "    .stop-btn { padding: 0.2rem 0.6rem; font-size: 0.85em; margin: 0; }\n"
	+ "    code { font-size: 0.85em; }\n"
	+ "  </style>\n"
	+ "</head>\n"
	+ "<body>\n"
	+ "  <main>\n"
	+ "    <h1>witchgrid</h1>\n"
	+ "    <p class=\"meta\">control plane · live every 5s</p>\n"
	+ "\n"
	+ "    <section>\n"
	+ "      <h2>Nodes</h2>\n"
	+ "      <div hx-get=\"/ui/nodes\" hx-trigger=\"load, every 5s\">loading…</div>\n"
	+ "    </section>\n"
	+ "\n"
	+ "    <section>\n"
	+ "      <h2>Services</h2>\n"
	+ "      <div hx-get=\"/ui/services\" hx-trigger=\"load, every 5s\">loading…</div>\n"
	+ "    </section>\n"
	+ "\n"
	+ "    <section>\n"
	+ "      <h2>Profiles</h2>\n"
	+ "      <div hx-get=\"/ui/profiles\" hx-trigger=\"load, every 5s\">loading…</div>\n"
	+ "    </section>\n"
	+ "  </main>\n"
	+ "</body>\n"
	+ "</html>\n";

export fn handle_dashboard(req): object {
	return html_resp(SHELL);
}

// ── /ui/nodes fragment ───────────────────────────────────────────────

// nodes_data: [{node_id, hostname, role, hardware: {gpus: [...]},
//               agent_url, registered_at, last_seen_at, age_seconds}]
// Renders one row per node, with GPU bars nested inside.
export fn render_nodes(nodes_data, stale_seconds: i32): string {
	if (nodes_data.length == 0) {
		return "<p class=\"empty\">No nodes registered.</p>";
	}
	let html = "<table>\n"
		+ "<thead><tr>"
		+ "<th>node</th><th>role</th><th>last seen</th>"
		+ "<th>GPUs (free / total)</th>"
		+ "</tr></thead>\n<tbody>\n";
	for (n in nodes_data) {
		let stale = n.age_seconds > stale_seconds;
		let last_class = "";
		if (stale) { last_class = " class=\"stale\""; }
		html = html + "<tr>"
			+ "<td><strong>" + esc(n.node_id) + "</strong>"
				+ "<br><span class=\"id\">" + esc(n.hostname) + "</span></td>"
			+ "<td>" + esc(n.role) + "</td>"
			+ "<td" + last_class + ">" + n.age_seconds + "s ago</td>"
			+ "<td>";
		let gpus = n.hardware?.gpus ?? [];
		if (gpus.length == 0) {
			html = html + "<span class=\"empty\">—</span>";
		} else {
			for (g in gpus) {
				let pct = (f64(g.free_mb) / f64(g.total_mb)) * 100.0;
				let color = vram_color(g.free_mb, g.total_mb);
				html = html + "<div class=\"gpu-row\">"
					+ "<span class=\"gpu-name\">[" + g.index + "] "
						+ esc(g.name) + "</span>"
					+ "<div class=\"gpu-bar\"><div style=\"width: "
						+ pct + "%; background: " + color + ";\"></div></div>"
					+ "<span class=\"gpu-mem\">" + fmt_mb(g.free_mb)
						+ " / " + fmt_mb(g.total_mb) + "</span>"
					+ "</div>";
			}
		}
		html = html + "</td></tr>\n";
	}
	html = html + "</tbody></table>";
	return html;
}

// ── /ui/services fragment ────────────────────────────────────────────

// services_data: [{id, profile, model_path, port, alive, node_id, ...}]
export fn render_services(services_data): string {
	if (services_data.length == 0) {
		return "<p class=\"empty\">No services running. POST /services to spawn.</p>";
	}
	let html = "<table>\n"
		+ "<thead><tr>"
		+ "<th>profile</th><th>node</th><th>port</th>"
		+ "<th>alive</th><th>model</th><th>id</th><th></th>"
		+ "</tr></thead>\n<tbody>\n";
	for (s in services_data) {
		let alive_class = "alive-no";
		let alive_text = "✗ dead";
		if (s.alive) { alive_class = "alive-yes"; alive_text = "● live"; }
		// Trim model path to just the basename for legibility.
		// Hemlock has no rfind/find_last on strings, so split + take last.
		let model = s.model_path;
		let parts = model.split("/");
		if (parts.length > 0) {
			let tail = parts[parts.length - 1];
			if (tail.length > 0) { model = tail; }
		}
		// Stop button: plain fetch() rather than htmx so we don't need the
		// json-enc extension loaded. The dashboard's auto-refresh picks
		// up the row removal on the next 5s tick.
		let stop_js = "if(confirm('Stop " + esc(s.profile) + " on "
			+ esc(s.node_id) + "?'))"
			+ "fetch('/services/stop',{method:'POST',"
			+ "headers:{'content-type':'application/json'},"
			+ "body:JSON.stringify({id:'" + esc(s.id) + "',"
				+ "node_id:'" + esc(s.node_id) + "'})})";
		html = html + "<tr>"
			+ "<td><strong>" + esc(s.profile) + "</strong></td>"
			+ "<td>" + esc(s.node_id) + "</td>"
			+ "<td><code>" + s.port + "</code></td>"
			+ "<td class=\"" + alive_class + "\">" + alive_text + "</td>"
			+ "<td><code>" + esc(model) + "</code></td>"
			+ "<td class=\"id\">" + esc(s.id.substr(0, 8)) + "…</td>"
			+ "<td><button class=\"secondary stop-btn\""
				+ " onclick=\"" + stop_js + "\""
				+ ">stop</button></td>"
			+ "</tr>\n";
	}
	html = html + "</tbody></table>";
	return html;
}

// ── /ui/profiles fragment ────────────────────────────────────────────

// profiles_data: object map { name → { default_port, context, kv_type,
//                                       default_model } }
export fn render_profiles(profiles_data): string {
	let names = profiles_data.keys();
	if (names.length == 0) {
		return "<p class=\"empty\">No agents reachable, no profiles to show.</p>";
	}
	let html = "<table>\n"
		+ "<thead><tr>"
		+ "<th>profile</th><th>context</th><th>kv</th>"
		+ "<th>default port</th><th>auto-spawn</th>"
		+ "</tr></thead>\n<tbody>\n";
	for (n in names) {
		let p = profiles_data[n];
		let auto = "—";
		if (p?.default_model != null) {
			auto = "<span class=\"alive-yes\">✓</span> <code>"
				+ esc(p.default_model) + "</code>";
		}
		html = html + "<tr>"
			+ "<td><strong>" + esc(n) + "</strong></td>"
			+ "<td><code>" + p.context + "</code></td>"
			+ "<td><code>" + esc(p.kv_type) + "</code></td>"
			+ "<td><code>" + p.default_port + "</code></td>"
			+ "<td>" + auto + "</td>"
			+ "</tr>\n";
	}
	html = html + "</tbody></table>";
	return html;
}
