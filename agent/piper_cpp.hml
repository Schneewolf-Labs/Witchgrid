// piper_cpp.hml — manage piper TTS installs on this node.
//
// Fourth sibling. Uses engine_common like the other three. piper is
// the natural pair with whisper.cpp — together they close the audio
// loop (whisper STT in / llama chat / piper TTS out).
//
// Upstream is rhasspy/piper (https://github.com/rhasspy/piper). Its
// `piper` binary supports an HTTP server mode (`piper --http :port
// --model voice.onnx`) that returns WAV bytes for posted text.
//
// Why source-only for v1: piper's GitHub-releases prebuilts are
// architecture-specific tarballs without a stable flavor matrix
// (artifacts are essentially per-arch CPU binaries with onnxruntime
// bundled). Source build via cmake is the most reliable cross-host
// path; the build's own CMake config pulls onnxruntime via piper's
// download-libs.sh-equivalent (operator needs cmake + curl + git).
//
// GPU acceleration is via ONNX Runtime's CUDA execution provider,
// which requires a CUDA-enabled onnxruntime build. piper's default
// build script fetches the CPU onnxruntime; getting CUDA support
// means swapping the runtime — out of scope for v1, document and
// leave CPU as the realistic default. Whisper handles the GPU side
// of audio; piper's CPU is fast enough for TTS at human cadence.
//
// Model files: rhasspy/piper-voices on HuggingFace ship .onnx + .onnx.json
// pairs. NOT GGUF — like sd-cpp / whisper.cpp models, these aren't
// catalogable by the agent's GGUF scanner; spawn with the explicit
// `model: <abs path to .onnx>` pin.
//
// Layout per install:
//   ~/.witchgrid/piper/
//     v1.2.0/build/piper      ← actual binary
//     current -> v1.2.0       ← active install

import { exec_argv } from "@stdlib/process";
import { stringify, parse } from "@stdlib/json";
import { exec as db_exec, query } from "@stdlib/sqlite";
import { platform, arch } from "@stdlib/os";
import { exists, file_stat, make_dirs } from "@stdlib/fs";
import {
	install_root_for, probe_binary, resolve_current,
	ensure_install_schema, new_id, iso_now,
	list_installs_at, flip_current,
	nproc_str, mark_error,
} from "./engine_common";

let PIPER_REPO    = "https://github.com/rhasspy/piper";
let ENGINE_NAME   = "piper";
let INSTALL_TABLE = "piper_cpp_installs";

// piper's CMake output puts the binary at build/piper (and on macOS
// sometimes build/Release/piper). Probe the common shapes + child
// dirs (release archives unpack to a piper/ subdir).
let BIN_CANDIDATES = [
	"piper",
	"bin/piper",
	"build/piper",
	"build/bin/piper",
	"build/Release/piper",
];

fn install_root(): string {
	return install_root_for("piper");
}

fn find_binary(dir: string) {
	return probe_binary(dir, BIN_CANDIDATES);
}

// Auto-detect the right flavor for THIS host. piper has no GPU path
// in v1 (see header), so role doesn't matter — only platform does.
export fn detect_flavor(role: string): string {
	let p = platform();
	let a = arch();
	if (p == "darwin" && a == "arm64") { return "macos-arm64"; }
	if (p == "linux" && a == "x86_64") { return "cpu"; }
	return null;
}

export fn current_binary_path(): string {
	return resolve_current(install_root(), BIN_CANDIDATES, ENGINE_NAME);
}

export fn init_piper_cpp_schema(db): null {
	return ensure_install_schema(db, INSTALL_TABLE);
}

export fn list_installed(): array {
	return list_installs_at(install_root(), find_binary, current_binary_path());
}

export fn activate(tag: string): string {
	flip_current(install_root(), tag, find_binary, ENGINE_NAME);
	return current_binary_path();
}

// Source build. piper's CMake config pulls onnxruntime via its own
// download script; we just invoke cmake configure + build and let
// piper handle its deps. No backend matrix to translate (piper has
// no GGML_CUDA-style toggle in v1).
async fn source_install_task(db, transfer_id: string, tag: string,
                            flavor: string, target_dir: string): null {
	db_exec(db, "update " + INSTALL_TABLE + " set status='cloning' where id=?",
		[transfer_id]);
	let cr = null;
	try {
		cr = exec_argv(["git", "clone", "--recursive", PIPER_REPO, target_dir]);
	} catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"git clone exec failed (install git?): " + e, 0);
		return null;
	}
	if (cr.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"git clone exit " + cr.exit_code + ": " + (cr?.stderr ?? cr?.output ?? ""),
			400);
		return null;
	}

	let tl = tag.lower();
	if (tl != "head" && tl != "main" && tl != "master" && tl != "latest") {
		let ok = true;
		let co = null;
		try { co = exec_argv(["git", "-C", target_dir, "checkout", "-q", tag]); }
		catch (e) { ok = false; }
		if (co == null || co.exit_code != 0) { ok = false; }
		if (ok) {
			try { exec_argv(["git", "-C", target_dir, "submodule", "update",
				"--init", "--recursive"]); } catch (e) { }
		}
		if (!ok) {
			mark_error(db, INSTALL_TABLE, transfer_id,
				"git checkout '" + tag + "' failed (not a valid ref; use a "
					+ "release tag like 2023.11.14-2, or 'head' for the default branch)", 0);
			return null;
		}
	}

	db_exec(db, "update " + INSTALL_TABLE + " set status='building' where id=?",
		[transfer_id]);
	let build_dir = target_dir + "/build";
	let cfg = ["cmake", "-S", target_dir, "-B", build_dir,
		"-DCMAKE_BUILD_TYPE=Release"];
	print("[piper_cpp] " + transfer_id + " source build (flavor=" + flavor + ", CPU only in v1)");

	let cf = null;
	try { cf = exec_argv(cfg); } catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake configure exec failed (install cmake?): " + e, 0);
		return null;
	}
	if (cf.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake configure exit " + cf.exit_code + ": "
				+ (cf?.stderr ?? cf?.output ?? "") + "\n"
				+ "(piper's build pulls onnxruntime via its own download "
				+ "script — needs curl + a working network)", 800);
		return null;
	}

	let bf = null;
	try {
		bf = exec_argv(["cmake", "--build", build_dir, "--config", "Release",
			"-j", nproc_str(), "--target", "piper"]);
	} catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake build exec failed: " + e, 0);
		return null;
	}
	if (bf.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake build exit " + bf.exit_code + ": "
				+ (bf?.stderr ?? bf?.output ?? ""), 600);
		return null;
	}

	let bin = find_binary(target_dir);
	if (bin == null) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"build completed but no piper binary found under " + target_dir
				+ " (expected build/piper). If piper's cmake split into "
				+ "multi-config, check build/Release/piper instead.", 0);
		return null;
	}
	try { exec_argv(["chmod", "+x", bin]); } catch (e) { }
	let stat = null;
	try { stat = file_stat(bin); } catch (e) { }
	let now = iso_now(db);
	db_exec(db,
		"update " + INSTALL_TABLE
		+ " set status='complete', bytes_total=?, completed_at=? where id=?",
		[(stat == null ? 0 : stat.size), now, transfer_id]);
	print("[piper_cpp] " + transfer_id + " source build complete: " + tag);
	return null;
}

export fn make_handlers(db, rescan_caps_after): object {
	let do_install = fn(req): object {
		let payload = null;
		try { payload = parse(req?.body ?? "{}"); } catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let tag = payload?.tag;
		let flavor = payload?.flavor;
		if (tag == null) {
			return { status: 400, body: "{\"error\":\"tag required (e.g. 2023.11.14-2, or 'head')\"}" };
		}
		if (flavor == null) {
			return { status: 400, body: "{\"error\":\"flavor required (source|cpu|macos-arm64)\"}" };
		}
		let root = install_root();
		try { make_dirs(root); } catch (e) { }
		let target_dir = root + "/" + tag;
		if (exists(target_dir)) {
			return { status: 409, body: stringify({
				error: "target dir already exists: " + target_dir
					+ " (remove it or pick a different tag)",
			})};
		}
		let id = new_id(db);
		let now = iso_now(db);
		db_exec(db,
			"insert into " + INSTALL_TABLE + " "
			+ "(id, tag, flavor, source_url, target_dir, status, started_at) "
			+ "values (?, ?, ?, ?, ?, 'queued', ?)",
			[id, tag, flavor, PIPER_REPO, target_dir, now]);
		let st = spawn(source_install_task, db, id, tag, flavor, target_dir);
		detach(st);
		return { status: 202, body: stringify({
			install_id: id, tag: tag, flavor: flavor,
			target_dir: target_dir, mode: "source-build",
		})};
	};

	let do_list = fn(req): object {
		let installs = query(db,
			"select id, tag, flavor, status, bytes_total, error, started_at, completed_at "
			+ "from " + INSTALL_TABLE + " "
			+ "where status in ('queued','cloning','building') "
			+ "   or started_at > datetime('now','-1 hour') "
			+ "order by started_at desc",
			[]);
		return { status: 200, body: stringify({
			installed:    list_installed(),
			recent_jobs:  installs,
			current_path: current_binary_path(),
		})};
	};

	let do_activate = fn(req): object {
		let payload = null;
		try { payload = parse(req?.body ?? "{}"); } catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let tag = payload?.tag;
		if (tag == null) {
			return { status: 400, body: "{\"error\":\"tag required\"}" };
		}
		let new_path = null;
		try { new_path = activate(tag); } catch (e) {
			return { status: 400, body: stringify({ error: "" + e }) };
		}
		try { rescan_caps_after(); } catch (e) {
			eprint("[piper_cpp] post-activate rescan failed: " + e);
		}
		return { status: 200, body: stringify({
			tag: tag, current_path: new_path,
		})};
	};

	return { install: do_install, list: do_list, activate: do_activate };
}
