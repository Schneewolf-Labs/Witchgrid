// llama_cpp.hml — manage llama.cpp installs on this node.
//
// First of the engine modules; uses engine_common for the shared
// install_root / probe_binary / schema / list / activate / CUDA detect
// / pick_backend / error-mark scaffolding. Per-engine bits owned here:
// upstream repo, asset URL template (llama.cpp's release naming IS
// templatable, unlike sd.cpp — no GitHub API call needed for prebuilt
// resolution), source-build cmake flag translation, llama-server's
// binary-discovery candidate paths.
//
// Flavor matrix (only what GitHub releases ship pre-built):
//   - macos-arm64           Apple Silicon (Metal in-binary)
//   - ubuntu-vulkan-x64     Linux NVIDIA / AMD via Vulkan; cross-vendor
//                           but slower than native CUDA
//   - ubuntu-x64            Linux CPU-only
//   - source                git clone + cmake build on this node;
//                           how CUDA-native llama-server gets under
//                           witchgrid management (the prebuilt matrix
//                           ships no Linux-CUDA tarball)
//
// Layout per install:
//   ~/.witchgrid/llama-server/
//     b9124/build/bin/llama-server   ← actual binary
//     current -> b9124                ← active install

import { exec_argv } from "@stdlib/process";
import { stringify, parse } from "@stdlib/json";
import { exec as db_exec, query } from "@stdlib/sqlite";
import { platform, arch } from "@stdlib/os";
import { exists, file_stat, make_dirs, remove_file } from "@stdlib/fs";
import {
	install_root_for, probe_binary, resolve_current,
	ensure_install_schema, new_id, iso_now,
	list_installs_at, flip_current,
	detect_nvcc, detect_cuda_arch, nproc_str, pick_backend, mark_error,
} from "./engine_common";

let LLAMA_REPO    = "https://github.com/ggerganov/llama.cpp";
let ENGINE_NAME   = "llama-server";
let INSTALL_TABLE = "llama_cpp_installs";

// llama.cpp's release tarballs use a few layouts:
//   <root>/llama-server                          (flat — rare)
//   <root>/build/bin/llama-server                (older Linux + source)
//   <root>/llama-bNNNN/llama-server              (current Linux + Mac)
//   <root>/llama-bNNNN/build/bin/llama-server    (some hybrids)
// probe_binary tries each + one level of child dirs; the child-dir
// probe catches the `llama-bNNNN/` cases automatically.
let BIN_CANDIDATES = [
	"llama-server",
	"build/bin/llama-server",
];

fn install_root(): string {
	return install_root_for("llama-server");
}

fn find_binary(dir: string) {
	return probe_binary(dir, BIN_CANDIDATES);
}

// Compose the GitHub-releases asset URL for a (tag, flavor) pair.
// Tag is like "b9124"; flavor is one of the matrix above.
fn asset_url(tag: string, flavor: string): string {
	return "https://github.com/ggerganov/llama.cpp/releases/download/"
		+ tag + "/llama-" + tag + "-bin-" + flavor + ".tar.gz";
}

// Auto-detect the right flavor for THIS host.
export fn detect_flavor(role: string): string {
	let p = platform();
	let a = arch();
	if (p == "darwin" && a == "arm64") { return "macos-arm64"; }
	if (p == "linux" && a == "x86_64") {
		if (role == "gpu") { return "ubuntu-vulkan-x64"; }
		return "ubuntu-x64";
	}
	return null;
}

export fn current_binary_path(): string {
	return resolve_current(install_root(), BIN_CANDIDATES, ENGINE_NAME);
}

export fn init_llama_cpp_schema(db): null {
	return ensure_install_schema(db, INSTALL_TABLE);
}

export fn list_installed(): array {
	return list_installs_at(install_root(), find_binary, current_binary_path());
}

export fn activate(tag: string): string {
	flip_current(install_root(), tag, find_binary, ENGINE_NAME);
	return current_binary_path();
}

// ─── prebuilt install task ───────────────────────────────────────

async fn install_task(db, transfer_id: string, tag: string, flavor: string,
                      url: string, target_dir: string): null {
	let tarball = target_dir + ".tar.gz";

	db_exec(db, "update " + INSTALL_TABLE + " set status='downloading' where id=?",
		[transfer_id]);
	// curl, not @stdlib/http.get_binary — get_binary's redirect
	// handling for GitHub release tarballs returns status 0 / empty
	// body in some cases; curl handles the redirect chain cleanly and
	// is universally available. Tarballs are 8-100MB so -o to disk
	// keeps memory bounded.
	let r = null;
	try { r = exec_argv(["curl", "-fsSL", "-o", tarball, url]); }
	catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"curl exec failed (install curl?): " + e, 0);
		return null;
	}
	if (r.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"curl exit " + r.exit_code + ": " + (r?.stderr ?? r?.output ?? ""),
			256);
		return null;
	}

	db_exec(db, "update " + INSTALL_TABLE + " set status='extracting' where id=?",
		[transfer_id]);
	try { make_dirs(target_dir); } catch (e) { }
	let tr = null;
	try { tr = exec_argv(["tar", "-xzf", tarball, "-C", target_dir]); }
	catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"tar exec failed (install tar?): " + e, 0);
		return null;
	}
	if (tr.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"tar exit " + tr.exit_code + ": " + (tr?.stderr ?? tr?.output ?? ""),
			512);
		return null;
	}

	let bin = find_binary(target_dir);
	if (bin == null) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"extracted tarball but no llama-server binary found under "
				+ target_dir + " (tried flat, build/bin, and llama-*/ layouts)", 0);
		return null;
	}
	try { remove_file(tarball); } catch (e) { }

	let stat = null;
	try { stat = file_stat(bin); } catch (e) { }
	let now = iso_now(db);
	db_exec(db,
		"update " + INSTALL_TABLE
		+ " set status='complete', bytes_total=?, completed_at=? where id=?",
		[(stat == null ? 0 : stat.size), now, transfer_id]);
	print("[llama_cpp] " + transfer_id + " complete: " + tag + "/" + flavor);
	return null;
}

// ─── source-build task ───────────────────────────────────────────

// Translate the shared pick_backend tag into llama.cpp's cmake flags.
// llama.cpp uses the ggml-shared `GGML_*` namespace.
fn cmake_flags_for(backend: string, transfer_id: string, db): array {
	if (backend == "cuda") {
		let nvcc = detect_nvcc();
		if (nvcc == null) {
			mark_error(db, INSTALL_TABLE, transfer_id,
				"backend=cuda but nvcc not found on PATH or /usr/local/cuda/bin "
					+ "(install CUDA toolkit, or pick a different flavor)", 0);
			return null;
		}
		return [
			"-DGGML_CUDA=ON",
			"-DCMAKE_CUDA_COMPILER=" + nvcc,
			"-DCMAKE_CUDA_ARCHITECTURES=" + detect_cuda_arch(),
		];
	}
	if (backend == "vulkan") { return ["-DGGML_VULKAN=ON"]; }
	// cpu / metal: no extra flags (metal auto-enabled on darwin).
	return [];
}

async fn source_install_task(db, transfer_id: string, tag: string,
                            flavor: string, target_dir: string): null {
	db_exec(db, "update " + INSTALL_TABLE + " set status='cloning' where id=?",
		[transfer_id]);
	let cr = null;
	try {
		// llama.cpp vendors ggml in-tree — no --recursive needed.
		cr = exec_argv(["git", "clone", LLAMA_REPO, target_dir]);
	} catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"git clone exec failed (install git?): " + e, 0);
		return null;
	}
	if (cr.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"git clone exit " + cr.exit_code + ": " + (cr?.stderr ?? cr?.output ?? ""),
			400);
		return null;
	}

	let tl = tag.lower();
	if (tl != "head" && tl != "main" && tl != "master" && tl != "latest") {
		let ok = true;
		let co = null;
		try { co = exec_argv(["git", "-C", target_dir, "checkout", "-q", tag]); }
		catch (e) { ok = false; }
		if (co == null || co.exit_code != 0) { ok = false; }
		if (!ok) {
			mark_error(db, INSTALL_TABLE, transfer_id,
				"git checkout '" + tag + "' failed (not a valid ref; use a "
					+ "release tag like b9124, or 'head' for the default branch)", 0);
			return null;
		}
	}

	db_exec(db, "update " + INSTALL_TABLE + " set status='building' where id=?",
		[transfer_id]);
	let build_dir = target_dir + "/build";
	let backend = pick_backend(flavor);
	let backend_flags = cmake_flags_for(backend, transfer_id, db);
	if (backend_flags == null) { return null; }

	let cfg = ["cmake", "-S", target_dir, "-B", build_dir,
		"-DCMAKE_BUILD_TYPE=Release", "-DLLAMA_BUILD_SERVER=ON"];
	for (f in backend_flags) { cfg.push(f); }
	print("[llama_cpp] " + transfer_id + " source build backend=" + backend);

	let cf = null;
	try { cf = exec_argv(cfg); } catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake configure exec failed (install cmake?): " + e, 0);
		return null;
	}
	if (cf.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake configure exit " + cf.exit_code + ": "
				+ (cf?.stderr ?? cf?.output ?? ""), 600);
		return null;
	}

	let bf = null;
	try {
		// --target llama-server: only build the one binary we ship.
		// llama.cpp builds many examples (perplexity, embedding, quantize,
		// llama-cli, …) that we don't use here — skipping cuts build time.
		bf = exec_argv(["cmake", "--build", build_dir, "--config", "Release",
			"-j", nproc_str(), "--target", "llama-server"]);
	} catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake build exec failed: " + e, 0);
		return null;
	}
	if (bf.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake build exit " + bf.exit_code + ": "
				+ (bf?.stderr ?? bf?.output ?? ""), 600);
		return null;
	}

	let bin = find_binary(target_dir);
	if (bin == null) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"build completed but no llama-server binary found under "
				+ target_dir + " (expected build/bin/llama-server)", 0);
		return null;
	}
	try { exec_argv(["chmod", "+x", bin]); } catch (e) { }
	let stat = null;
	try { stat = file_stat(bin); } catch (e) { }
	let now = iso_now(db);
	db_exec(db,
		"update " + INSTALL_TABLE
		+ " set status='complete', bytes_total=?, completed_at=? where id=?",
		[(stat == null ? 0 : stat.size), now, transfer_id]);
	print("[llama_cpp] " + transfer_id + " source build complete: " + tag
		+ "/" + backend);
	return null;
}

// ─── HTTP handlers ───────────────────────────────────────────────

export fn make_handlers(db, rescan_caps_after): object {
	let do_install = fn(req): object {
		let payload = null;
		try { payload = parse(req?.body ?? "{}"); } catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let tag = payload?.tag;
		let flavor = payload?.flavor;
		if (tag == null) {
			return { status: 400, body: "{\"error\":\"tag required (e.g. b9124)\"}" };
		}
		if (flavor == null) {
			return { status: 400, body: "{\"error\":\"flavor required (source, or a prebuilt: ubuntu-vulkan-x64|ubuntu-x64|macos-arm64)\"}" };
		}
		let root = install_root();
		try { make_dirs(root); } catch (e) { }
		let target_dir = root + "/" + tag;
		let id = new_id(db);
		let now = iso_now(db);

		if (flavor == "source") {
			if (exists(target_dir)) {
				return { status: 409, body: stringify({
					error: "target dir already exists: " + target_dir
						+ " (remove it or pick a different tag)",
				})};
			}
			db_exec(db,
				"insert into " + INSTALL_TABLE + " "
				+ "(id, tag, flavor, source_url, target_dir, status, started_at) "
				+ "values (?, ?, ?, ?, ?, 'queued', ?)",
				[id, tag, "source", LLAMA_REPO, target_dir, now]);
			let st = spawn(source_install_task, db, id, tag, "source", target_dir);
			detach(st);
			return { status: 202, body: stringify({
				install_id: id, tag: tag, flavor: "source",
				target_dir: target_dir, mode: "source-build",
			})};
		}

		let url = asset_url(tag, flavor);
		db_exec(db,
			"insert into " + INSTALL_TABLE + " "
			+ "(id, tag, flavor, source_url, target_dir, status, started_at) "
			+ "values (?, ?, ?, ?, ?, 'queued', ?)",
			[id, tag, flavor, url, target_dir, now]);
		let t = spawn(install_task, db, id, tag, flavor, url, target_dir);
		detach(t);
		return { status: 202, body: stringify({
			install_id: id, tag: tag, flavor: flavor, target_dir: target_dir,
		})};
	};

	let do_list = fn(req): object {
		let installs = query(db,
			"select id, tag, flavor, status, bytes_total, error, started_at, completed_at "
			+ "from " + INSTALL_TABLE + " "
			+ "where status in ('queued','downloading','extracting','cloning','building') "
			+ "   or started_at > datetime('now','-1 hour') "
			+ "order by started_at desc",
			[]);
		return { status: 200, body: stringify({
			installed:    list_installed(),
			recent_jobs:  installs,
			current_path: current_binary_path(),
		})};
	};

	let do_activate = fn(req): object {
		let payload = null;
		try { payload = parse(req?.body ?? "{}"); } catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let tag = payload?.tag;
		if (tag == null) {
			return { status: 400, body: "{\"error\":\"tag required\"}" };
		}
		let new_path = null;
		try { new_path = activate(tag); } catch (e) {
			return { status: 400, body: stringify({ error: "" + e }) };
		}
		try { rescan_caps_after(); } catch (e) {
			eprint("[llama_cpp] post-activate rescan failed: " + e);
		}
		return { status: 200, body: stringify({
			tag: tag, current_path: new_path,
		})};
	};

	return { install: do_install, list: do_list, activate: do_activate };
}
