// http_server.hml — tiny HTTP/1.1 server for an internal control plane.
//
// Built on @stdlib/net.TcpListener. No keep-alive, no chunked transfer,
// no TLS. Sufficient for JSON RPC + small HTML pages on a trusted
// network. Dies on parse errors with 400.
//
// Handler shape:
//   fn handler(req: Request) -> Response
//   Request:  { method, path, headers (object), body (string) }
//   Response: { status: i32, headers?: object, body?: string,
//               stream_path?: string }
//
// Two body modes:
//   - body         in-memory string. Default. Right for JSON / HTML.
//   - stream_path  file path to stream from disk in 64KB chunks. Use
//                  for big artifacts (GGUFs) so we don't peg RAM.
//                  When set, body is ignored.
//
// Routes are matched exact path + exact method, then prefix routes
// (route.prefix == true). No glob params; handlers parse req.path
// themselves when they need a captured segment.

import { TcpListener } from "@stdlib/net";
import { open, file_stat } from "@stdlib/fs";

// Decode a buffer of UTF-8 bytes into a Hemlock string with proper
// codepoints. The naive byte-as-rune approach we used before was wrong
// for any non-ASCII content: each UTF-8 byte (e.g. 0xC3 from "é"'s
// 0xC3 0xA9 sequence) became its own rune, so the resulting string
// when re-encoded for the wire produced double-UTF-8 mojibake (the
// French chat completion "écrire" went out as "Ã©crire" and the model
// happily generated mojibake-shaped responses to match).
//
// __string_from_bytes is the runtime builtin for this; not currently
// exported through any @stdlib module wrapper.
fn buf_to_string(buf): string {
	return __string_from_bytes(buf);
}

export fn parse_request(stream): object {
	let line = stream.read_line();
	if (line == null || line.length == 0) {
		return null;
	}
	let parts = line.split(" ");
	if (parts.length < 2) {
		return null;
	}
	let method = parts[0];
	let path = parts[1];

	let headers = {};
	loop {
		let h = stream.read_line();
		if (h == null) { break; }
		let trimmed = h.trim();
		if (trimmed.length == 0) { break; }
		let colon = trimmed.find(":");
		if (colon > 0) {
			let key = trimmed.substr(0, colon).trim().to_lower();
			let value = trimmed.substr(colon + 1, trimmed.length - colon - 1).trim();
			headers[key] = value;
		}
	}

	let body = "";
	if (headers.has("content-length")) {
		let n = i32(headers["content-length"]);
		if (n > 0) {
			let buf = stream.read(n);
			body = buf_to_string(buf);
		}
	}
	return { method: method, path: path, headers: headers, body: body };
}

fn status_text(code: i32): string {
	return match (code) {
		200 => "OK",
		201 => "Created",
		204 => "No Content",
		400 => "Bad Request",
		404 => "Not Found",
		405 => "Method Not Allowed",
		500 => "Internal Server Error",
		_ => "OK",
	};
}

// Read+write loop tuned for moving GGUFs over a LAN. 64KB matches
// what curl uses by default — bigger doesn't gain meaningfully on
// gigabit, smaller wastes syscalls.
let STREAM_CHUNK_BYTES = 65536;

export fn write_response(stream, resp): null {
	let status = resp.status;
	let stream_path = resp?.stream_path;
	let headers = resp?.headers ?? {};

	if (stream_path != null) {
		// Streaming file response. Compute Content-Length from stat
		// rather than read-the-whole-thing-twice; default to
		// application/octet-stream since we use this for binary blobs.
		let stat = file_stat(stream_path);
		if (!headers.has("content-type")) {
			headers["content-type"] = "application/octet-stream";
		}
		headers["content-length"] = stat.size;
		headers["connection"] = "close";

		stream.write("HTTP/1.1 " + status + " " + status_text(status) + "\r\n");
		let keys = headers.keys();
		for (k in keys) {
			stream.write(k + ": " + headers[k] + "\r\n");
		}
		stream.write("\r\n");

		let f = open(stream_path, "r");
		loop {
			let buf = f.read_bytes(STREAM_CHUNK_BYTES);
			if (buf == null || buf.length == 0) { break; }
			stream.write(buf);
			if (buf.length < STREAM_CHUNK_BYTES) { break; }
		}
		f.close();
		return null;
	}

	let body = resp?.body ?? "";
	if (body.length > 0 && !headers.has("content-type")) {
		headers["content-type"] = "application/json";
	}
	// Content-Length is BYTES on the wire, not codepoints. body.length
	// is rune count, which under-reports for any non-ASCII content
	// (e.g. an llama-server completion response with French / Spanish
	// / emoji output) and the client truncates the body mid-stream.
	headers["content-length"] = body.byte_length;
	headers["connection"] = "close";

	stream.write("HTTP/1.1 " + status + " " + status_text(status) + "\r\n");
	let keys = headers.keys();
	for (k in keys) {
		stream.write(k + ": " + headers[k] + "\r\n");
	}
	stream.write("\r\n");
	if (body.length > 0) {
		stream.write(body);
	}
	return null;
}

// Dispatch matches exact (method, path) first; if nothing hits, falls back
// to prefix routes (route.prefix == true), letting the handler inspect
// req.path itself to extract any trailing path segments.
//
// A route with method == "*" matches any method — used by the inference
// proxy so /v1/llama/{profile}/{...} forwards GET, POST, etc. uniformly.
//
// auth_check (optional): see cp/http_server.hml — same semantics here.
export fn dispatch(req, routes, auth_check): object {
	if (req == null) {
		return { status: 400, body: "{\"error\":\"bad request\"}" };
	}
	// First pass: exact (method, path).
	for (route in routes) {
		if (route?.prefix == true) { continue; }
		let method_match = (route.method == req.method) || (route.method == "*");
		if (method_match && route.path == req.path) {
			if (auth_check != null) {
				let denied = auth_check(req, route);
				if (denied != null) { return denied; }
			}
			try {
				return route.handler(req);
			} catch (e) {
				eprint("[error] " + req.method + " " + req.path + ": " + e);
				return { status: 500, body: "{\"error\":\"internal\"}" };
			}
		}
	}
	// Second pass: prefix routes.
	for (route in routes) {
		if (route?.prefix != true) { continue; }
		let method_match = (route.method == req.method) || (route.method == "*");
		if (method_match && req.path.starts_with(route.path)) {
			if (auth_check != null) {
				let denied = auth_check(req, route);
				if (denied != null) { return denied; }
			}
			try {
				return route.handler(req);
			} catch (e) {
				eprint("[error] " + req.method + " " + req.path + ": " + e);
				return { status: 500, body: "{\"error\":\"internal\"}" };
			}
		}
	}
	return { status: 404, body: "{\"error\":\"not found\"}" };
}

// Per-accept worker. Parses, dispatches, writes, closes — all on its
// own thread so a slow handler doesn't freeze the accept loop. The
// accept-and-spawn pattern is fine for our QPS (homelab, single-digit
// concurrent requests); a real worker pool would amortize spawn cost
// at higher load but this is way below that bar.
//
// Concurrency safety relies on:
//   - sqlite (libsqlite3 is thread-safe at the connection level when
//     compiled with default mutex mode, which @stdlib/sqlite uses)
//   - models_ref / capability map: read-mostly; one writer (POST
//     /rescan) racing with readers is fine — pointer-swap of the
//     entries array is single-instruction; readers see either the
//     before or after, never a torn list
//   - PROFILES + LLM caps: read-only after boot, no contention
async fn handle_connection(stream, routes, auth_check): null {
	try {
		let req = parse_request(stream);
		let resp = dispatch(req, routes, auth_check);
		write_response(stream, resp);
	} catch (e) {
		eprint("[server] " + e);
	}
	try { stream.close(); } catch (e) { }
	return null;
}

// Serve forever on host:port. routes is array of { method, path, handler,
// public? }. auth_check is optional — see dispatch() docs.
export fn serve(host: string, port: i32, routes, auth_check): null {
	let listener = TcpListener(host, port);
	print("[http] listening on " + host + ":" + port);
	loop {
		let stream = listener.accept();
		// Detach so we don't accumulate join handles. If the handler
		// throws past its own try/catch (shouldn't, dispatch wraps),
		// the runtime swallows on the worker thread.
		let t = spawn(handle_connection, stream, routes, auth_check);
		detach(t);
	}
	return null;
}

