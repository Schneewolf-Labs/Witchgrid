// services.hml — llama-server supervisor.
//
// The "fancy llama-server wrapper" pillar of Witchgrid v0.x: profile templates
// encoding opinionated default flags (Merlina-style: 4-bit KV cache, 128K
// context, no parallel slots), posix_spawn-detached children, sqlite-tracked
// PIDs, SIGTERM-graceful shutdown.
//
// Spawn model: open the log file and /dev/null as raw fds via fs.open_fd,
// hand them to posix_spawn as stdout/stderr/stdin redirects, set setsid:true
// so the child becomes its own session leader and survives us going away.
// No shell wrapper, no argv quoting, no shell-injection surface.
//
// CUDA_VISIBLE_DEVICES: setenv on the parent immediately before spawn
// (children inherit env), unsetenv immediately after. cp.hml's HTTP loop
// is single-threaded so there's no race window.
//
// Endpoints registered by cp.hml:
//   POST /services            { profile, model, port?, gpus? }    → 201 {id,...}
//   GET  /services                                                → [ {...} ]
//   POST /services/stop       { id }                              → 204
//   GET  /profiles                                                → [profile names]

import { posix_spawn, kill } from "@stdlib/process";
import { SIGTERM } from "@stdlib/signal";
import { setenv, unsetenv } from "@stdlib/env";
import { open, open_fd, file_stat, list_dir } from "@stdlib/fs";
import { fd_close } from "@stdlib/ipc";
import { exec as db_exec, query } from "@stdlib/sqlite";
import { parse, stringify } from "@stdlib/json";
import { sleep } from "@stdlib/time";
import { render_argv } from "./intent";

// IDs come from sqlite's hex(randomblob(16)) rather than @stdlib/uuid —
// keeps us at one FFI-backed stdlib dep (libsqlite3) and avoids needing
// libcrypto. The post-#531 codegen handles two FFI libs cleanly, but one
// fewer dynamic dep on the deploy box is still worth keeping.
fn new_id(db): string {
	let r = query(db, "select hex(randomblob(16)) as id", []);
	return r[0].id;
}

// ── profiles ──────────────────────────────────────────────────────────
// Profiles live on CP since v0.7 (was a baked-in PROFILES map here
// pre-v0.7). The agent doesn't know what profiles exist anymore — it
// just runs whatever profile object CP inlines into the spawn payload.
// Same intent → argv translation via agent/intent.hml; same capability
// gating; the only thing that changed is where the source of truth
// lives.

// ── schema ────────────────────────────────────────────────────────────

export fn init_services_schema(db): null {
	db_exec(db, "create table if not exists services ("
		+ "id text primary key,"
		+ "profile text not null,"
		+ "model_path text not null,"
		+ "pid integer not null,"
		+ "port integer not null,"
		+ "log_path text not null,"
		+ "args_json text not null,"
		+ "started_at text not null"
		+ ")", []);
	// profile_version added in slice 8 of the v0.7 dashboard polish.
	// Cross-version SQLite migration: ALTER TABLE ADD COLUMN succeeds
	// against fresh DBs (column gets created normally) and against
	// existing DBs (nullable column added, old rows get NULL). Wrapped
	// in try/catch because ALTER TABLE re-running on a DB that already
	// has the column throws "duplicate column name".
	try {
		db_exec(db, "alter table services add column profile_version integer", []);
	} catch (e) { }
	// state added for orphan adoption: services rows are now
	// soft-deleted ('stopped' / 'dead') instead of removed, so when
	// the agent restarts and finds an orphan llama-server matching a
	// previously-stored row's port, we can re-adopt with the right
	// profile metadata. Defaults to 'running' for fresh inserts and
	// for migration of pre-existing rows (those should all be live;
	// reap_zombie_services will catch any that aren't on next pass).
	try {
		db_exec(db, "alter table services add column state text not null default 'running'", []);
	} catch (e) { }
	// profile_json holds the full inlined profile object so adoption
	// can rebuild the row exactly as CP originally pushed it. Nullable
	// for back-compat with rows inserted by older agents.
	try {
		db_exec(db, "alter table services add column profile_json text", []);
	} catch (e) { }
	return null;
}

// Mark stale rows as 'dead' (soft-delete) so the orphan-adoption
// path can later port-match a discovered llama-server back to the
// profile metadata that originally spawned it. Catches:
//
//   1. Process exited (crash, OOM, operator kill) — process_alive
//      returns false. Row becomes 'dead'.
//   2. PID recycled to a different process — process_alive returns
//      true but cmdline isn't llama-server. Row becomes 'dead'.
//   3. PID alive AND is one of our llama-servers — keep state.
//      This is the agent-crash-and-restart path; children survived
//      (init reparented via setsid), the row survived in sqlite,
//      reconciliation is automatic.
//
// Also prunes 'dead' rows older than ADOPTION_HISTORY_DAYS so the
// table doesn't grow forever. 7d is plenty — after a week, the
// llama-server children have almost certainly been killed by reboot.
//
// Returns the number of rows transitioned to 'dead' (for logging).
let ADOPTION_HISTORY_DAYS = 7;

export fn reap_zombie_services(db): i32 {
	let rows = query(db,
		"select id, pid from services where state = 'running'", []);
	let reaped = 0;
	for (row in rows) {
		let drop = false;
		if (!process_alive(row.pid)) {
			drop = true;
		} else if (!is_our_llama_server(row.pid)) {
			drop = true;
		}
		if (drop) {
			db_exec(db,
				"update services set state = 'dead' where id = ?",
				[row.id]);
			reaped = reaped + 1;
		}
	}
	// Prune ancient soft-deleted rows. Keep enough recent history
	// for adoption to work across the kinds of restart windows that
	// happen during normal ops (CP upgrades, agent bounces).
	db_exec(db,
		"delete from services where state in ('dead', 'stopped') "
		+ "and started_at < datetime('now', ?)",
		["-" + ADOPTION_HISTORY_DAYS + " days"]);
	return reaped;
}

// True iff /proc/<pid>/cmdline names a llama-server binary. Used by
// reap_zombie_services to detect PID recycling (alive process at the
// stored pid that ISN'T one of our llama-servers).
fn is_our_llama_server(pid: i32): bool {
	try {
		let f = open("/proc/" + pid + "/cmdline", "r");
		let content = f.read();
		f.close();
		if (content == null || content.length == 0) { return false; }
		// argv[0] is the first nul-terminated string. Look for either
		// "llama-server" anywhere in the leading segment (covers both
		// `/usr/local/bin/llama-server` absolute paths and bare names).
		let nul = content.find("\0");
		let head = nul > 0 ? content.substr(0, nul) : content;
		return head.find("llama-server") >= 0;
	} catch (e) {
		return false;
	}
}

// Walk own-uid llama-server processes and emit a log line for any
// not currently represented in the services table. Doesn't auto-
// adopt — without the original profile/intent metadata we can't
// fabricate a matching services row that would survive a witchgrid
// upgrade. But surfacing them at boot lets the operator see "hey,
// these are here, decide whether to claim or kill."
//
// Uses `pgrep -af llama-server` rather than nvidia-smi: CPU-only
// services (gpu_layers=0) don't appear in nvidia-smi compute apps,
// and we want to catch those too.
// On boot, walk same-uid llama-server processes and reconcile them
// with our services table. Three outcomes per discovered process:
//
//   - Already running in our table (PID match) → no-op
//   - Port matches a soft-deleted row (state in 'dead'/'stopped')
//     and the row has profile_json → ADOPT: update pid, flip state
//     back to 'running'. The service is now under our wing again.
//   - No port match anywhere → log [orphan] and leave alone. We
//     have no profile metadata to reconstruct it; operator decides.
//
// This is the "agent crashed mid-flight, children survived" recovery
// path: the row was preserved in sqlite (because reap soft-deletes
// rather than hard-deletes), the child kept running, and now we
// stitch them back together by port.
export fn discover_orphan_llama_servers(db, our_uid: i32): null {
	let r = null;
	try {
		r = exec_argv(["pgrep", "-u", "" + our_uid, "-f", "llama-server"]);
	} catch (e) { return null; }
	if (r.output.length == 0) { return null; }

	// PIDs already running in our table — skip.
	let known = {};
	let owned = query(db,
		"select pid from services where state = 'running'", []);
	for (o in owned) { known["" + o.pid] = true; }

	let lines = r.output.split("\n");
	for (line in lines) {
		let pid_str = line.trim();
		if (pid_str.length == 0) { continue; }
		let pid = i32(pid_str);
		if (!is_our_llama_server(pid)) { continue; }
		if (known.has("" + pid)) { continue; }
		if (!is_our_uid(pid, our_uid)) { continue; }
		let port_str = read_arg_after(pid, "--port");
		let model = read_arg_after(pid, "-m");
		if (port_str == null) {
			print("[orphan] pid " + pid + " no --port in argv, can't adopt");
			continue;
		}
		let port = i32(port_str);

		// Find the most recent soft-deleted row with this port +
		// matching model_path (if we know the model). Model match
		// guards against the case where the operator stopped one
		// service, started a different one on the same port, then
		// the agent crashed — we don't want to adopt the new one
		// into the old one's profile slot.
		let candidates = query(db,
			"select id, profile, port, profile_json, profile_version "
			+ "from services where state in ('dead', 'stopped') and port = ? "
			+ "and (model_path = ? or model_path is null) "
			+ "order by started_at desc limit 1",
			[port, model ?? ""]);
		if (candidates.length == 0) {
			print("[orphan] pid " + pid + " port=" + port
				+ " model=" + (model ?? "?")
				+ " — running but no matching history row. "
				+ "Kill manually or spawn a fresh service for the same profile.");
			continue;
		}
		let cand = candidates[0];
		// Adopt: bind the new pid to the historical row, flip back
		// to 'running'. The profile_json on the row already carries
		// everything CP needs to recognize this service.
		db_exec(db,
			"update services set pid = ?, state = 'running' where id = ?",
			[pid, cand.id]);
		print("[adopt] pid " + pid + " port=" + port + " profile="
			+ cand.profile + " v" + cand.profile_version
			+ " — re-attached to historical row " + cand.id.substr(0, 8) + "…");
	}
	return null;
}

// sd-server (stable-diffusion.cpp) orphan reconciliation. Parallel to
// discover_orphan_llama_servers — same crash-recovery contract — but
// matches the sd-server binary and reads the bind port from
// --listen-port (sd-server's flag) instead of --port.
fn is_our_sd_server(pid: i32): bool {
	try {
		let f = open("/proc/" + pid + "/cmdline", "r");
		let content = f.read();
		f.close();
		if (content == null || content.length == 0) { return false; }
		let nul = content.find("\0");
		let head = nul > 0 ? content.substr(0, nul) : content;
		return head.find("sd-server") >= 0;
	} catch (e) {
		return false;
	}
}

export fn discover_orphan_sd_servers(db, our_uid: i32): null {
	let r = null;
	try {
		r = exec_argv(["pgrep", "-u", "" + our_uid, "-f", "sd-server"]);
	} catch (e) { return null; }
	if (r.output.length == 0) { return null; }

	let known = {};
	let owned = query(db,
		"select pid from services where state = 'running'", []);
	for (o in owned) { known["" + o.pid] = true; }

	let lines = r.output.split("\n");
	for (line in lines) {
		let pid_str = line.trim();
		if (pid_str.length == 0) { continue; }
		let pid = i32(pid_str);
		if (!is_our_sd_server(pid)) { continue; }
		if (known.has("" + pid)) { continue; }
		if (!is_our_uid(pid, our_uid)) { continue; }
		let port_str = read_arg_after(pid, "--listen-port");
		let model = read_arg_after(pid, "-m");
		if (port_str == null) {
			print("[orphan] sd pid " + pid + " no --listen-port in argv, can't adopt");
			continue;
		}
		let port = i32(port_str);

		let candidates = query(db,
			"select id, profile, port, profile_json, profile_version "
			+ "from services where state in ('dead', 'stopped') and port = ? "
			+ "and (model_path = ? or model_path is null) "
			+ "order by started_at desc limit 1",
			[port, model ?? ""]);
		if (candidates.length == 0) {
			print("[orphan] sd pid " + pid + " port=" + port
				+ " model=" + (model ?? "?")
				+ " — running but no matching history row. "
				+ "Kill manually or spawn a fresh service for the same profile.");
			continue;
		}
		let cand = candidates[0];
		db_exec(db,
			"update services set pid = ?, state = 'running' where id = ?",
			[pid, cand.id]);
		print("[adopt] sd pid " + pid + " port=" + port + " profile="
			+ cand.profile + " v" + cand.profile_version
			+ " — re-attached to historical row " + cand.id.substr(0, 8) + "…");
	}
	return null;
}

fn is_our_uid(pid: i32, our_uid: i32): bool {
	try {
		let s = exec_argv(["stat", "-c", "%u", "/proc/" + pid]);
		if (s.exit_code != 0) { return false; }
		return i32(s.output.trim()) == our_uid;
	} catch (e) { return false; }
}

// Read /proc/<pid>/cmdline, find the named arg, return its value
// (the next argv element). Null when not found or unreadable.
//
// cmdline is nul-separated argv. Use file.read_binary (Hemlock 2.4.1+)
// to get the raw bytes intact, walk to find 0x00 boundaries, slice
// out each segment as a string. The pre-2.4.1 workaround was a
// `tr '\0' '\n'` shellout because file.read() truncated at the first
// nul byte.
fn read_arg_after(pid: i32, name: string) {
	try {
		let f = open("/proc/" + pid + "/cmdline", "r");
		let buf = f.read_binary();
		f.close();
		if (buf == null || buf.length == 0) { return null; }

		// Walk bytes, slice each nul-bounded segment into argv. We only
		// need to find one match so we could short-circuit on the first
		// `name` hit, but a full pass is microseconds for typical
		// cmdlines (< 1 KB) — readability wins.
		let argv = [];
		let start: i32 = 0;
		let i: i32 = 0;
		while (i < buf.length) {
			if (buf[i] == 0) {
				let sub = buf.slice(start, i);
				argv.push(__string_from_bytes(sub));
				start = i + 1;
			}
			i = i + 1;
		}

		let j: i32 = 0;
		while (j < argv.length - 1) {
			if (argv[j] == name) { return argv[j + 1]; }
			j = j + 1;
		}
	} catch (e) { }
	return null;
}

// ── helpers ───────────────────────────────────────────────────────────

fn iso_now(db): string {
	let r = query(db, "select datetime('now') as ts", []);
	return r[0].ts;
}

// kill(pid, 0) returns success for zombie processes (process exited but
// not yet reaped), which makes it useless for "is this child still doing
// work?" checks. Read /proc/<pid>/status and parse the State: line —
// Z (zombie), X (dead), T (stopped) all mean "not alive" for placement
// purposes. Linux-specific; portability hit if we ever support macOS
// agents (waitpid(pid, WNOHANG) would be the cross-platform answer
// once Hemlock 2.2.x is settled).
fn process_alive(pid: i32): bool {
	try {
		let f = open("/proc/" + pid + "/status", "r");
		let content = f.read();
		f.close();
		if (content == null || content.length == 0) { return false; }
		let idx = content.find("State:");
		if (idx < 0) { return false; }
		let i = idx + 6;
		while (i < content.length) {
			let c = content[i];
			if (c != ' ' && c != '\t') { break; }
			i = i + 1;
		}
		if (i >= content.length) { return false; }
		let state = content[i];
		return state != 'Z' && state != 'X' && state != 'T';
	} catch (e) {
		return false;
	}
}

// Read up to `max_bytes` from the end of a file. Best-effort — returns
// empty string on any error so callers can use it inline without their
// own try/catch (we use this in the spawn-failed error path; the original
// failure is the interesting bit, not whether we could read its log).
fn read_log_tail(path: string, max_bytes: i32): string {
	try {
		let stat = file_stat(path);
		let f = open(path, "r");
		let start = 0;
		if (stat.size > max_bytes) { start = i32(stat.size) - max_bytes; }
		f.seek(start);
		let content = f.read();
		f.close();
		if (content == null) { return ""; }
		return content;
	} catch (e) {
		return "";
	}
}

// How long to wait before deciding the child crashed-on-launch.
//
// Choosing this is a tradeoff. Too short and we false-pass spawns that
// will fail their socket bind a moment later (llama-server runs CUDA
// init *before* binding, which on a multi-GPU box takes ~1s — we get
// past the grace check, then bind fails, then we've already returned
// 201). Too long and we tax every successful spawn with that latency.
//
// 2.0s is empirical: covers post-CUDA-init bind failures on schneewolf
// (4× 4060 Ti, ~1s CUDA enumeration) with margin, while a successful
// 12B model spawn takes 15-30s of mmap + GPU upload, so the grace is
// noise on top.
let SPAWN_FAILURE_GRACE_SECONDS = 2.0;

// Multimodal autoload: a llama.cpp vision model is a normal chat GGUF
// plus a separate projector (mmproj) GGUF. The catalog can't track the
// mmproj (no arch metadata — same reason SD ggufs are skipped), so we
// pair it here from the model's own directory: any sibling whose name
// contains "mmproj" and ends .gguf. Prefer f16 (projector is small;
// quantizing it costs vision quality for ~no VRAM — same principle as
// keeping the KV cache f16), then q8, then whatever's there. Returns
// the absolute mmproj path or null. An explicit --mmproj in the
// profile's extra_flags overrides this (checked at the call site).
fn find_mmproj_sibling(model_path: string) {
	let li = -1;
	let i = 0;
	while (i < model_path.length) {
		if (model_path.substr(i, 1) == "/") { li = i; }
		i = i + 1;
	}
	if (li < 0) { return null; }
	let dir = model_path.substr(0, li);
	let entries = null;
	try { entries = list_dir(dir); } catch (e) { return null; }
	let f16 = null;
	let q8 = null;
	let any = null;
	for (name in entries) {
		let ln = name.lower();
		if (ln.find("mmproj") < 0) { continue; }
		if (name.length < 5) { continue; }
		if (name.substr(name.length - 5, 5) != ".gguf") { continue; }
		let full = dir + "/" + name;
		if (any == null) { any = full; }
		if (f16 == null && ln.find("f16") >= 0) { f16 = full; }
		if (q8 == null && ln.find("q8") >= 0) { q8 = full; }
	}
	if (f16 != null) { return f16; }
	if (q8 != null) { return q8; }
	return any;
}

// ── core: spawn ───────────────────────────────────────────────────────

export fn spawn_service(db, profile_name: string, prof, model_path: string, port: i32, gpus, tensor_split, capabilities, binary_path: string): object {
	if (prof == null) {
		throw "spawn_service called without a profile object — "
			+ "v0.7+ requires CP to inline the profile in the spawn payload";
	}

	// Build full argv: binary + intent-derived flags + extras + spawner-set
	// model/port/host. capabilities is the parsed --help map for prof.binary
	// — passed in rather than re-introspected per spawn.
	//
	// binary_path is the resolved on-disk binary (or bare name for PATH
	// lookup) provided by agent.hml's caller — comes from
	// llama_cpp.current_binary_path() since v0.7 C2 so a Witchgrid-
	// managed install is honored.
	// sd-server (stable-diffusion.cpp) is a second engine with a
	// different CLI surface: image profiles carry an empty intent map
	// (no context/kv/gpu-layers concepts) + extra_flags only, and the
	// bind flags are -l/--listen-port, not --host/--port. It also has
	// no --tensor-split. Branch on the profile's declared binary.
	let is_sd = (prof?.binary == "sd-server");

	// The caps-empty guard exists because llama profiles render intents
	// against the parsed --help map; an empty map means a broken/missing
	// binary. sd-server image profiles render no intents, so an empty
	// caps map is benign there — skip the guard for sd-server.
	if (!is_sd && (capabilities == null || capabilities.keys().length == 0)) {
		throw "agent has no parsed capabilities for " + prof.binary
			+ " (introspection may have failed at boot — check agent log)";
	}
	let argv = [binary_path];
	let derived = render_argv(prof?.intent ?? {}, prof?.extra_flags ?? [],
		capabilities ?? {});
	for (a in derived) { argv.push(a); }
	argv.push("-m"); argv.push(model_path);
	if (is_sd) {
		argv.push("--listen-port"); argv.push("" + port);
		argv.push("-l"); argv.push("0.0.0.0");
	} else {
		argv.push("--port"); argv.push("" + port);
		argv.push("--host"); argv.push("0.0.0.0");

		// Multimodal autoload (llama-server only). If the model has a
		// co-located mmproj projector and the profile didn't already
		// pin one explicitly, pass it so vision "just works" off a
		// normal chat profile pointing at a VL model.
		let has_explicit_mmproj = false;
		for (f in (prof?.extra_flags ?? [])) {
			if (f == "--mmproj") { has_explicit_mmproj = true; }
		}
		if (!has_explicit_mmproj) {
			let mmproj = find_mmproj_sibling(model_path);
			if (mmproj != null) {
				argv.push("--mmproj"); argv.push(mmproj);
				print("[spawn] mmproj autoloaded: " + mmproj);
			}
		}
	}

	// Multi-GPU tensor-parallel split. We only emit --tensor-split when
	// CP told us to — for single-GPU spawns the flag isn't needed (or
	// meaningful), and for multi-GPU pinned spawns where CP didn't
	// compute weights, we leave llama-server to its default equal-split.
	//
	// Capability gate: if the binary doesn't expose --tensor-split (very
	// old llama.cpp or a CPU-only build), fail loud rather than silently
	// shipping a malformed argv. The placement decision was made on the
	// assumption tensor-split would work; if it can't, the operator
	// needs to know.
	if (!is_sd && tensor_split != null && tensor_split.length > 1) {
		if (!capabilities.has("tensor-split")) {
			throw "binary does not support --tensor-split but CP placed a "
				+ "multi-GPU spawn (" + tensor_split.length + " GPUs). "
				+ "Either upgrade llama.cpp on this node or pin to a "
				+ "single GPU.";
		}
		let csv = "";
		let i = 0;
		while (i < tensor_split.length) {
			if (i > 0) { csv = csv + ","; }
			csv = csv + tensor_split[i];
			i = i + 1;
		}
		// Use the binary's actual short form when present (typically -ts).
		let ts_cap = capabilities["tensor-split"];
		let ts_flag = "--tensor-split";
		if (ts_cap?.short != null) { ts_flag = ts_cap.short; }
		argv.push(ts_flag);
		argv.push(csv);
	}

	let id = new_id(db);
	let log_path = "/tmp/witchgrid-" + id + ".log";

	// Open the log file (truncate) and /dev/null (read) as raw fds so
	// posix_spawn can dup2 them onto the child's std{in,out,err}.
	let log_fd = open_fd(log_path, "w");
	let null_fd = open_fd("/dev/null", "r");

	// CUDA_VISIBLE_DEVICES via setenv around the spawn. posix_spawn's `env`
	// opt would *replace* the parent env (losing PATH/HOME/etc), so we
	// mutate the parent env transiently instead — children inherit, then
	// we restore. Safe because cp.hml is single-threaded.
	//
	// Three placement modes:
	//   pinned (gpus.length > 0)              → CVD = "0,2"   pick GPUs
	//   cpu_only (gpu_layers=0, gpus empty)   → CVD = ""      hide all GPUs
	//                                                           so flash_attn
	//                                                           can't grab one
	//   neither (auto, no constraint)          → CVD untouched (child sees all)
	let pinned   = (gpus != null && gpus.length > 0);
	let cpu_only = (!pinned && prof?.intent?.gpu_layers == 0);
	if (pinned) {
		let csv = "";
		let g = 0;
		while (g < gpus.length) {
			if (g > 0) { csv = csv + ","; }
			csv = csv + gpus[g];
			g = g + 1;
		}
		setenv("CUDA_VISIBLE_DEVICES", csv);
	} else if (cpu_only) {
		setenv("CUDA_VISIBLE_DEVICES", "");
	}

	// sd-server can't find libstable-diffusion.so on its own: the
	// upstream prebuilt's RUNPATH is the dead GitHub-Actions build dir
	// (no $ORIGIN), and even a source build keeps the lib next to the
	// binary rather than in a system path. Point LD_LIBRARY_PATH at the
	// binary's own directory so the co-located .so (and any ggml libs)
	// resolve. Same transient-parent-env trick as CUDA_VISIBLE_DEVICES.
	// The agent's launch env doesn't set LD_LIBRARY_PATH, so a plain
	// set→unset (no prior-value restore) is safe here.
	if (is_sd) {
		let li = -1;
		let bi = 0;
		while (bi < binary_path.length) {
			if (binary_path.substr(bi, 1) == "/") { li = bi; }
			bi = bi + 1;
		}
		let libdir = li >= 0 ? binary_path.substr(0, li) : ".";
		setenv("LD_LIBRARY_PATH", libdir);
	}

	let result = posix_spawn(argv, {
		stdin: null_fd,
		stdout: log_fd,
		stderr: log_fd,
		setsid: true,
	});

	if (pinned || cpu_only) {
		unsetenv("CUDA_VISIBLE_DEVICES");
	}
	if (is_sd) {
		unsetenv("LD_LIBRARY_PATH");
	}
	fd_close(log_fd);
	fd_close(null_fd);

	let pid = result.pid;
	if (pid <= 0) {
		throw "posix_spawn returned invalid pid: " + pid;
	}

	// Did the child immediately exit? Common causes: contended port,
	// missing model file, missing CUDA runtime, malformed args. Without
	// this check, we'd return 201 + a pid that's already a zombie, and
	// the caller wouldn't know until the next /v1/llama/* request fails
	// or the next agent /services list shows alive=false. Surface it now.
	sleep(SPAWN_FAILURE_GRACE_SECONDS);
	if (!process_alive(pid)) {
		let tail = read_log_tail(log_path, 4096);
		let msg = "spawn died immediately (pid " + pid + " exited within "
			+ SPAWN_FAILURE_GRACE_SECONDS + "s)";
		if (tail.length > 0) {
			msg = msg + "; log tail:\n" + tail;
		} else {
			msg = msg + " (no log output captured at " + log_path + ")";
		}
		throw msg;
	}

	let now = iso_now(db);
	// profile_version comes from CP's all_profiles_map() which stamps
	// __version onto the inlined profile object. Captured at spawn time
	// so the dashboard can flag a "stale" badge if the operator edits
	// the profile after the service is already running.
	let pv = prof?.__version;
	// profile_json holds the full inlined profile so adoption can
	// rebuild the row exactly when an orphan is discovered after
	// agent restart with sqlite intact OR after sqlite wipe (when
	// adoption falls back to log-only because no row exists at all).
	let pjson = stringify(prof);
	db_exec(db,
		"insert into services (id, profile, model_path, pid, port, log_path, args_json, started_at, profile_version, profile_json, state) "
		+ "values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'running')",
		[id, profile_name, model_path, pid, port, log_path, stringify(argv), now, pv, pjson]);

	return {
		id: id,
		profile: profile_name,
		model_path: model_path,
		pid: pid,
		port: port,
		log_path: log_path,
		started_at: now,
		profile_version: pv,
	};
}

export fn list_services(db): array {
	// Filter to running rows so the dashboard doesn't show every
	// historical spawn. Adoption-history rows (state in 'dead' /
	// 'stopped') are kept around for the discovery path but not
	// surfaced to operators.
	let rows = query(db,
		"select id, profile, model_path, pid, port, log_path, started_at, profile_version "
		+ "from services where state = 'running' order by started_at desc", []);
	let out = [];
	for (row in rows) {
		out.push({
			id: row.id,
			profile: row.profile,
			model_path: row.model_path,
			pid: row.pid,
			port: row.port,
			log_path: row.log_path,
			started_at: row.started_at,
			profile_version: row?.profile_version,
			alive: process_alive(row.pid),
		});
	}
	return out;
}

export fn stop_service(db, id: string): bool {
	let rows = query(db,
		"select pid from services where id = ? and state = 'running'", [id]);
	if (rows.length == 0) {
		return false;
	}
	let pid = rows[0].pid;
	if (process_alive(pid)) {
		try { kill(pid, SIGTERM); } catch (e) { /* race with exit; fine */ }
	}
	// Soft-delete: keep the row so adoption can match by port if the
	// operator later restarts the service with the same profile and
	// the previous llama-server hadn't yet exited.
	db_exec(db, "update services set state = 'stopped' where id = ?", [id]);
	return true;
}

// ── HTTP handlers ─────────────────────────────────────────────────────

// reserved_ports: ports the agent must refuse to spawn services on,
// regardless of who asks. The agent's own listen port is the obvious
// one — letting an llama-server land there is how schneewolf orphaned
// itself last session (a stray auto-spawn took 8766, agent restart
// then couldn't bind, ssh-and-pkill required to recover).
//
// capabilities_for: function `(binary_name) → caps_map` so each spawn
// can resolve its profile's intents against the right binary's --help
// map. Passed as a closure so the agent can refresh on its own schedule
// without us shipping a stale snapshot here.
export fn make_handlers(db, reserved_ports, capabilities_for, binary_path_for): object {
	return {
		create: fn(req): object {
			let payload = parse(req.body);
			// Since v0.7 CP inlines the profile object as `profile`,
			// with the human-friendly name in `profile_name`. The
			// agent doesn't have its own PROFILES map anymore.
			let profile = payload?.profile;
			let profile_name = payload?.profile_name;
			let model = payload?.model;
			if (profile == null || model == null) {
				return { status: 400, body: "{\"error\":\"profile+model required (CP must inline profile object since v0.7)\"}" };
			}
			if (profile_name == null) { profile_name = "<unnamed>"; }
			let port = payload?.port;
			if (port == null) { port = profile?.default_port; }
			if (port == null) {
				return { status: 400, body: "{\"error\":\"port required (profile has no default_port)\"}" };
			}
			// Refuse to bind on reserved ports. Caller (CP's pick_port)
			// should never send one of these, but defense in depth.
			let i = 0;
			while (i < reserved_ports.length) {
				if (port == reserved_ports[i]) {
					return { status: 409, body: stringify({
						error: "port " + port + " is reserved by the agent itself",
					})};
				}
				i = i + 1;
			}
			let gpus = payload?.gpus ?? [];
			let tensor_split = payload?.tensor_split;
			try {
				let caps = capabilities_for(profile.binary);
				let bin = binary_path_for(profile.binary);
				let svc = spawn_service(db, profile_name, profile, model, port, gpus, tensor_split, caps, bin);
				return { status: 201, body: stringify(svc) };
			} catch (e) {
				// 502 vs 400: a port-bind / missing-model / OOM error from
				// llama-server is upstream failure (502), not a client-input
				// error. The "spawn died immediately" prefix is the marker.
				let msg = "" + e;
				let status = 400;
				if (msg.find("spawn died") >= 0) { status = 502; }
				return { status: status, body: stringify({ error: msg }) };
			}
		},
		list: fn(req): object {
			return { status: 200, body: stringify(list_services(db)) };
		},
		stop: fn(req): object {
			let payload = parse(req.body);
			let id = payload?.id;
			if (id == null) {
				return { status: 400, body: "{\"error\":\"id required\"}" };
			}
			let ok = stop_service(db, id);
			if (!ok) {
				return { status: 404, body: "{\"error\":\"not found\"}" };
			}
			return { status: 204, body: "" };
		},
		// /profiles handler removed in v0.7 — profiles live on CP.
		// agent.hml dropped its registration; this stub stays so the
		// handlers map shape doesn't break callers expecting `.profiles`.
		profiles: fn(req): object {
			return { status: 410, body: stringify({
				error: "agent /profiles gone in v0.7 — see CP /api/profiles",
			})};
		},
		// GET /services/log/{id} → tail of the per-service log file.
		// 32KB cap so a single response doesn't dump multi-MB inference
		// logs. Returns plain text (Content-Type: text/plain) so the
		// dashboard can show it raw without JSON-decoding noise.
		log: fn(req): object {
			let prefix = "/services/log/";
			let id = req.path.substr(prefix.length, req.path.length - prefix.length);
			if (id == null || id.length == 0) {
				return { status: 400, body: "{\"error\":\"id required\"}" };
			}
			let rows = query(db,
				"select log_path from services where id = ?", [id]);
			if (rows.length == 0) {
				return { status: 404, body: "{\"error\":\"no such service\"}" };
			}
			let tail = read_log_tail(rows[0].log_path, 32768);
			return { status: 200, body: tail,
				headers: { "content-type": "text/plain; charset=utf-8" } };
		},
	};
}
