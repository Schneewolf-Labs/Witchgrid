// services.hml — llama-server supervisor.
//
// The "fancy llama-server wrapper" pillar of Witchgrid v0.x: profile templates
// encoding opinionated default flags (Merlina-style: 4-bit KV cache, 128K
// context, no parallel slots), posix_spawn-detached children, sqlite-tracked
// PIDs, SIGTERM-graceful shutdown.
//
// Spawn model: open the log file and /dev/null as raw fds via fs.open_fd,
// hand them to posix_spawn as stdout/stderr/stdin redirects, set setsid:true
// so the child becomes its own session leader and survives us going away.
// No shell wrapper, no argv quoting, no shell-injection surface.
//
// CUDA_VISIBLE_DEVICES: setenv on the parent immediately before spawn
// (children inherit env), unsetenv immediately after. cp.hml's HTTP loop
// is single-threaded so there's no race window.
//
// Endpoints registered by cp.hml:
//   POST /services            { profile, model, port?, gpus? }    → 201 {id,...}
//   GET  /services                                                → [ {...} ]
//   POST /services/stop       { id }                              → 204
//   GET  /profiles                                                → [profile names]

import { posix_spawn, kill } from "@stdlib/process";
import { SIGTERM } from "@stdlib/signal";
import { setenv, unsetenv } from "@stdlib/env";
import { open, open_fd, file_stat } from "@stdlib/fs";
import { fd_close } from "@stdlib/ipc";
import { exec as db_exec, query } from "@stdlib/sqlite";
import { parse, stringify } from "@stdlib/json";
import { sleep } from "@stdlib/time";

// IDs come from sqlite's hex(randomblob(16)) rather than @stdlib/uuid —
// keeps us at one FFI-backed stdlib dep (libsqlite3) and avoids needing
// libcrypto. The post-#531 codegen handles two FFI libs cleanly, but one
// fewer dynamic dep on the deploy box is still worth keeping.
fn new_id(db): string {
	let r = query(db, "select hex(randomblob(16)) as id", []);
	return r[0].id;
}

// ── profiles ──────────────────────────────────────────────────────────
// Encode the Merlina-style defaults. These are the *whole point* of v0.x:
// no consumer should ever have to remember `--cache-type-k q4_0`.
//
// `context` and `kv_type` are duplicated from the flags array because
// CP needs them as structured data for placement (max-VRAM math). The
// flags array remains the source of truth for what we actually exec.
// If you change one, change the other — small-enough surface to hand-sync.
//
// `default_model` is opt-in. When set, CP's routing API can auto-spawn
// the profile on first request (POST /v1/llama/{profile}/completion
// without a prior explicit POST /services). Set per-deployment because
// the path is operator-specific. NULL means "explicit POST /services
// required to bring this profile up." Future: read from a config file
// or env so the binary doesn't carry deployment paths.

let PROFILES = {
	// 128K context, 4-bit KV cache (chat hot path; quality unchanged at
	// this quant for most chat workloads). Single slot — RP models hate
	// slot-shared sampler state.
	"chat-mahou": {
		binary: "llama-server",
		flags: ["-c", "131072",
				"--cache-type-k", "q4_0",
				"--cache-type-v", "q4_0",
				"-np", "1",
				"-ngl", "99",
				"-fa", "on"],
		default_port: 8080,
		context: 131072,
		kv_type: "q4_0",
		default_model: "/mnt/BALTEUS/gguf_models/mahou-1.5-mistral-nemo-12b.Q5_K_M.gguf",
	},

	// CPU profile — Q8 KV (quality > speed for grammar-constrained
	// design pass), tighter context (designer prompts are short).
	"designer-cpu": {
		binary: "llama-server",
		flags: ["-c", "8192",
				"--cache-type-k", "q8_0",
				"--cache-type-v", "q8_0"],
		default_port: 8081,
		context: 8192,
		kv_type: "q8_0",
		default_model: null,
	},

	// Memory pipeline (Phoenix-style): JSON-mode capable, mid-context.
	"memory-phoenix": {
		binary: "llama-server",
		flags: ["-c", "32768",
				"--cache-type-k", "q4_0",
				"--cache-type-v", "q4_0",
				"-ngl", "99",
				"-fa", "on"],
		default_port: 8085,
		context: 32768,
		kv_type: "q4_0",
		default_model: null,
	},
};

// ── schema ────────────────────────────────────────────────────────────

export fn init_services_schema(db): null {
	db_exec(db, "create table if not exists services ("
		+ "id text primary key,"
		+ "profile text not null,"
		+ "model_path text not null,"
		+ "pid integer not null,"
		+ "port integer not null,"
		+ "log_path text not null,"
		+ "args_json text not null,"
		+ "started_at text not null"
		+ ")", []);
	return null;
}

// ── helpers ───────────────────────────────────────────────────────────

fn iso_now(db): string {
	let r = query(db, "select datetime('now') as ts", []);
	return r[0].ts;
}

// kill(pid, 0) returns success for zombie processes (process exited but
// not yet reaped), which makes it useless for "is this child still doing
// work?" checks. waitpid(pid, WNOHANG) would reap and tell us truthfully,
// but calling Hemlock's waitpid from this code path crashed the agent
// process with `longjmp causes uninitialized stack frame` — likely an
// interaction with the async heartbeat task's setjmp context. Workaround:
// read /proc/<pid>/status, parse the State: line, treat Z (zombie) and
// X (dead) as "not alive". Linux-specific; portability hit if we ever
// support macOS agents.
//
// Two Hemlock subtleties worth knowing if this code surprises you:
//   1. f.read() (no args) returns "" on /proc files because their stat
//      size is 0 — must pass an explicit max-bytes for /proc reads.
//   2. string[i] returns a rune, not a string. `c != " "` is always true
//      (compares rune to string, mismatched types). Use rune literals
//      with single quotes: `c != ' '`. Compiler warns on the mismatch
//      but it's silent in the interpreter — easy to miss.
fn process_alive(pid: i32): bool {
	try {
		let f = open("/proc/" + pid + "/status", "r");
		let content = f.read(2048);
		f.close();
		if (content == null || content.length == 0) { return false; }
		let idx = content.find("State:");
		if (idx < 0) { return false; }
		// Walk past "State:" + whitespace to the state character.
		let i = idx + 6;
		while (i < content.length) {
			let c = content[i];
			if (c != ' ' && c != '\t') { break; }
			i = i + 1;
		}
		if (i >= content.length) { return false; }
		let state = content[i];
		// R(unning), S(leeping), D(uninterruptible), I(idle) → alive.
		// Z(ombie), X(dead), T(stopped) → not alive for our purposes.
		return state != 'Z' && state != 'X' && state != 'T';
	} catch (e) {
		// /proc/<pid>/status missing → process gone.
		return false;
	}
}

// Read up to `max_bytes` from the end of a file. Best-effort — returns
// empty string on any error so callers can use it inline without their
// own try/catch (we use this in the spawn-failed error path; the original
// failure is the interesting bit, not whether we could read its log).
fn read_log_tail(path: string, max_bytes: i32): string {
	try {
		let stat = file_stat(path);
		let f = open(path, "r");
		let start = 0;
		if (stat.size > max_bytes) { start = i32(stat.size) - max_bytes; }
		f.seek(start);
		let content = f.read();
		f.close();
		if (content == null) { return ""; }
		return content;
	} catch (e) {
		return "";
	}
}

// How long to wait before deciding the child crashed-on-launch.
//
// Choosing this is a tradeoff. Too short and we false-pass spawns that
// will fail their socket bind a moment later (llama-server runs CUDA
// init *before* binding, which on a multi-GPU box takes ~1s — we get
// past the grace check, then bind fails, then we've already returned
// 201). Too long and we tax every successful spawn with that latency.
//
// 2.0s is empirical: covers post-CUDA-init bind failures on schneewolf
// (4× 4060 Ti, ~1s CUDA enumeration) with margin, while a successful
// 12B model spawn takes 15-30s of mmap + GPU upload, so the grace is
// noise on top.
let SPAWN_FAILURE_GRACE_SECONDS = 2.0;

// ── core: spawn ───────────────────────────────────────────────────────

export fn spawn_service(db, profile_name: string, model_path: string, port: i32, gpus): object {
	if (!PROFILES.has(profile_name)) {
		throw "unknown profile: " + profile_name;
	}
	let prof = PROFILES[profile_name];

	// Build full argv: binary + profile flags + -m model + --port port
	let argv = [prof.binary];
	let i = 0;
	while (i < prof.flags.length) {
		argv.push(prof.flags[i]);
		i = i + 1;
	}
	argv.push("-m"); argv.push(model_path);
	argv.push("--port"); argv.push("" + port);
	argv.push("--host"); argv.push("0.0.0.0");

	let id = new_id(db);
	let log_path = "/tmp/witchgrid-" + id + ".log";

	// Open the log file (truncate) and /dev/null (read) as raw fds so
	// posix_spawn can dup2 them onto the child's std{in,out,err}.
	let log_fd = open_fd(log_path, "w");
	let null_fd = open_fd("/dev/null", "r");

	// CUDA_VISIBLE_DEVICES via setenv around the spawn. posix_spawn's `env`
	// opt would *replace* the parent env (losing PATH/HOME/etc), so we
	// mutate the parent env transiently instead — children inherit, then
	// we restore. Safe because cp.hml is single-threaded.
	let pinned = (gpus != null && gpus.length > 0);
	if (pinned) {
		let csv = "";
		let g = 0;
		while (g < gpus.length) {
			if (g > 0) { csv = csv + ","; }
			csv = csv + gpus[g];
			g = g + 1;
		}
		setenv("CUDA_VISIBLE_DEVICES", csv);
	}

	let result = posix_spawn(argv, {
		stdin: null_fd,
		stdout: log_fd,
		stderr: log_fd,
		setsid: true,
	});

	if (pinned) {
		unsetenv("CUDA_VISIBLE_DEVICES");
	}
	fd_close(log_fd);
	fd_close(null_fd);

	let pid = result.pid;
	if (pid <= 0) {
		return { spawn_error: "posix_spawn returned invalid pid: " + pid };
	}

	// Did the child immediately exit? Common causes: contended port,
	// missing model file, missing CUDA runtime, malformed args. Without
	// this check, we'd return 201 + a pid that's already a zombie, and
	// the caller wouldn't know until the next /v1/llama/* request fails
	// or the next agent /services list shows alive=false. Surface it now.
	//
	// Returning a structured error rather than `throw`-ing because Hemlock's
	// exception path interacts badly with the async heartbeat task — the
	// throw triggered "longjmp causes uninitialized stack frame" abort
	// in the agent process. Worth filing upstream; in the meantime,
	// non-throwing error returns sidestep the issue.
	sleep(SPAWN_FAILURE_GRACE_SECONDS);
	if (!process_alive(pid)) {
		let tail = read_log_tail(log_path, 4096);
		let msg = "spawn died immediately (pid " + pid + " exited within "
			+ SPAWN_FAILURE_GRACE_SECONDS + "s)";
		if (tail.length > 0) {
			msg = msg + "; log tail:\n" + tail;
		} else {
			msg = msg + " (no log output captured at " + log_path + ")";
		}
		return { spawn_error: msg };
	}

	let now = iso_now(db);
	db_exec(db,
		"insert into services (id, profile, model_path, pid, port, log_path, args_json, started_at) "
		+ "values (?, ?, ?, ?, ?, ?, ?, ?)",
		[id, profile_name, model_path, pid, port, log_path, stringify(argv), now]);

	return {
		id: id,
		profile: profile_name,
		model_path: model_path,
		pid: pid,
		port: port,
		log_path: log_path,
		started_at: now,
	};
}

export fn list_services(db): array {
	let rows = query(db,
		"select id, profile, model_path, pid, port, log_path, started_at "
		+ "from services order by started_at desc", []);
	let out = [];
	for (row in rows) {
		out.push({
			id: row.id,
			profile: row.profile,
			model_path: row.model_path,
			pid: row.pid,
			port: row.port,
			log_path: row.log_path,
			started_at: row.started_at,
			alive: process_alive(row.pid),
		});
	}
	return out;
}

export fn stop_service(db, id: string): bool {
	let rows = query(db, "select pid from services where id = ?", [id]);
	if (rows.length == 0) {
		return false;
	}
	let pid = rows[0].pid;
	if (process_alive(pid)) {
		try { kill(pid, SIGTERM); } catch (e) { /* race with exit; fine */ }
	}
	db_exec(db, "delete from services where id = ?", [id]);
	return true;
}

// ── HTTP handlers ─────────────────────────────────────────────────────

export fn make_handlers(db): object {
	return {
		create: fn(req): object {
			let payload = parse(req.body);
			let profile = payload?.profile;
			let model = payload?.model;
			if (profile == null || model == null) {
				return { status: 400, body: "{\"error\":\"profile+model required\"}" };
			}
			let port = payload?.port;
			if (port == null) {
				port = PROFILES[profile].default_port;
			}
			let gpus = payload?.gpus ?? [];
			try {
				let svc = spawn_service(db, profile, model, port, gpus);
				if (svc?.spawn_error != null) {
					// 502 because the upstream binary (llama-server) failed
					// during startup, not because the request was malformed.
					return { status: 502, body: stringify({ error: svc.spawn_error }) };
				}
				return { status: 201, body: stringify(svc) };
			} catch (e) {
				return { status: 400, body: stringify({ error: "" + e }) };
			}
		},
		list: fn(req): object {
			return { status: 200, body: stringify(list_services(db)) };
		},
		stop: fn(req): object {
			let payload = parse(req.body);
			let id = payload?.id;
			if (id == null) {
				return { status: 400, body: "{\"error\":\"id required\"}" };
			}
			let ok = stop_service(db, id);
			if (!ok) {
				return { status: 404, body: "{\"error\":\"not found\"}" };
			}
			return { status: 204, body: "" };
		},
		profiles: fn(req): object {
			// Return the full profile map so CP can use context/kv_type for
			// placement math, not just names. Skip the binary `flags` array
			// (the agent's responsibility, not CP's concern) to keep the
			// payload small.
			let out = {};
			let names = PROFILES.keys();
			for (n in names) {
				let p = PROFILES[n];
				out[n] = {
					default_port: p.default_port,
					context: p.context,
					kv_type: p.kv_type,
					default_model: p.default_model,
				};
			}
			return { status: 200, body: stringify(out) };
		},
	};
}
