// agent.hml — Witchgrid node agent.
//
// Runs on every box that hosts inference. On boot:
//   1. Probe hardware (nvidia-smi if GPU box, empty if CPU-only) +
//      cpu_count + ram totals + per-watched-dir disk free.
//   2. Scan model dirs (canonical + extras) into a GGUF catalog.
//   3. POST /register to the control plane with hardware + catalog.
//   4. Open sqlite, init the local services schema.
//   5. Spawn a detached heartbeat task that re-registers every
//      HEARTBEAT_SECONDS with refreshed hardware (live free_mb counts
//      so CP placement sees current state, not boot snapshot). Catalog
//      is sent on every heartbeat too — small payload, easier than
//      change-detection.
//   6. Listen on AGENT_PORT for service-supervisor requests from CP.
//
// CP is the only intended caller — agents don't need to be reachable
// from the public internet, just from CP. Bind to 0.0.0.0 by default
// so a CP on another box on the LAN can reach us; override AGENT_HOST
// to lock down further.
//
// Endpoints:
//   POST /services         { profile, model?, port?, gpus? }   → 201 {id,...}
//   GET  /services                                             → [...]
//   POST /services/stop    { id }                              → 204
//   GET  /profiles                                             → [profile names]
//   GET  /capabilities                                         → { binary: caps_map }
//   GET  /models                                               → catalog entries
//   POST /rescan                                               → 200, refresh + return new count
//   GET  /healthz                                              → ok
//
// Config (env vars):
//   WITCHGRID_CP_URL           required   e.g. http://10.0.0.10:8765
//   WITCHGRID_AGENT_URL        required   what URL CP can reach this agent at
//   WITCHGRID_AGENT_HOST       0.0.0.0    bind address
//   WITCHGRID_AGENT_PORT       8766       bind port
//   WITCHGRID_NODE_ID          $HOSTNAME  stable identifier
//   WITCHGRID_MODEL_DIR        ~/.witchgrid/models
//                                         canonical dir; pulls land here,
//                                         disk free reported as "canonical"
//   WITCHGRID_MODEL_DIRS_EXTRA <empty>    colon-separated extra scan dirs
//                                         (read-only as far as Witchgrid
//                                         is concerned; just discovered)

import { open_db, close_db, query as db_query } from "@stdlib/sqlite";
import { stringify, parse } from "@stdlib/json";
import { getenv } from "@stdlib/env";
import { exec_argv } from "@stdlib/process";
import { post_json, post } from "@stdlib/http";
import { sha256 } from "@stdlib/hash";
import { sleep } from "@stdlib/time";
import { homedir } from "@stdlib/os";
import { exists, make_dirs } from "@stdlib/fs";
import { socket_create, AF_INET, SOCK_STREAM } from "@stdlib/net";
import { serve } from "./http_server";
import { init_services_schema, make_handlers, reap_zombie_services, discover_orphan_llama_servers } from "./services";
import { probe, probe_unmanaged_procs } from "./hardware";
import { introspect, probe_version } from "./capabilities";
import { scan as scan_models } from "./models";
import { init_transfers_schema, make_pull_handler, list_transfers } from "./transfers";
import { init_llama_cpp_schema, make_handlers as make_llama_cpp_handlers, current_binary_path, detect_flavor } from "./llama_cpp";

let DB_PATH = "witchgrid-agent.db";

// 30s gives CP enough resolution that placement sees current free_mb
// without burning excessive RPC. CP's stale-node cutoff is 90s (3x
// this) so a single missed heartbeat doesn't flap us out of placement.
let HEARTBEAT_SECONDS = 30;

// ── auth (shared bearer; matches CP's slice-1 design) ─────────────
//
// Same model as CP: WITCHGRID_SHARED_SECRET, sent on every outbound
// CP call AND required on every inbound CP→agent call. Unset = legacy
// mode (warn at boot, accept all). When CP and agent disagree (one has
// secret set, other doesn't), the side with auth on rejects with 401
// — easy to spot in the log.
//
// Read fresh from env on every call rather than caching in a let:
// Hemlock spawn() snapshots module state at spawn time, so the
// heartbeat task would see whatever SHARED_SECRET was BEFORE init_auth
// ran. Re-reading dodges that. getenv is microseconds — once per
// heartbeat (30s) or per inbound request, well under the noise floor.
fn shared_secret(): string {
	return env_or("WITCHGRID_SHARED_SECRET", "");
}

fn init_auth(): null {
	let s = shared_secret();
	if (s.length > 0) {
		print("[auth] enabled (" + s.length + "-char shared secret)");
	} else {
		print("[auth] DISABLED — set WITCHGRID_SHARED_SECRET to enable");
	}
	return null;
}

fn auth_match(provided): bool {
	let secret = shared_secret();
	if (secret == "") { return true; }
	if (provided == null || provided.length == 0) { return false; }
	let prefix = "Bearer ";
	if (provided.length < prefix.length) { return false; }
	if (provided.substr(0, prefix.length) != prefix) { return false; }
	let raw = provided.substr(prefix.length, provided.length - prefix.length);
	return sha256(raw) == sha256(secret);
}

fn agent_auth_check(req, route) {
	if (shared_secret() == "") { return null; }
	if (route?.public == true) { return null; }
	let header = req?.headers?["authorization"] ?? "";
	if (auth_match(header)) { return null; }
	// Body fallback — see CP's matching cp_auth_check for context.
	if (req?.body != null && req.body.length > 0
		&& req.body.length < 1048576) {
		try {
			let payload = parse(req.body);
			let tok = payload?._auth_token;
			if (tok != null && auth_match("Bearer " + tok)) { return null; }
		} catch (e) { }
	}
	return { status: 401,
		body: "{\"error\":\"unauthorized\"}",
		headers: { "content-type": "application/json",
			"www-authenticate": "Bearer realm=\"witchgrid\"" } };
}

// Outbound — agent→CP (register, heartbeat). POSTs inject the bearer
// as `_auth_token` in the JSON body (Hemlock workaround — its lws POST
// wrapper drops arbitrary headers). Authorization header sent too so
// the day Hemlock gains POST-with-headers we can drop the body field.
fn cp_post_json(url: string, data) {
	let secret = shared_secret();
	let payload = data;
	if (secret != "" && payload != null) { payload["_auth_token"] = secret; }
	let body = stringify(payload);
	let h = ["Content-Type: application/json"];
	if (secret != "") { h.push("Authorization: Bearer " + secret); }
	return post(url, body, h);
}

fn require_env(name: string): string {
	let v = getenv(name);
	if (v == null || v.length == 0) {
		eprint("[agent] missing required env var: " + name);
		throw "missing env: " + name;
	}
	return v;
}

fn env_or(name: string, default_value: string): string {
	let v = getenv(name);
	if (v == null || v.length == 0) { return default_value; }
	return v;
}

fn detect_hostname(): string {
	try {
		let r = exec_argv(["hostname"]);
		if (r.exit_code == 0) { return r.output.trim(); }
	} catch (e) { }
	return "unknown";
}

// Split a colon-separated PATH-style env value, dropping empties. Used
// for WITCHGRID_MODEL_DIRS_EXTRA. Returns [] when the value is unset
// or empty so the scan code doesn't have to nil-check.
fn split_paths(value: string): array {
	let out = [];
	if (value == null || value.length == 0) { return out; }
	let parts = value.split(":");
	for (p in parts) {
		let pp = p.trim();
		if (pp.length > 0) { out.push(pp); }
	}
	return out;
}

fn register_with_cp(cp_url: string, payload): null {
	let url = cp_url + "/register";
	print("[agent] registering with CP at " + url);
	try {
		let resp = cp_post_json(url, payload);
		if (resp.status_code >= 200 && resp.status_code < 300) {
			print("[agent] registered OK: " + resp.body);
		} else {
			eprint("[agent] CP returned " + resp.status_code + ": " + resp.body);
		}
	} catch (e) {
		// Non-fatal: agent stays up, the heartbeat loop will re-try.
		// CP-down at agent boot is fine; we'll show up on first heartbeat.
		eprint("[agent] register failed: " + e + " (continuing; heartbeat will retry)");
	}
	return null;
}

// Heartbeat task. Runs detached on a worker thread. Re-probes hardware
// each tick so CP's placement sees current free_mb, not boot-time
// snapshot. Catalog is sent verbatim from the cached scan — rescans
// are operator-triggered, not heartbeat-driven (boot scan + POST
// /rescan covers the realistic cadence; per-heartbeat rescan would
// repeatedly read every GGUF header for no operational gain).
//
// Pull every PID the agent has ever spawned and not reaped — these
// are "ours" for the unmanaged-proc cross-reference. Includes zombies
// the next reap_zombie_services() pass would cull, but that's harmless;
// nvidia-smi already won't list them.
fn collect_known_pids(db): array {
	let rows = db_query(db, "select pid from services", []);
	let out = [];
	for (r in rows) { out.push(r.pid); }
	return out;
}

// Transient CP failures are swallowed — we'll succeed on the next
// tick. The only way to stop the loop is process exit.
async fn heartbeat_loop(cp_url: string, node_id: string, hostname: string,
                        agent_url: string, canonical_dir: string,
                        extra_dirs, models_ref, runtime_ref, db,
                        interval_seconds: i32): null {
	loop {
		sleep(f64(interval_seconds));
		let hw = probe(canonical_dir, extra_dirs);
		let unmanaged = probe_unmanaged_procs(hw.gpus, collect_known_pids(db));
		try {
			let resp = cp_post_json(cp_url + "/register", {
				node_id:   node_id,
				hostname:  hostname,
				role:      hw.role,
				hardware:  hw,
				agent_url: agent_url,
				models:    models_ref.entries,
				runtime:   runtime_ref.value,
				unmanaged_processes: unmanaged,
			});
			if (resp.status_code < 200 || resp.status_code >= 300) {
				eprint("[heartbeat] CP " + resp.status_code + ": " + resp.body);
			}
		} catch (e) {
			eprint("[heartbeat] CP unreachable: " + e);
		}
	}
	return null;
}

// Strip URL → bare host. Handed to make_pull_handler so peer pulls
// can refuse self-targeting cleanly.
fn extract_url_host(url: string): string {
	let rest = url;
	let scheme = rest.find("://");
	if (scheme >= 0) { rest = rest.substr(scheme + 3, rest.length - scheme - 3); }
	let slash = rest.find("/");
	if (slash >= 0) { rest = rest.substr(0, slash); }
	let colon = rest.find(":");
	if (colon >= 0) { rest = rest.substr(0, colon); }
	return rest;
}

// Probe whether a TCP port is currently bindable on this host. Tries a
// fresh bind to 0.0.0.0:port — that's the exact condition llama-server
// faces — and reports the answer. Hemlock 2.2.3 made this catchable in
// compiled binaries (#559), so we no longer need to shell out to `ss`.
fn port_is_free(port: i32): bool {
	let s = null;
	try {
		s = socket_create(AF_INET, SOCK_STREAM, 0);
	} catch (e) {
		// FD exhaustion or worse. Optimistic — let the spawn try and
		// surface the real error.
		return true;
	}
	let free = true;
	try {
		s.bind("0.0.0.0", port);
	} catch (e) {
		free = false;
	}
	try { s.close(); } catch (e) { }
	return free;
}

// Default canonical dir is ~/.witchgrid/models. Created if missing so
// the operator doesn't have to mkdir before first run; harmless on
// CPU-only boxes that won't ever hold models (empty dir reports 0
// catalog entries, which is what we want).
fn default_canonical_dir(): string {
	let h = homedir();
	if (h == null || h.length == 0) { return "/var/lib/witchgrid/models"; }
	return h + "/.witchgrid/models";
}

fn ensure_canonical_dir(path: string): null {
	if (exists(path)) { return null; }
	try { make_dirs(path); } catch (e) {
		eprint("[agent] could not create canonical dir " + path + ": " + e);
	}
	return null;
}

fn main(): null {
	init_auth();
	let cp_url     = require_env("WITCHGRID_CP_URL");
	let agent_url  = require_env("WITCHGRID_AGENT_URL");
	let host       = env_or("WITCHGRID_AGENT_HOST", "0.0.0.0");
	let port_str   = env_or("WITCHGRID_AGENT_PORT", "8766");
	let port       = i32(port_str);
	let hostname   = detect_hostname();
	let node_id    = env_or("WITCHGRID_NODE_ID", hostname);

	// Catalog config. Canonical defaults to ~/.witchgrid/models (created
	// if missing). Extras are colon-separated and read-only — we discover
	// what's there but pulls always land in the canonical dir.
	let canonical_dir = env_or("WITCHGRID_MODEL_DIR", default_canonical_dir());
	let extra_dirs    = split_paths(env_or("WITCHGRID_MODEL_DIRS_EXTRA", ""));
	ensure_canonical_dir(canonical_dir);

	let hw = probe(canonical_dir, extra_dirs);
	print("[agent] " + node_id + " (" + hostname + ", " + hw.role + ") "
		+ hw.cpu_cores + " cores, "
		+ hw.ram_total_mb + " MB RAM, "
		+ hw.gpus.length + " GPU(s), "
		+ hw.disks.length + " disk path(s)");

	// Probe llama-server build/version + capabilities. Both are wrapped
	// in holder objects so the llama_cpp/activate handler can re-run
	// these against a freshly-installed binary without restarting the
	// agent — closures capture the holder by reference.
	//
	// current_binary_path() resolves to ~/.witchgrid/llama-server/current/
	// when there's a Witchgrid-managed install, falls back to bare
	// "llama-server" (PATH lookup) otherwise.
	let runtime_ref = { value: {} };
	let caps_ref    = { llama_server: {} };
	let do_rescan_caps = fn(): null {
		let bin = current_binary_path();
		try { caps_ref.llama_server = introspect(bin); } catch (e) {
			eprint("[agent] introspect " + bin + " failed: " + e);
			caps_ref.llama_server = {};
		}
		let lv = probe_version(bin);
		let rt = {};
		if (lv != null) {
			rt["llama_server"] = lv;
			print("[agent] llama-server build " + lv.version
				+ " (" + (lv?.build_hash ?? "?") + ") at " + bin);
		}
		runtime_ref.value = rt;
		return null;
	};
	do_rescan_caps();
	if (caps_ref.llama_server.keys().length == 0) {
		print("[agent] llama-server not installed; capabilities empty (spawn will reject until installed)");
	} else {
		print("[agent] llama-server: " + caps_ref.llama_server.keys().length + " flags");
	}

	// Scan the catalog before first /register so CP gets the model list
	// on the very first contact (placement can use it immediately).
	// Cost: ~16ms per file. A box with 100 GGUFs sees ~1.5s extra boot
	// time — acceptable for a one-shot.
	print("[agent] scanning models in " + canonical_dir
		+ (extra_dirs.length > 0 ? " + " + extra_dirs.length + " extra dir(s)" : ""));
	let model_entries = scan_models(canonical_dir, extra_dirs);
	print("[agent] catalog: " + model_entries.length + " GGUF(s)");

	// Wrap entries in a holder object so the heartbeat closure sees the
	// SAME live reference after a /rescan replaces the inner list.
	// (Hemlock arrays are passed by value in some assignment forms; the
	// holder dodges any reassignment-vs-mutation ambiguity.)
	let models_ref = { entries: model_entries };

	// Open db before initial register so the heartbeat (and the very
	// first /register) can include the unmanaged-proc list — needs the
	// services table to know which PIDs are ours vs. the rest.
	let db = open_db(DB_PATH);
	init_services_schema(db);
	init_transfers_schema(db);
	init_llama_cpp_schema(db);

	register_with_cp(cp_url, {
		node_id:   node_id,
		hostname:  hostname,
		role:      hw.role,
		hardware:  hw,
		agent_url: agent_url,
		models:    models_ref.entries,
		runtime:   runtime_ref.value,
		unmanaged_processes: probe_unmanaged_procs(hw.gpus,
			collect_known_pids(db)),
	});

	// Detached heartbeat task — fire-and-forget, runs until process exit.
	let hb = spawn(heartbeat_loop, cp_url, node_id, hostname, agent_url,
	               canonical_dir, extra_dirs, models_ref, runtime_ref,
	               db, HEARTBEAT_SECONDS);
	detach(hb);
	print("[agent] heartbeat every " + HEARTBEAT_SECONDS + "s");

	let reaped = reap_zombie_services(db);
	if (reaped > 0) {
		print("[agent] reaped " + reaped + " zombie service rows from prior run");
	}
	// Surface any same-uid llama-servers we don't have rows for —
	// catches the "agent's sqlite was wiped but children survived"
	// case + cross-checks against PID recycling. No auto-adoption
	// (we lack the original profile metadata to fabricate a row);
	// operator decides whether to claim or kill.
	try {
		let uid_r = exec_argv(["id", "-u"]);
		if (uid_r.exit_code == 0) {
			discover_orphan_llama_servers(db, i32(uid_r.output.trim()));
		}
	} catch (e) { }
	print("[agent] sqlite ready: " + DB_PATH);

	// Introspect the local llama-server binary once at boot so CP can
	// ask "does this agent's binary support flash_attention?" without
	// each request re-running --help. Cached for the agent's lifetime;
	// restart the agent after a llama.cpp upgrade to refresh.
	let llama_caps = {};
	try {
		llama_caps = introspect("llama-server");
		print("[agent] llama-server: " + llama_caps.keys().length + " flags");
	} catch (e) {
		eprint("[agent] llama-server introspection failed: " + e
			+ " (capabilities unavailable; spawning still works)");
	}

	// Capabilities lookup closure — services.hml uses this to resolve
	// each profile's intent map at spawn time. Reads through caps_ref
	// so a llama_cpp/activate hot-swap is reflected immediately
	// without restarting the agent.
	fn capabilities_for(binary_name) {
		if (binary_name == "llama-server") { return caps_ref.llama_server; }
		return {};
	}

	// Closure shared by /rescan and the pull-completion hook so a
	// successful download immediately enters the catalog without
	// waiting for an operator to re-trigger.
	fn do_rescan(): null {
		let fresh = scan_models(canonical_dir, extra_dirs);
		models_ref.entries = fresh;
		return null;
	}
	let pull = make_pull_handler(db, canonical_dir, do_rescan,
		extract_url_host(agent_url));

	// llama.cpp install handlers — activate triggers do_rescan_caps
	// so a fresh build is reflected in /capabilities + the next
	// heartbeat's runtime field without restarting the agent.
	let lcpp = make_llama_cpp_handlers(db, do_rescan_caps);

	// Resolve a binary name to its on-disk path. Since v0.7 C2 the
	// llama_cpp module owns the install layer; current_binary_path()
	// reads through ~/.witchgrid/llama-server/current/ when set.
	fn binary_path_for(binary_name) {
		if (binary_name == "llama-server") { return current_binary_path(); }
		return binary_name;
	}

	// Pass our own listen port as reserved so spawn_service refuses to
	// land an llama-server there (the OS would let two binds compete and
	// our future restart would lose).
	let svc = make_handlers(db, [port], capabilities_for, binary_path_for);
	let routes = [
		{ method: "POST", path: "/services",      handler: svc.create },
		{ method: "GET",  path: "/services",      handler: svc.list },
		{ method: "POST", path: "/services/stop", handler: svc.stop },
		{ method: "GET",  path: "/services/log/", prefix: true, handler: svc.log },
		// /profiles gone in v0.7 — profiles live on CP. The handler
		// stub returns 410; route left out so 404 is the response.
		{ method: "GET",  path: "/capabilities",  handler: fn(req): object {
			return { status: 200, body: stringify({
				"llama-server": caps_ref.llama_server,
			})};
		} },
		{ method: "GET",  path: "/models",        handler: fn(req): object {
			return { status: 200, body: stringify(models_ref.entries) };
		} },
		// Streaming blob serve. URL: /models/{alias}/blob — peers (or
		// curl, or `wget`) pull the actual GGUF file from here. Response
		// is application/octet-stream with Content-Length set; the body
		// streams from disk in 64KB chunks (see http_server.write_response)
		// so we don't peg RAM on a 40GB model. Prefix-route because alias
		// lives in the path; reject non-/blob suffixes with 404.
		{ method: "GET",  path: "/models/",       prefix: true, handler: fn(req): object {
			let after = req.path.substr(8, req.path.length - 8);  // strip "/models/"
			let slash = after.find("/");
			if (slash < 0) {
				return { status: 404, body: "{\"error\":\"expected /models/{alias}/blob\"}" };
			}
			let alias = after.substr(0, slash);
			let suffix = after.substr(slash, after.length - slash);
			if (suffix != "/blob") {
				return { status: 404, body: "{\"error\":\"only /models/{alias}/blob is served\"}" };
			}
			let entries = models_ref.entries;
			let path = null;
			for (e in entries) {
				if (e.alias == alias) { path = e.path; break; }
			}
			if (path == null) {
				return { status: 404, body: stringify({
					error: "alias not in this node's catalog: " + alias,
				})};
			}
			return { status: 200, stream_path: path, headers: {
				"content-type": "application/octet-stream",
				"x-witchgrid-alias": alias,
			}};
		} },
		{ method: "POST", path: "/rescan",        handler: fn(req): object {
			print("[agent] rescan triggered");
			do_rescan();
			return { status: 200, body: stringify({
				count: models_ref.entries.length,
			})};
		} },
		{ method: "POST", path: "/models/pull",   handler: pull },
		{ method: "GET",  path: "/models/transfers", handler: fn(req): object {
			return { status: 200, body: stringify(list_transfers(db)) };
		} },
		// llama.cpp lifecycle (v0.7 C2): install a build from GitHub
		// releases, list installed builds, activate one as `current`.
		// Spawn uses current_binary_path() which honors the symlink.
		{ method: "POST", path: "/llama_cpp/install",  handler: lcpp.install },
		{ method: "GET",  path: "/llama_cpp/installed", handler: lcpp.list },
		{ method: "POST", path: "/llama_cpp/activate", handler: lcpp.activate },
		// Convenience: report the auto-detected flavor for this host so
		// the dashboard can pre-fill the install form.
		{ method: "GET",  path: "/llama_cpp/flavor",   handler: fn(req): object {
			return { status: 200, body: stringify({
				flavor: detect_flavor(probe(canonical_dir, extra_dirs).role),
			})};
		} },
		{ method: "POST", path: "/port_check",    handler: fn(req): object {
			// CP calls this to OS-truth-check candidate ports before
			// telling us to spawn there. Existing pick_port logic only
			// dodges Witchgrid-spawned services; non-Witchgrid stuff
			// (kobold/ooba/sd-webui) is invisible to it. This endpoint
			// closes that gap.
			//
			// Body: { port: N }
			let body = req?.body ?? "{}";
			let payload = null;
			try { payload = parse(body); } catch (e) {
				return { status: 400, body: "{\"error\":\"bad json\"}" };
			}
			let p = payload?.port;
			if (p == null) {
				return { status: 400, body: "{\"error\":\"port required\"}" };
			}
			let free = port_is_free(i32(p));
			return { status: 200, body: stringify({ port: p, available: free }) };
		} },
		{ method: "GET",  path: "/healthz",       handler: fn(req): object {
			return { status: 200, body: "{\"status\":\"ok\"}" };
		}, public: true },
	];

	serve(host, port, routes, agent_auth_check);
	close_db(db);
	return null;
}

main();
