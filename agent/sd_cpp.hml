// sd_cpp.hml — manage stable-diffusion.cpp installs on this node.
//
// Second sibling of llama_cpp.hml; uses engine_common for the shared
// install_root / probe_binary / schema / list / activate / CUDA detect
// / pick_backend scaffolding. Per-engine bits owned here: upstream,
// asset matcher (GitHub releases naming is unpredictable enough to
// need API resolution rather than a URL template), source-build cmake
// flag translation.
//
// Why both prebuilt + source: sd.cpp ships Ubuntu-24.04 / glibc-2.38
// Linux prebuilts which don't run on older boxes. flavor=="source"
// triggers a local cmake build against the node's toolchain. The
// flavor parameter doubles as the source-build backend override
// when the install task is invoked with cuda/vulkan/cpu/macos-arm64
// directly (currently the API only routes flavor=="source" to source,
// but source_install_task respects whatever flavor it receives so the
// plumbing is ready).
//
// Layout per install:
//   ~/.witchgrid/sd-server/
//     master-602-0665a7f/.../sd-server   ← actual binary
//     current -> master-602-0665a7f       ← active install

import { exec_argv } from "@stdlib/process";
import { stringify, parse } from "@stdlib/json";
import { exec as db_exec, query } from "@stdlib/sqlite";
import { platform, arch } from "@stdlib/os";
import { exists, file_stat, make_dirs, remove_file } from "@stdlib/fs";
import {
	install_root_for, probe_binary, resolve_current,
	ensure_install_schema, new_id, iso_now,
	list_installs_at, flip_current,
	detect_nvcc, detect_cuda_arch, nproc_str, pick_backend, mark_error,
} from "./engine_common";

let SD_REPO       = "https://github.com/leejet/stable-diffusion.cpp";
let ENGINE_NAME   = "sd-server";
let INSTALL_TABLE = "sd_cpp_installs";

// Candidate binary paths inside an install dir (flat extracted zip,
// child-dir layout, source build's build/bin).
let BIN_CANDIDATES = [
	"sd-server",
	"bin/sd-server",
	"build/bin/sd-server",
];

fn install_root(): string {
	return install_root_for("sd-server");
}

fn find_binary(dir: string) {
	return probe_binary(dir, BIN_CANDIDATES);
}

// Auto-detect the right flavor for THIS host.
//   gpu + darwin/arm64 → macos-arm64
//   gpu + linux        → vulkan  (cross-vendor — sd.cpp ships no
//                                 Linux CUDA prebuilt; source build
//                                 is the path for CUDA)
//   cpu + darwin/arm64 → macos-arm64
//   cpu + linux        → cpu
export fn detect_flavor(role: string): string {
	let p = platform();
	let a = arch();
	if (p == "darwin" && a == "arm64") { return "macos-arm64"; }
	if (p == "linux" && a == "x86_64") {
		if (role == "gpu") { return "vulkan"; }
		return "cpu";
	}
	return null;
}

// ─── prebuilt asset resolution ───────────────────────────────────

// True iff the GitHub asset `name` matches the requested flavor for
// this platform. Linux assets look like
// sd-<short>-bin-Linux-Ubuntu-<ver>-x86_64[-<flavor>].zip ; the CPU
// build is the one with NO -vulkan/-rocm/-cuda suffix.
fn asset_matches(name: string, flavor: string): bool {
	if (name.find(".zip") < 0) { return false; }
	if (flavor == "macos-arm64") {
		return name.find("Darwin") >= 0 && name.find("arm64") >= 0;
	}
	if (name.find("Linux") < 0 || name.find("x86_64") < 0) { return false; }
	if (flavor == "vulkan") { return name.find("vulkan") >= 0; }
	if (flavor == "rocm")   { return name.find("rocm") >= 0; }
	if (flavor == "cpu") {
		return name.find("vulkan") < 0 && name.find("rocm") < 0
			&& name.find("cuda") < 0 && name.find("cu12") < 0;
	}
	return false;
}

// Resolve a (tag, flavor) pair to a browser_download_url via the
// GitHub releases API. sd.cpp's asset names embed the build runner's
// OS version + a short release form that can't be reconstructed by
// pure string templating, so we ask the API rather than guess. One
// cheap unauthenticated GET per install — install is rare.
fn resolve_asset_url(tag: string, flavor: string): string {
	let api = "https://api.github.com/repos/leejet/stable-diffusion.cpp/releases/tags/" + tag;
	let r = null;
	try {
		r = exec_argv(["curl", "-fsSL", "-H", "Accept: application/vnd.github+json", api]);
	} catch (e) {
		throw "curl exec failed resolving release (install curl?): " + e;
	}
	if (r.exit_code != 0) {
		throw "GitHub API GET " + api + " failed (exit " + r.exit_code
			+ "): tag may not exist. " + (r?.stderr ?? "");
	}
	let rel = null;
	try { rel = parse(r.output); } catch (e) {
		throw "could not parse GitHub API response for tag " + tag;
	}
	let assets = rel?.assets ?? [];
	for (as in assets) {
		let nm = as?.name ?? "";
		if (asset_matches(nm, flavor)) {
			let u = as?.browser_download_url;
			if (u != null) { return u; }
		}
	}
	throw "no '" + flavor + "' asset found in release " + tag
		+ " (assets exist but none matched; check flavor or tag)";
}

export fn current_binary_path(): string {
	return resolve_current(install_root(), BIN_CANDIDATES, ENGINE_NAME);
}

export fn init_sd_cpp_schema(db): null {
	return ensure_install_schema(db, INSTALL_TABLE);
}

export fn list_installed(): array {
	return list_installs_at(install_root(), find_binary, current_binary_path());
}

export fn activate(tag: string): string {
	flip_current(install_root(), tag, find_binary, ENGINE_NAME);
	return current_binary_path();
}

// ─── prebuilt install task (download zip, unzip, validate) ───────

async fn install_task(db, transfer_id: string, tag: string, flavor: string,
                      url: string, target_dir: string): null {
	let archive = target_dir + ".zip";

	db_exec(db, "update " + INSTALL_TABLE + " set status='downloading' where id=?",
		[transfer_id]);
	let r = null;
	try { r = exec_argv(["curl", "-fsSL", "-o", archive, url]); }
	catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"curl exec failed (install curl?): " + e, 0);
		return null;
	}
	if (r.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"curl exit " + r.exit_code + ": " + (r?.stderr ?? r?.output ?? ""),
			256);
		return null;
	}

	db_exec(db, "update " + INSTALL_TABLE + " set status='extracting' where id=?",
		[transfer_id]);
	try { make_dirs(target_dir); } catch (e) { }
	let tr = null;
	try { tr = exec_argv(["unzip", "-o", archive, "-d", target_dir]); }
	catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"unzip exec failed (install unzip?): " + e, 0);
		return null;
	}
	if (tr.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"unzip exit " + tr.exit_code + ": " + (tr?.stderr ?? tr?.output ?? ""),
			512);
		return null;
	}

	let bin = find_binary(target_dir);
	if (bin == null) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"extracted archive but no sd-server binary found under " + target_dir
				+ " (tried flat, bin/, build/bin, and child dirs)", 0);
		return null;
	}
	// Some release zips ship without the executable bit. Defensive chmod.
	try { exec_argv(["chmod", "+x", bin]); } catch (e) { }
	try { remove_file(archive); } catch (e) { }

	let stat = null;
	try { stat = file_stat(bin); } catch (e) { }
	let now = iso_now(db);
	db_exec(db,
		"update " + INSTALL_TABLE
		+ " set status='complete', bytes_total=?, completed_at=? where id=?",
		[(stat == null ? 0 : stat.size), now, transfer_id]);
	print("[sd_cpp] " + transfer_id + " complete: " + tag + "/" + flavor);
	return null;
}

// ─── source-build task ───────────────────────────────────────────

// Translate the shared pick_backend tag into sd.cpp's cmake flags.
// sd-cpp uses SD_* macros (not the GGML_* shared namespace whisper
// uses), and macOS Metal is auto-enabled by sd.cpp's CMakeLists on
// darwin/arm64 so we don't need a flag for it.
fn cmake_flags_for(backend: string, transfer_id: string, db): array {
	if (backend == "cuda") {
		let nvcc = detect_nvcc();
		if (nvcc == null) {
			mark_error(db, INSTALL_TABLE, transfer_id,
				"backend=cuda but nvcc not found on PATH or /usr/local/cuda/bin "
					+ "(install CUDA toolkit, or pick a different flavor)", 0);
			return null;
		}
		return [
			"-DSD_CUDA=ON",
			"-DCMAKE_CUDA_COMPILER=" + nvcc,
			"-DCMAKE_CUDA_ARCHITECTURES=" + detect_cuda_arch(),
		];
	}
	if (backend == "vulkan") { return ["-DSD_VULKAN=ON"]; }
	// cpu / metal: no extra flags.
	return [];
}

async fn source_install_task(db, transfer_id: string, tag: string,
                            flavor: string, target_dir: string): null {
	db_exec(db, "update " + INSTALL_TABLE + " set status='cloning' where id=?",
		[transfer_id]);
	let cr = null;
	try {
		cr = exec_argv(["git", "clone", "--recursive", SD_REPO, target_dir]);
	} catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"git clone exec failed (install git?): " + e, 0);
		return null;
	}
	if (cr.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"git clone exit " + cr.exit_code + ": " + (cr?.stderr ?? cr?.output ?? ""),
			400);
		return null;
	}

	let tl = tag.lower();
	if (tl != "head" && tl != "main" && tl != "master" && tl != "latest") {
		let ok = true;
		let co = null;
		try { co = exec_argv(["git", "-C", target_dir, "checkout", "-q", tag]); }
		catch (e) { ok = false; }
		if (co == null || co.exit_code != 0) { ok = false; }
		if (ok) {
			try { exec_argv(["git", "-C", target_dir, "submodule", "update",
				"--init", "--recursive"]); } catch (e) { }
		}
		if (!ok) {
			mark_error(db, INSTALL_TABLE, transfer_id,
				"git checkout '" + tag + "' failed (not a valid ref; use a "
					+ "release tag like master-602-0665a7f, or 'head' to build "
					+ "the default branch)", 0);
			return null;
		}
	}

	db_exec(db, "update " + INSTALL_TABLE + " set status='building' where id=?",
		[transfer_id]);
	let build_dir = target_dir + "/build";
	let backend = pick_backend(flavor);
	let backend_flags = cmake_flags_for(backend, transfer_id, db);
	if (backend_flags == null) { return null; }

	let cfg = ["cmake", "-S", target_dir, "-B", build_dir, "-DCMAKE_BUILD_TYPE=Release"];
	for (f in backend_flags) { cfg.push(f); }
	print("[sd_cpp] " + transfer_id + " source build backend=" + backend);

	let cf = null;
	try { cf = exec_argv(cfg); } catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake configure exec failed (install cmake?): " + e, 0);
		return null;
	}
	if (cf.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake configure exit " + cf.exit_code + ": "
				+ (cf?.stderr ?? cf?.output ?? ""), 600);
		return null;
	}

	let bf = null;
	try {
		// --target sd-server: only build the server binary we ship.
		// sd.cpp produces several example/util binaries (sd CLI, esrgan
		// tooling, …) that we never touch — skipping them cuts build
		// wall time noticeably.
		bf = exec_argv(["cmake", "--build", build_dir, "--config", "Release",
			"-j", nproc_str(), "--target", "sd-server"]);
	} catch (e) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake build exec failed: " + e, 0);
		return null;
	}
	if (bf.exit_code != 0) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"cmake build exit " + bf.exit_code + ": "
				+ (bf?.stderr ?? bf?.output ?? ""), 600);
		return null;
	}

	let bin = find_binary(target_dir);
	if (bin == null) {
		mark_error(db, INSTALL_TABLE, transfer_id,
			"build completed but no sd-server binary found under "
				+ target_dir + " (expected build/bin/sd-server)", 0);
		return null;
	}
	try { exec_argv(["chmod", "+x", bin]); } catch (e) { }
	let stat = null;
	try { stat = file_stat(bin); } catch (e) { }
	let now = iso_now(db);
	db_exec(db,
		"update " + INSTALL_TABLE
		+ " set status='complete', bytes_total=?, completed_at=? where id=?",
		[(stat == null ? 0 : stat.size), now, transfer_id]);
	print("[sd_cpp] " + transfer_id + " source build complete: " + tag
		+ "/" + backend);
	return null;
}

// ─── HTTP handlers ───────────────────────────────────────────────

export fn make_handlers(db, rescan_caps_after): object {
	let do_install = fn(req): object {
		let payload = null;
		try { payload = parse(req?.body ?? "{}"); } catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let tag = payload?.tag;
		let flavor = payload?.flavor;
		if (tag == null) {
			return { status: 400, body: "{\"error\":\"tag required (e.g. master-602-0665a7f)\"}" };
		}
		if (flavor == null) {
			return { status: 400, body: "{\"error\":\"flavor required (source|vulkan|rocm|cpu|macos-arm64)\"}" };
		}
		let root = install_root();
		try { make_dirs(root); } catch (e) { }
		let target_dir = root + "/" + tag;
		let id = new_id(db);
		let now = iso_now(db);

		if (flavor == "source") {
			if (exists(target_dir)) {
				return { status: 409, body: stringify({
					error: "target dir already exists: " + target_dir
						+ " (remove it or pick a different tag)",
				})};
			}
			db_exec(db,
				"insert into " + INSTALL_TABLE + " "
				+ "(id, tag, flavor, source_url, target_dir, status, started_at) "
				+ "values (?, ?, ?, ?, ?, 'queued', ?)",
				[id, tag, "source", SD_REPO, target_dir, now]);
			let st = spawn(source_install_task, db, id, tag, "source", target_dir);
			detach(st);
			return { status: 202, body: stringify({
				install_id: id, tag: tag, flavor: "source",
				target_dir: target_dir, mode: "source-build",
			})};
		}

		// Prebuilt download path. Resolve the asset URL up front so a
		// bad tag/flavor fails the request synchronously with a 400.
		let url = null;
		try { url = resolve_asset_url(tag, flavor); } catch (e) {
			return { status: 400, body: stringify({ error: "" + e }) };
		}
		db_exec(db,
			"insert into " + INSTALL_TABLE + " "
			+ "(id, tag, flavor, source_url, target_dir, status, started_at) "
			+ "values (?, ?, ?, ?, ?, 'queued', ?)",
			[id, tag, flavor, url, target_dir, now]);
		let t = spawn(install_task, db, id, tag, flavor, url, target_dir);
		detach(t);
		return { status: 202, body: stringify({
			install_id: id, tag: tag, flavor: flavor, target_dir: target_dir,
		})};
	};

	let do_list = fn(req): object {
		let installs = query(db,
			"select id, tag, flavor, status, bytes_total, error, started_at, completed_at "
			+ "from " + INSTALL_TABLE + " "
			+ "where status in ('queued','downloading','extracting','cloning','building') "
			+ "   or started_at > datetime('now','-1 hour') "
			+ "order by started_at desc",
			[]);
		return { status: 200, body: stringify({
			installed:    list_installed(),
			recent_jobs:  installs,
			current_path: current_binary_path(),
		})};
	};

	let do_activate = fn(req): object {
		let payload = null;
		try { payload = parse(req?.body ?? "{}"); } catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let tag = payload?.tag;
		if (tag == null) {
			return { status: 400, body: "{\"error\":\"tag required\"}" };
		}
		let new_path = null;
		try { new_path = activate(tag); } catch (e) {
			return { status: 400, body: stringify({ error: "" + e }) };
		}
		try { rescan_caps_after(); } catch (e) {
			eprint("[sd_cpp] post-activate rescan failed: " + e);
		}
		return { status: 200, body: stringify({
			tag: tag, current_path: new_path,
		})};
	};

	return { install: do_install, list: do_list, activate: do_activate };
}
