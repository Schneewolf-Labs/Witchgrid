// transfers.hml — model file pulls (peer + HuggingFace).
//
// CP asks an agent to pull a model alias from somewhere; the agent
// runs the download in a detached background task and exposes
// progress via GET /models/transfers. When the file lands in the
// canonical dir, a rescan picks it up and the next /register tells
// CP the agent now has the alias.
//
// Two source kinds:
//
//   peer         — HTTP GET against another agent's /models/{alias}/blob.
//                  Source URL pre-resolved by CP.
//
//   huggingface  — shell out to `hf download <repo> <file>
//                  --local-dir <canonical>`. `hf` is the rebranded
//                  huggingface-cli; speaks Xet automatically when the
//                  repo's enabled, handles auth + retries + chunk dedup.
//                  Witchgrid never touches HF protocol bytes directly.
//
// Memory: peer pulls use @stdlib/http.download_streaming (Hemlock
// 2.3.1+) which writes chunks straight to disk — bounded memory at
// any model size.

import { exec as db_exec, query } from "@stdlib/sqlite";
import { stringify, parse } from "@stdlib/json";
import { download_streaming } from "@stdlib/http";
import { file_stat, exists, remove_file, rename } from "@stdlib/fs";
import { exec_argv } from "@stdlib/process";

export fn init_transfers_schema(db): null {
	db_exec(db, "create table if not exists model_transfers ("
		+ "id text primary key,"
		+ "alias text not null,"
		+ "source_kind text not null,"
		+ "source_url text,"
		+ "hf_repo text,"
		+ "hf_file text,"
		+ "target_path text not null,"
		+ "status text not null,"          // queued|downloading|complete|error
		+ "bytes_downloaded integer default 0,"
		+ "bytes_total integer default 0,"
		+ "error text,"
		+ "started_at text not null,"
		+ "completed_at text"
		+ ")", []);
	db_exec(db, "create index if not exists ix_transfers_status "
		+ "on model_transfers(status, started_at)", []);
	return null;
}

fn new_id(db): string {
	let r = query(db, "select hex(randomblob(8)) as id", []);
	return r[0].id;
}

fn iso_now(db): string {
	let r = query(db, "select datetime('now') as ts", []);
	return r[0].ts;
}

// Alias safety: the alias becomes a filename component (canonical/<alias>.gguf),
// so it must be a single safe path segment. Without this, a pull with
// alias="../../../etc/foo" would write attacker bytes anywhere the agent
// user can reach (arbitrary file write — critical, since auth is off by
// default). Allow only [A-Za-z0-9._-], reject empty, '/', any '..', and a
// leading '-' (which would also be read as a flag by `hf`/curl downstream).
export fn valid_alias(alias): bool {
	if (alias == null || alias.length == 0 || alias.length > 128) { return false; }
	if (alias.find("/") >= 0) { return false; }
	if (alias.find("..") >= 0) { return false; }
	if (alias.substr(0, 1) == "-") { return false; }
	let i = 0;
	while (i < alias.length) {
		let c = alias.substr(i, 1);
		let ok = (c >= "A" && c <= "Z") || (c >= "a" && c <= "z")
			|| (c >= "0" && c <= "9") || c == "." || c == "_" || c == "-";
		if (!ok) { return false; }
		i = i + 1;
	}
	return true;
}

// HF repo/file safety. These are positional args to `hf download` and
// `file` also forms a local path (canonical/<file>), so: reject any '..'
// segment, a leading '-' (flag injection), control chars, spaces, and
// shell-ish metacharacters. Slashes ARE allowed (repo is org/name, file
// may be nested in the repo tree).
export fn valid_hf_component(s): bool {
	if (s == null || s.length == 0 || s.length > 256) { return false; }
	if (s.substr(0, 1) == "-") { return false; }
	if (s.find("..") >= 0) { return false; }
	let i = 0;
	while (i < s.length) {
		let c = s.substr(i, 1);
		let ok = (c >= "A" && c <= "Z") || (c >= "a" && c <= "z")
			|| (c >= "0" && c <= "9")
			|| c == "." || c == "_" || c == "-" || c == "/";
		if (!ok) { return false; }
		i = i + 1;
	}
	return true;
}

// Pulls always land in canonical/<alias>.gguf. Filename derived from
// alias (not the source filename) so a rescan re-derives the same
// alias from the file we just wrote — round-trip stable.
export fn target_path_for(canonical_dir: string, alias: string): string {
	return canonical_dir + "/" + alias + ".gguf";
}

// Background task: HTTP GET from a peer's /models/{alias}/blob, write
// to target.partial, atomic rename to target on success. Updates the
// DB row at start, on success, on failure.
//
// Hemlock 2.3.1 download_streaming() handles the .partial + atomic
// rename internally and chunks straight to disk — bounded memory
// regardless of model size. Previous implementation buffered the
// whole response via get_binary (worked for ≤ 8 GB on schneewolf;
// would pinch at 40 GB Saoirse).
async fn pull_peer_task(db, transfer_id: string, source_url: string,
                        target: string): null {
	let partial = target + ".partial";
	db_exec(db,
		"update model_transfers set status='downloading' where id=?",
		[transfer_id]);
	try {
		let r = download_streaming(source_url, target);
		let stat = file_stat(target);
		let now = iso_now(db);
		db_exec(db,
			"update model_transfers "
			+ "set status='complete', bytes_downloaded=?, bytes_total=?, completed_at=? "
			+ "where id=?",
			[stat.size, stat.size, now, transfer_id]);
		print("[transfer] " + transfer_id + " complete: " + target
			+ " (" + stat.size + " bytes, status " + r.status_code + ")");
	} catch (e) {
		let msg = "" + e;
		db_exec(db,
			"update model_transfers set status='error', error=? where id=?",
			[msg, transfer_id]);
		// download_streaming cleans up its own .partial on success but
		// not on every failure mode — best-effort sweep.
		try { if (exists(partial)) { remove_file(partial); } } catch (ee) { }
		eprint("[transfer] " + transfer_id + " failed: " + msg);
	}
	return null;
}

// HTTP handler: POST /models/pull
//
// Body: { alias, source: { kind: "peer", url } }
// Returns 202 + { transfer_id } when the background task is queued.
//
// rescan_after: callback invoked after a successful peer pull so the
// agent's catalog picks up the new file without waiting for the next
// operator-triggered rescan.
//
// (As of v0.4 the http_server is multi-threaded, so self-pulls work
// — agent serves its own /models/{alias}/blob on one worker thread
// while another runs the pull task. The own_host parameter is kept
// for the API contract but the refuser logic is gone.)
export fn make_pull_handler(db, canonical_dir: string, rescan_after, own_host: string): object {
	return fn(req): object {
		let payload = null;
		try { payload = parse_or_throw(req?.body ?? "{}"); }
		catch (e) {
			return { status: 400, body: "{\"error\":\"bad json\"}" };
		}
		let alias = payload?.alias;
		let source = payload?.source;
		if (alias == null || source == null) {
			return { status: 400, body: "{\"error\":\"alias + source required\"}" };
		}
		// alias is a filename component — reject traversal / unsafe chars
		// before it ever touches the filesystem (see valid_alias).
		if (!valid_alias(alias)) {
			return { status: 400, body: "{\"error\":\"invalid alias: must be a single path segment of [A-Za-z0-9._-], no '..'\"}" };
		}
		let kind = source?.kind;
		let id = new_id(db);
		let target = target_path_for(canonical_dir, alias);

		if (kind == "peer") {
			let url = source?.url;
			if (url == null) {
				return { status: 400, body: "{\"error\":\"source.url required for kind=peer\"}" };
			}
			let now = iso_now(db);
			db_exec(db,
				"insert into model_transfers "
				+ "(id, alias, source_kind, source_url, target_path, status, started_at) "
				+ "values (?, ?, 'peer', ?, ?, 'queued', ?)",
				[id, alias, url, target, now]);
			let t = spawn(pull_peer_task_with_rescan, db, id, url, target, rescan_after);
			detach(t);
			return { status: 202, body: stringify({ transfer_id: id, target_path: target }) };
		}

		if (kind == "huggingface") {
			let repo = source?.repo;
			let file = source?.file;
			if (repo == null || file == null) {
				return { status: 400, body: "{\"error\":\"source.repo + source.file required for kind=huggingface\"}" };
			}
			// repo/file are passed positionally to `hf download` AND `file`
			// builds the post-download path (canonical/<file>). Reject '..'
			// (path escape on the rename source) and a leading '-' on either
			// (would be parsed as an `hf` flag). `valid_repo`/`valid_file`
			// keep this to printable, slash-bearing repo paths only.
			if (!valid_hf_component(repo) || !valid_hf_component(file)) {
				return { status: 400, body: "{\"error\":\"invalid repo/file: no '..', no leading '-', printable path chars only\"}" };
			}
			let now = iso_now(db);
			db_exec(db,
				"insert into model_transfers "
				+ "(id, alias, source_kind, hf_repo, hf_file, target_path, status, started_at) "
				+ "values (?, ?, 'huggingface', ?, ?, ?, 'queued', ?)",
				[id, alias, repo, file, target, now]);
			let t = spawn(pull_hf_task_with_rescan, db, id, repo, file,
				canonical_dir, target, rescan_after);
			detach(t);
			return { status: 202, body: stringify({ transfer_id: id, target_path: target }) };
		}

		return { status: 400, body: stringify({
			error: "unknown source kind: " + kind + " (expected 'peer' or 'huggingface')",
		})};
	};
}

// Background task: shell out to `hf download <repo> <file>
// --local-dir <canonical>`. Renames the resulting file to
// canonical/<alias>.gguf so the catalog rescan recognizes it under
// the alias the operator asked for (which may differ from the HF
// filename, e.g. they downloaded a different quant once).
//
// hf is the rebranded huggingface-cli (per user's tooling memory).
// It speaks Xet automatically when the repo is enabled, handles
// auth via ~/.cache/huggingface/token, retries chunks, dedupes
// against existing local files. We just wait for it.
async fn pull_hf_task(db, transfer_id: string, repo: string, file: string,
                      canonical_dir: string, target: string): null {
	db_exec(db,
		"update model_transfers set status='downloading' where id=?",
		[transfer_id]);
	let r = null;
	try {
		// `hf download <repo> <file> --local-dir <dir>` writes the
		// file at <dir>/<file> (preserving any nested path inside the
		// repo). We pass --local-dir-use-symlinks=False since some
		// older hf versions defaulted to symlinking into the cache
		// instead of materializing the file, which then breaks the
		// rename/scan loop. Modern `hf` (>= 0.20) ignores this flag
		// safely.
		// Flags BEFORE a `--` end-of-options marker, then the positional
		// repo/file. Even though valid_hf_component already rejects a
		// leading '-', the `--` makes flag-injection structurally
		// impossible regardless of future validator changes.
		r = exec_argv(["hf", "download", "--local-dir", canonical_dir,
			"--", repo, file]);
	} catch (e) {
		db_exec(db,
			"update model_transfers set status='error', error=? where id=?",
			["could not exec `hf download` (is huggingface_hub installed?): " + e,
			 transfer_id]);
		return null;
	}
	if (r.exit_code != 0) {
		let tail = r?.stderr ?? r?.output ?? "";
		if (tail.length > 1024) { tail = tail.substr(tail.length - 1024, 1024); }
		db_exec(db,
			"update model_transfers set status='error', error=? where id=?",
			["hf download exited " + r.exit_code + ": " + tail, transfer_id]);
		return null;
	}

	// hf wrote the file at canonical_dir/<file>. Move it to the alias-
	// derived target so a rescan re-derives the same alias from this file.
	let downloaded = canonical_dir + "/" + file;
	if (!exists(downloaded)) {
		// hf may have written into a subdirectory mirroring the repo's
		// path; try to find it.
		db_exec(db,
			"update model_transfers set status='error', error=? where id=?",
			["hf download said success but expected file at "
				+ downloaded + " is missing — check repo path", transfer_id]);
		return null;
	}
	if (downloaded != target) {
		try { rename(downloaded, target); } catch (e) {
			db_exec(db,
				"update model_transfers set status='error', error=? where id=?",
				["rename " + downloaded + " → " + target + " failed: " + e,
				 transfer_id]);
			return null;
		}
	}
	let stat = file_stat(target);
	let now = iso_now(db);
	db_exec(db,
		"update model_transfers "
		+ "set status='complete', bytes_downloaded=?, bytes_total=?, completed_at=? "
		+ "where id=?",
		[stat.size, stat.size, now, transfer_id]);
	print("[transfer] " + transfer_id + " complete (hf): " + target
		+ " (" + stat.size + " bytes)");
	return null;
}

async fn pull_hf_task_with_rescan(db, transfer_id: string, repo: string,
                                  file: string, canonical_dir: string,
                                  target: string, rescan_after): null {
	pull_hf_task(db, transfer_id, repo, file, canonical_dir, target);
	let row = query(db, "select status from model_transfers where id=?",
		[transfer_id]);
	if (row.length > 0 && row[0].status == "complete" && rescan_after != null) {
		try { rescan_after(); } catch (e) {
			eprint("[transfer] post-pull rescan failed: " + e);
		}
	}
	return null;
}

// Wrap pull_peer_task so it triggers a rescan on successful completion.
// Done at this layer rather than inside pull_peer_task itself because
// the rescan callback is captured from main()'s closure scope.
async fn pull_peer_task_with_rescan(db, transfer_id: string, source_url: string,
                                    target: string, rescan_after): null {
	pull_peer_task(db, transfer_id, source_url, target);
	let row = query(db, "select status from model_transfers where id=?",
		[transfer_id]);
	if (row.length > 0 && row[0].status == "complete" && rescan_after != null) {
		try { rescan_after(); } catch (e) {
			eprint("[transfer] post-pull rescan failed: " + e);
		}
	}
	return null;
}

// Tiny wrapper so make_pull_handler can lift JSON parsing errors as
// catchable. Hemlock's parse() throws, but we want to translate to
// a 400 cleanly without hauling in a separate try/catch dance.
fn parse_or_throw(s: string): object {
	return parse(s);
}

// HTTP handler: GET /models/transfers
//
// Returns transfers in three buckets effectively:
//   - any active (status in queued/downloading)
//   - any completed within last hour
//   - any errored within last hour
// Older finished transfers fall off so the dashboard panel doesn't
// grow without bound. Operators can still grep agent logs for older.
export fn list_transfers(db): array {
	let rows = query(db,
		"select id, alias, source_kind, source_url, hf_repo, hf_file, "
		+ "target_path, status, bytes_downloaded, bytes_total, error, "
		+ "started_at, completed_at "
		+ "from model_transfers "
		+ "where status in ('queued','downloading') "
		+ "   or started_at > datetime('now','-1 hour') "
		+ "order by started_at desc",
		[]);
	let out = [];
	for (row in rows) { out.push(row); }
	return out;
}
