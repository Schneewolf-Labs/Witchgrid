// hardware.hml — local hardware probe for the agent.
//
// Builds the hardware snapshot the agent ships to CP on registration
// and every heartbeat. Covers four dimensions:
//
//   role:     "gpu" | "cpu"  (gpu if any nvidia GPU is visible)
//   cpu:      core count
//   ram:      total + free in MB
//   gpus:     [{index, name, total_mb, free_mb, uuid}]   (empty on CPU box)
//   disks:    [{path, role, total_mb, free_mb}]          (per watched dir)
//
// CPU/RAM via @stdlib/os (cross-platform). GPU via nvidia-smi (Linux,
// CUDA box only — graceful empty on anything else). Disk free via
// `df -B1 <path>` (Linux/macOS shellout — no statvfs in @stdlib/fs yet).
//
// Disks are reported per watched dir, not per device, because the
// operator-relevant question is "is there room for another GGUF in
// the canonical dir," not "what's the layout of /dev/sdX."

import { exec_argv } from "@stdlib/process";
import { cpu_count, total_memory, free_memory } from "@stdlib/os";
import { exists, open } from "@stdlib/fs";
import { parse } from "@stdlib/json";

// Apple Silicon Metal cap: by default Metal can claim ~75% of system
// RAM as VRAM via MTLDevice.recommendedMaxWorkingSetSize; we round
// down to 66% as a placement-time conservative budget so the rest of
// macOS keeps room to breathe. llama.cpp on Metal honors this same
// cap for KV-cache + weights allocation.
let APPLE_METAL_RAM_FRACTION: f64 = 0.66;

fn probe_gpus_nvidia(): array {
	// exec_argv captures stderr instead of leaking it to the terminal AND
	// throws if the binary isn't on PATH — both branches mean "no GPUs."
	let r = null;
	try {
		r = exec_argv(["nvidia-smi",
			"--query-gpu=index,name,memory.total,memory.free,uuid,power.draw,power.limit",
			"--format=csv,noheader,nounits"]);
	} catch (e) {
		return [];
	}
	if (r.exit_code != 0 || r.output.length == 0) {
		return [];
	}

	let gpus = [];
	let lines = r.output.split("\n");
	for (line in lines) {
		let trimmed = line.trim();
		if (trimmed.length == 0) { continue; }
		let parts = trimmed.split(",");
		if (parts.length < 5) { continue; }
		// power.draw / power.limit can be "[N/A]" on cards without
		// a power sensor — keep null in that case so the dashboard
		// renders "—" instead of bogus zeroes.
		let power_draw = null;
		let power_limit = null;
		if (parts.length >= 7) {
			let pd = parts[5].trim();
			let pl = parts[6].trim();
			if (pd != "[N/A]" && pd.length > 0) { power_draw = f64(pd); }
			if (pl != "[N/A]" && pl.length > 0) { power_limit = f64(pl); }
		}
		gpus.push({
			index:        i32(parts[0].trim()),
			name:         parts[1].trim(),
			total_mb:     i32(parts[2].trim()),
			free_mb:      i32(parts[3].trim()),
			uuid:         parts[4].trim(),
			power_draw_w:  power_draw,
			power_limit_w: power_limit,
		});
	}
	return gpus;
}

// AMD probe via rocm-smi. ROCm-compatible cards (Navi 21 / RDNA2+ on
// the desktop side, plus AMD APUs / iGPUs that expose VRAM through
// HIP) get surfaced here. llama.cpp speaks HIP via the rocm-x64 build
// flavor, so a placement target like "RX 6800" actually works.
//
// One JSON call gets us name + vram + power for every card. The power
// key naming differs between dGPU ("Average Graphics Package Power")
// and APU ("Current Socket Graphics Package Power") so we match either.
//
// `start_index` lets the caller continue numbering after NVIDIA so the
// fleet has a single GPU index space — placement code doesn't need to
// know about per-vendor namespaces.
fn probe_gpus_amd(start_index: i32): array {
	let r = null;
	try {
		r = exec_argv(["rocm-smi",
			"--showmeminfo", "vram",
			"--showproductname",
			"--showpower",
			"--json"]);
	} catch (e) { return []; }
	if (r.exit_code != 0 || r.output.length == 0) { return []; }

	let parsed = null;
	try { parsed = parse(r.output); } catch (e) { return []; }
	if (parsed == null) { return []; }

	let gpus = [];
	let next_index = start_index;
	let card_keys = parsed.keys();
	for (key in card_keys) {
		let card = parsed[key];
		// VRAM fields are decimal-string bytes — convert to MB i32.
		let total_b: i64 = 0;
		let used_b:  i64 = 0;
		let tstr = card?["VRAM Total Memory (B)"];
		let ustr = card?["VRAM Total Used Memory (B)"];
		if (tstr != null) { total_b = i64(tstr); }
		if (ustr != null) { used_b  = i64(ustr); }
		let total_mb: i32 = i32(total_b / 1048576);
		let free_mb:  i32 = i32((total_b - used_b) / 1048576);
		if (free_mb < 0) { free_mb = 0; }

		// Power: try both possible keys (dGPU vs APU naming). rocm-smi
		// gives a string with no power.limit equivalent without an
		// extra call — leave limit null for now.
		let power_draw = null;
		let pd_avg = card?["Average Graphics Package Power (W)"];
		let pd_cur = card?["Current Socket Graphics Package Power (W)"];
		if (pd_avg != null) { power_draw = f64(pd_avg); }
		else if (pd_cur != null) { power_draw = f64(pd_cur); }

		// Name: "Card series" carries the human-readable label
		// ("Navi 21 [Radeon RX 6800/6800 XT / 6900 XT]"). For APUs
		// it's a hex device ID, which is uglier — fall back to
		// "AMD <SKU>" for those (e.g. "AMD RAPHAEL").
		let name = card?["Card series"] ?? "?";
		if (name.starts_with("0x")) {
			let sku = card?["Card SKU"];
			if (sku != null) { name = "AMD " + sku; }
		}

		gpus.push({
			index:         next_index,
			name:          name,
			total_mb:      total_mb,
			free_mb:       free_mb,
			uuid:          key,                // card0/card1 — stable rocm-smi handle
			power_draw_w:  power_draw,
			power_limit_w: null,
		});
		next_index = next_index + 1;
	}
	return gpus;
}

// Mac fallback. Apple Silicon GPUs have unified memory — there's no
// separate VRAM pool, Metal allocates from the same physical RAM as
// the rest of the system. We surface the M-series as a single GPU
// entry so placement can target it like an NVIDIA card; total/free
// are derived from the system RAM × APPLE_METAL_RAM_FRACTION.
//
// Detection: parse `system_profiler SPDisplaysDataType` for the
// "Chipset Model:" line. That's stable across M1/M2/M3/M4 and
// includes the full chip name ("Apple M1", "Apple M3 Pro", etc.).
fn probe_gpus_metal(ram_total_mb: i32, ram_free_mb: i32): array {
	let r = null;
	try {
		r = exec_argv(["system_profiler", "SPDisplaysDataType"]);
	} catch (e) {
		return [];
	}
	if (r.exit_code != 0 || r.output.length == 0) {
		return [];
	}
	let chipset = "";
	let lines = r.output.split("\n");
	for (line in lines) {
		let trimmed = line.trim();
		// Only Apple Silicon GPUs report Metal — discrete AMD/NVIDIA
		// on older Intel Macs would also appear here; we want the
		// Apple chip specifically.
		if (trimmed.starts_with("Chipset Model:")) {
			let rest = trimmed.substr(14, trimmed.length - 14).trim();
			if (rest.starts_with("Apple ")) {
				chipset = rest;
				break;
			}
		}
	}
	if (chipset.length == 0) { return []; }

	let total_mb = i32(f64(ram_total_mb) * APPLE_METAL_RAM_FRACTION);
	let free_mb  = i32(f64(ram_free_mb)  * APPLE_METAL_RAM_FRACTION);
	if (free_mb > total_mb) { free_mb = total_mb; }
	return [{
		index:    0,
		name:     chipset,
		total_mb: total_mb,
		free_mb:  free_mb,
		uuid:     "metal-0",
	}];
}

fn probe_gpus(ram_total_mb: i32, ram_free_mb: i32): array {
	// Linux: NVIDIA via nvidia-smi + AMD via rocm-smi, in one fleet-wide
	// index space (AMD continues numbering after NVIDIA so placement
	// doesn't need per-vendor namespaces). Either or both vendors may
	// be empty; only Apple Silicon takes the Metal fallback.
	let nv = probe_gpus_nvidia();
	let amd = probe_gpus_amd(nv.length);
	if (nv.length > 0 || amd.length > 0) {
		let merged = [];
		for (g in nv)  { merged.push(g); }
		for (g in amd) { merged.push(g); }
		return merged;
	}
	return probe_gpus_metal(ram_total_mb, ram_free_mb);
}

// `df -B1 <path>` output looks like (1024 = 1KB blocks; -B1 forces bytes):
//   Filesystem     1B-blocks         Used     Available Use% Mounted on
//   /dev/nvme0n1p2 500107862016 320451551232 154316603392  68% /
// We want the second-to-last number (Available, in bytes) and the first
// (1B-blocks total). Format is whitespace-aligned.
fn probe_disk(path: string, role: string) {
	if (!exists(path)) { return null; }
	let r = null;
	try {
		r = exec_argv(["df", "-B1", path]);
	} catch (e) {
		return null;
	}
	if (r.exit_code != 0) { return null; }

	let lines = r.output.split("\n");
	if (lines.length < 2) { return null; }
	// Take the LAST non-empty data line — `df` sometimes wraps long
	// device names onto a continuation line, but the numeric fields
	// always end up on a single line we can parse.
	let data_line = "";
	for (line in lines) {
		let trimmed = line.trim();
		if (trimmed.length == 0) { continue; }
		if (trimmed.find("Filesystem") == 0) { continue; }
		data_line = trimmed;
	}
	if (data_line.length == 0) { return null; }

	let parts = data_line.split(" ");
	let nums = [];
	for (p in parts) {
		let pp = p.trim();
		if (pp.length == 0) { continue; }
		nums.push(pp);
	}
	// Expected fields: device 1B-blocks used available use% mounted-on
	// Numbers we want are at indices 1 (total) and 3 (available).
	if (nums.length < 5) { return null; }
	let total_b: i64 = i64(nums[1]);
	let free_b:  i64 = i64(nums[3]);
	return {
		path:     path,
		role:     role,
		total_mb: i32(total_b / 1048576),
		free_mb:  i32(free_b  / 1048576),
	};
}

// Probe the canonical model dir + any extra scan dirs. Each path that
// exists turns into one entry; missing paths are skipped silently
// (operator may have configured an extra dir that isn't on this node).
//
// canonical: single path (the WITCHGRID_MODEL_DIR — where pulls land).
// extras: array of paths (WITCHGRID_MODEL_DIRS_EXTRA, read-only scans).
export fn probe_disks(canonical, extras): array {
	let out = [];
	if (canonical != null) {
		let d = probe_disk(canonical, "canonical");
		if (d != null) { out.push(d); }
	}
	if (extras != null) {
		for (p in extras) {
			let d = probe_disk(p, "scan");
			if (d != null) { out.push(d); }
		}
	}
	return out;
}

// Returns the full hardware snapshot. Disks come from probe_disks() so
// the agent can pass in whichever dirs it actually cares about.
//
// canonical_dir + extra_dirs are nullable; pass null when the model
// catalog isn't configured yet (early boot, or future CPU-only nodes
// that don't host any models).
// Unmanaged-process probe (slice C5).
//
// Lists every process holding GPU memory according to nvidia-smi, then
// drops the ones witchgrid spawned itself (matched against `known_pids`,
// the set of PIDs from the agent's services table). Output:
//
//   [{ pid, process_name, vram_mb, gpu_index, owner_uid, owner_name }]
//
// owner_uid/owner_name are best-effort via stat(/proc/<pid>) — empty
// strings if /proc isn't readable (rare on default Linux). gpu_index
// resolved from gpu_uuid by walking the gpus list we already probed.
//
// Why this exists: on shared boxes (e.g. schneewolf — nbeerbower owns
// the agent, flammenai owns FlameWorker, jupyter has its own llama-server)
// vram contention is invisible to placement unless we surface it.
// Reporting these to CP doesn't grant control over them — it just
// stops the dashboard from claiming "47 GB free" when 28 GB is in use.
// Map every listening TCP port to the pid(s) holding it, via one
// `ss -ltnp` call. Lets us answer "what port is this unmanaged
// llama-server serving on?" without a per-pid probe. Linux-only (ss);
// returns {} where ss is absent (macOS) or unreadable — callers treat
// a missing entry as "port unknown". Shape: { pid_str → [port, ...] }.
fn listening_ports_by_pid(): object {
	let out = {};
	let r = null;
	// -H drops the header row; -p needs no root to see *our* pids and
	// (on most distros) others' too. If it can't, the pid= field is just
	// absent and that proc simply has no port — non-fatal.
	try { r = exec_argv(["ss", "-Hltnp"]); } catch (e) { return out; }
	if (r.exit_code != 0 || r.output.length == 0) { return out; }

	let lines = r.output.split("\n");
	for (line in lines) {
		if (line.find("LISTEN") < 0) { continue; }
		// Tokenize on whitespace (ss pads with runs of spaces).
		let toks = [];
		let parts = line.split(" ");
		for (p in parts) { let pp = p.trim(); if (pp.length > 0) { toks.push(pp); } }
		// Columns (header-less): State Recv-Q Send-Q Local Peer Process
		if (toks.length < 4) { continue; }
		// Local Address:Port — port is after the final ':' ("0.0.0.0:8080",
		// "[::]:8080", "*:8080" all end in ":<port>").
		let local = toks[3];
		let colon = -1;
		let ci = 0;
		while (ci < local.length) {
			if (local.substr(ci, 1) == ":") { colon = ci; }
			ci = ci + 1;
		}
		if (colon < 0) { continue; }
		let port_str = local.substr(colon + 1, local.length - colon - 1);
		// Guard the i32() — skip non-numeric (shouldn't happen post-':').
		let all_digit = port_str.length > 0;
		let di = 0;
		while (di < port_str.length) {
			let c = port_str.substr(di, 1);
			if (c < "0" || c > "9") { all_digit = false; }
			di = di + 1;
		}
		if (!all_digit) { continue; }
		let port = i32(port_str);

		// One LISTEN line may name several pids: users:(("a",pid=1,fd=2),
		// ("b",pid=3,fd=4)). Walk every "pid=" occurrence.
		let rest = line;
		loop {
			let idx = rest.find("pid=");
			if (idx < 0) { break; }
			rest = rest.substr(idx + 4, rest.length - idx - 4);
			let d = 0;
			while (d < rest.length) {
				let ch = rest.substr(d, 1);
				if (ch >= "0" && ch <= "9") { d = d + 1; } else { break; }
			}
			if (d > 0) {
				let pid_str = rest.substr(0, d);
				if (!out.has(pid_str)) { out[pid_str] = []; }
				let dup = false;
				for (e in out[pid_str]) { if (e == port) { dup = true; } }
				if (!dup) { out[pid_str].push(port); }
			}
		}
	}
	return out;
}

// Full argv of a pid from /proc/<pid>/cmdline (NUL-separated). Returns
// "" when unreadable (macOS, gone proc, hidepid). Trimmed + space-joined
// so it renders on one line in the dashboard detail panel.
fn read_cmdline(pid: i32): string {
	let out = "";
	try {
		let f = open("/proc/" + pid + "/cmdline", "r");
		let buf = f.read_binary();
		f.close();
		if (buf == null || buf.length == 0) { return ""; }
		let start = 0;
		let i = 0;
		while (i < buf.length) {
			if (buf[i] == 0) {
				let seg = __string_from_bytes(buf.slice(start, i));
				if (out.length > 0) { out = out + " "; }
				out = out + seg;
				start = i + 1;
			}
			i = i + 1;
		}
	} catch (e) { return ""; }
	return out.trim();
}

fn str_is_digits(s: string): bool {
	if (s == null || s.length == 0) { return false; }
	let i = 0;
	while (i < s.length) {
		let c = s.substr(i, 1);
		if (c < "0" || c > "9") { return false; }
		i = i + 1;
	}
	return true;
}

// Pull the listening port straight out of a captured cmdline. This is the
// reliable cross-user path: `ss` redacts the pid→socket mapping for other
// users' processes (no root), but /proc/<pid>/cmdline is world-readable,
// and servers spell their port out — llama-server/sd-server: `--port N`
// (or `--port=N`). Returns -1 when no explicit port flag is present.
fn port_from_cmdline(cmd: string): i32 {
	if (cmd == null || cmd.length == 0) { return -1; }
	let toks = cmd.split(" ");
	let i = 0;
	while (i < toks.length) {
		let t = toks[i];
		if (t == "--port") {
			if (i + 1 < toks.length && str_is_digits(toks[i + 1])) {
				return i32(toks[i + 1]);
			}
		}
		if (t.find("--port=") == 0) {
			let v = t.substr(7, t.length - 7);
			if (str_is_digits(v)) { return i32(v); }
		}
		i = i + 1;
	}
	return -1;
}

export fn probe_unmanaged_procs(gpus, known_pids): array {
	if (gpus.length == 0) { return []; }

	let r = null;
	try {
		r = exec_argv(["nvidia-smi",
			"--query-compute-apps=pid,process_name,used_memory,gpu_uuid",
			"--format=csv,noheader,nounits"]);
	} catch (e) {
		return [];
	}
	if (r.exit_code != 0 || r.output.length == 0) { return []; }

	// Build uuid→index lookup once.
	let uuid_to_idx = {};
	for (g in gpus) {
		if (g?.uuid != null) { uuid_to_idx[g.uuid] = g.index; }
	}
	// Hash-style "set" for quick known-pid lookup. Hemlock dicts are
	// fine for this — no native set type.
	let known = {};
	for (p in known_pids) { known["" + p] = true; }

	// pid → listening ports, probed once for the whole batch.
	let port_map = listening_ports_by_pid();

	let out = [];
	let lines = r.output.split("\n");
	for (line in lines) {
		let trimmed = line.trim();
		if (trimmed.length == 0) { continue; }
		let parts = trimmed.split(",");
		if (parts.length < 4) { continue; }
		let pid = i32(parts[0].trim());
		if (known.has("" + pid)) { continue; }
		let name = parts[1].trim();
		let vram = i32(parts[2].trim());
		let uuid = parts[3].trim();
		let gpu_idx = -1;
		if (uuid_to_idx.has(uuid)) { gpu_idx = uuid_to_idx[uuid]; }

		// Port(s) this proc listens on + its full argv — the "what
		// actually is this?" detail surfaced on click in the dashboard.
		// ss gives us own-user pids; the cmdline --port flag covers
		// other users' procs (ss redacts their pid mapping without root).
		let ports = port_map?["" + pid] ?? [];
		let cmdline = read_cmdline(pid);
		let cport = port_from_cmdline(cmdline);
		if (cport > 0) {
			let seen = false;
			for (e in ports) { if (e == cport) { seen = true; } }
			if (!seen) { ports.push(cport); }
		}

		// Owner via stat(1) — cheap, cross-distro, and survives /proc
		// hidepid=1 since stat just needs +x on /proc itself. Format
		// is "username uid", so split on whitespace.
		let owner_name = "";
		let owner_uid = -1;
		try {
			let s = exec_argv(["stat", "-c", "%U %u", "/proc/" + pid]);
			if (s.exit_code == 0) {
				let stxt = s.output.trim().split(" ");
				if (stxt.length >= 2) {
					owner_name = stxt[0];
					owner_uid = i32(stxt[1]);
				}
			}
		} catch (e) { }

		out.push({
			pid:           pid,
			process_name:  name,
			vram_mb:       vram,
			gpu_index:     gpu_idx,
			owner_name:    owner_name,
			owner_uid:     owner_uid,
			ports:         ports,
			cmdline:       cmdline,
		});
	}
	return out;
}

export fn probe(canonical_dir, extra_dirs): object {
	// Convert bytes → MB up front so the wire payload is small ints,
	// not 64-bit byte counts CP would have to divide every render.
	// Compute RAM first so the Metal probe can derive its UMA cap.
	let ram_total_b: i64 = total_memory();
	let ram_free_b:  i64 = free_memory();
	let ram_total_mb: i32 = i32(ram_total_b / 1048576);
	let ram_free_mb:  i32 = i32(ram_free_b  / 1048576);

	let gpus = probe_gpus(ram_total_mb, ram_free_mb);
	let disks = probe_disks(canonical_dir, extra_dirs);
	let role = "cpu";
	if (gpus.length > 0) { role = "gpu"; }

	return {
		role:         role,
		cpu_cores:    cpu_count(),
		ram_total_mb: ram_total_mb,
		ram_free_mb:  ram_free_mb,
		gpus:         gpus,
		disks:        disks,
	};
}
